<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_concept_sim: MM_xor + the LIVE conceptual similarity codebook on
       ConceptualSpace (doc/plans/2026-06-23-conceptual-similarity-space.md).
       Parallel pass (symbolicOrder=0) so the all-siblings concept slab is
       produced and the rotation SBOW can situate it. -->
  <architecture>
    <subsymbolicOrder>3</subsymbolicOrder>
    <data>
      <dataType>embedding</dataType>
    </data>
    <symbolicOrder>0</symbolicOrder>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.005</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <conceptualSimilarityScale>0.1</conceptualSimilarityScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <InputSpace>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
  </InputSpace>

  <PartSpace>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>200</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
    <invertible>true</invertible>
    <synthesis>radix</synthesis>
    <butterfly>true</butterfly>
  </PartSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
    <invertible>true</invertible>
    <butterfly>true</butterfly>
  </ConceptualSpace>

  <WholeSpace>
    <analysis>byte</analysis>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
  </WholeSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
  </OutputSpace>

  <SymbolSpace>
    <language>
      <start>S</start>
      <grammar>xor.grammar</grammar>
    </language>
  </SymbolSpace>

</model>
