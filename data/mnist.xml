<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <architecture>
    <conceptualOrder>2</conceptualOrder>
    <modelType>passthrough</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <weightsPath>mnist_weights.ckpt</weightsPath>

    <data>
      <dataset>mnist</dataset>
      <classificationMin>0</classificationMin>
      <classificationMax>9</classificationMax>
    </data>

    <training>
      <numEpochs>10</numEpochs>
      <autosave>true</autosave>
    </training>
  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): modelType=passthrough,
       validator doesn't fire. Original shape preserved. -->
  <InputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </InputSpace>

  <!-- VQ codebook spaces: nVectors=16 > nOutput=8 — codebook=quantize. -->
  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nVectors>8</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
