<?xml version="1.0" ?>
<model>
  <architecture>
    <conceptualOrder>1</conceptualOrder>
    <dataset>mnist</dataset>
    <modelType>passthrough</modelType>
    <numEpochs>10</numEpochs>
    <stoppingCriterion>1</stoppingCriterion>
    <classificationMin>0</classificationMin>
    <classificationMax>9</classificationMax>
    <weightsPath>output/mnist_weights.pt</weightsPath>
    <autosave>true</autosave>
  </architecture>

  <InputSpace>
    <nVectors>1</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nVectors>8</nVectors>
    <prototypes>16</prototypes>
  </PerceptualSpace>

  <ConceptualSpace>
    <nVectors>8</nVectors>
    <prototypes>16</prototypes>
  </ConceptualSpace>

  <SymbolicSpace>
    <nVectors>8</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
