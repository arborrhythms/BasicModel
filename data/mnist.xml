<?xml version="1.0" ?>
<model>
  <architecture>
    <conceptualOrder>2</conceptualOrder>
    <dataset>mnist</dataset>
    <modelType>passthrough</modelType>
    <numEpochs>10</numEpochs>
    <classificationMin>0</classificationMin>
    <classificationMax>9</classificationMax>
    <weightsPath>output/mnist_weights.pt</weightsPath>
    <autosave>true</autosave>
  </architecture>

  <InputSpace>
    <nActive>1</nActive>
    <nVectors>1</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nActive>8</nActive>
    <nVectors>16</nVectors>
  </PerceptualSpace>

  <ConceptualSpace>
    <nActive>8</nActive>
    <nVectors>16</nVectors>
  </ConceptualSpace>

  <SymbolicSpace>
    <nActive>8</nActive>
    <nVectors>8</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>1</nActive>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
