<?xml version="1.0" ?>
<model>
  <!-- MM_xor: MentalModel topology on XOR dataset for convergence testing.
       Based on MM_1B architecture (iterative [Percept,Symbol]->Concept->Symbol)
       but scaled to XOR-sized dims. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <useButterflies>true</useButterflies>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <modelType>embedding</modelType>
    <maskedPrediction>NONE</maskedPrediction>
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>
    <weightsPath></weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>400</numEpochs>
      <batchSize>64</batchSize>
      <learningRate>0.005</learningRate>
      <reverseScale>0.1</reverseScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
      <autosave>false</autosave>
      <certainty>false</certainty>
    </training>

  </architecture>

  <InputSpace>
    <nInput>0</nInput>
    <nInputDim>0</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <lexer>word</lexer>
    <codebook>false</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>

    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>true</codebook>
  </PerceptualSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>

    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
    <nonlinear>true</nonlinear>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>

    <l1Lambda>0.01</l1Lambda>
    <accumulateTruth>0</accumulateTruth>
    <codebook>true</codebook>
    <useVQVAE>true</useVQVAE>
    <commitmentBeta>0.25</commitmentBeta>
    <nonlinear>true</nonlinear>
  </SymbolicSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>1</nVectors>
    <nDim>1</nDim>
    <nOutput>1</nOutput>
    <nOutputDim>1</nOutputDim>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>

  <WordSpace>
    <useGrammar>none</useGrammar>
    <language>
      <start>S</start>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). Previously these were
             supplied by the SyntacticLayer's default_rule
             code-level fallback. -->
        <!--
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
        <S>absorb(S, S)</S>
        -->
        <S>S = not(S)</S>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>

</model>
