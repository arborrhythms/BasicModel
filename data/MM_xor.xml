<?xml version="1.0" ?>
<model>
  <!-- MM_xor: MentalModel topology on XOR dataset for convergence testing.
       Based on MM_1B architecture (iterative [Percept,Symbol]->Concept->Symbol)
       but scaled to XOR-sized dims. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <modelType>embedding</modelType>
    <!-- Stage 5 (doc/plans/2026-05-26-two-loop-pi-sigma-substrate.md):
         butterfly cascade on PerceptualSpace.pi requires the parallel
         (whole-slab) forward path so the cascade sees all N positions
         at once. Serial / per-word mode iterates the cascade with a
         single position per call (the cascade then passes through as
         a no-op). -->
    <conceptualMode>parallel</conceptualMode>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.005</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <InputSpace>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
  </InputSpace>

  <PerceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <!-- Stage 5 (doc/plans/2026-05-26-two-loop-pi-sigma-substrate.md;
         2026-05-27 revision): FFT-style element-pair butterfly cascade
         on self.pi AND self.sigma for cross-element mixing on the
         flattened ``[B, N*D]`` view (auto-computed as nInput *
         nInputDim = 8 * 10 = 80, padded internally to 128). 2x2 LDU
         per node — no torch.linalg.solve in reverse.
         For the cascade to actually flow gradient into the butterfly
         params, the perceptual codebook must NOT muxed-snap the
         pi+sigma output; set ``<codebook>none</codebook>`` on this
         Space and let the downstream SS / OS handle quantisation. -->
    <codebook>none</codebook>
    <chunking>lexicon</chunking>
    <butterfly>false</butterfly>
  </PerceptualSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
    <accumulateTruth>0</accumulateTruth>
    <codebook>quantize</codebook>
    <useVQVAE>true</useVQVAE>
  </SymbolicSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
  </OutputSpace>

  <WordSpace>
    <language>
      <start>S</start>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). Previously these were
             supplied by the SyntacticLayer's default_rule
             code-level fallback. -->
        <!--
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
        <S>absorb(S, S)</S>
        -->
        <S>S = not(S)</S>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
