<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_xor: MentalModel topology on XOR dataset for convergence testing.
       Based on MM_1B architecture (iterative [Percept,Symbol]->Concept->Symbol)
       but scaled to XOR-sized dims. -->
  <architecture>
    <subsymbolicOrder>3</subsymbolicOrder>
    <data>
      <dataType>embedding</dataType>
    </data>
    <!-- Stage 5 (doc/plans/2026-05-26-two-loop-pi-sigma-substrate.md):
         butterfly cascade on PartSpace.pi requires the parallel
         (whole-slab) forward path so the cascade sees all N positions
         at once. Serial / per-word mode iterates the cascade with a
         single position per call (the cascade then passes through as
         a no-op). -->
    <symbolicOrder>0</symbolicOrder>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.005</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <InputSpace>
    <!-- radix chunking consumes pre-lexed word tokens; pin word so it does
         not inherit the raw default (which targets analyse). -->
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
  </InputSpace>

  <PartSpace>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>200</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
    <invertible>true</invertible>
    <synthesis>radix</synthesis>
    <butterfly>true</butterfly>
  </PartSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
    <invertible>true</invertible>
    <butterfly>true</butterfly>
  </ConceptualSpace>

  <WholeSpace>
    <lexer>byte</lexer>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>14</nOutputDim>
  </WholeSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>14</nInputDim>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
  </OutputSpace>

  <SymbolicSpace>
    <language>
      <start>S</start>
      <grammar>xor.grammar</grammar>
    </language>
  </SymbolicSpace>

</model>
