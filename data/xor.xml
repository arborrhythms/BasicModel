<?xml version="1.0" ?>
<model>
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <weightsPath>xor_weights.ckpt</weightsPath>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>true</autosave>
    </training>
  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): IS, PS, CS share
       the same flat slab (4*1=4). -->
  <InputSpace>
    <nOutput>4</nOutput>
    <nVectors>2</nVectors>
  </InputSpace>

  <!-- PerceptualSpace: VQ codebook (nVectors=16 > nOutput=4) — codebook=quantize. -->
  <PerceptualSpace>
    <nOutput>4</nOutput>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </PerceptualSpace>

  <!-- ConceptualSpace: VQ codebook (nVectors=16 > nOutput=4) — codebook=quantize. -->
  <ConceptualSpace>
    <nOutput>4</nOutput>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>4</nOutput>
    <nVectors>3</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
