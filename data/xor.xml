<?xml version="1.0" ?>
<model>
  <architecture>
    <nInput>2</nInput>
    <nPercepts>3</nPercepts>
    <nConcepts>3</nConcepts>
    <nSymbols>3</nSymbols>
    <nWords>3</nWords>
    <nOutput>1</nOutput>
    <conceptualOrder>0</conceptualOrder>
    <symbolicOrder>0</symbolicOrder>
    <perceptPrototypes>16</perceptPrototypes>
    <conceptPrototypes>16</conceptPrototypes>
    <reshape>True</reshape>
    <reversePass>True</reversePass>
  </architecture>

  <training>
    <dataset>xor</dataset>
    <modelType>lm</modelType>
    <pretrained>false</pretrained>
    <numEpochs>1000</numEpochs>
    <stoppingCriterion>0.01</stoppingCriterion>
    <learningRate>0.01</learningRate>
    <detectAnomaly>true</detectAnomaly>
  </training>

  <weights>
    <path>output/xor_weights.pt</path>
    <autosave>true</autosave>
  </weights>
</model>
