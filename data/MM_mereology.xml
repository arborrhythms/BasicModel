<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_mereology: DEDICATED mereological order-raising experiment config
       (doc/specs/mereological-order-raising.md). NEVER mutate the shared
       MM_20M.xml for mereology experiments (it is a reference config pinned by
       ~19 test files); flip knobs HERE instead.

       A radix-synthesis sibling of MM_20M: PartSpace
       <synthesis>radix</synthesis> drives the PerceptStore spell-out, so an
       unfamiliar word emits a RUN of byte/prefix percepts (the order-0 PARTS
       of the word-as-WHOLE). <mereologyRaise>true</mereologyRaise> turns on the
       gated, order-0 word-whole binding (a lexer token's spell-out pids bind to
       ONE shared whole, keyed by surface text) so the whole accumulates > 1
       part and maybe_raise_order fires (S3). With the flag OFF this file would
       behave exactly like the un-gated radix baseline (byte-identical), so the gate is the only
       behavioural delta.

       STATUS: S3 (the live many-to-one binding + raise) is exercised by
       test/test_mereology_word_binding.py at the autobind level. The full
       end-to-end radix-climb training run on this config (the actual MM_20M
       mean-collapse fix) is deferred to S7; this file is the home for it. -->
  <architecture>
    <!-- parallel mereology: per-stage forward, no serial grammar loop. -->
    <symbolicOrder>0</symbolicOrder>
    <subsymbolicOrder>3</subsymbolicOrder>
    <l1Lambda>0.01</l1Lambda>
    <sigmaPi>butterfly</sigmaPi>
    <!-- S3: opt-in order-0 mereology word-whole binding + order-raising.
         Read by Models (architecture.mereologyRaise); stamps _mereology_raise
         onto PartSpace + the terminal WholeSpace. Default false elsewhere. -->
    <mereologyRaise>true</mereologyRaise>

    <!-- Basic-level bounds for the overcomplete part-tiling (Eleanor Rosch's
         "basic level"). "Size in .what" for a TEXT model = count of letters,
         so a part ranges from 0 (the Universe / no committed letters) up to
         the longest reasonable word: len("disestablishmentarianism") == 24.
         Matches outside [0, 24] are too general or too specific to keep.
         Refine these for non-text models (where size is the committed-property
         count in the relevant basis). Read only under <mereologyRaise>. -->
    <basicLevelMinSize>0</basicLevelMinSize>
    <basicLevelMaxSize>24</basicLevelMaxSize>

    <data>
      <dataType>embedding</dataType>
      <dataset>xor</dataset>
    </data>
    <training>
      <numEpochs>300</numEpochs>
      <batchSize>12</batchSize>
      <learningRate>0.01</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>8192</nOutput>
    <nVectors>256</nVectors>
    <nDim>1024</nDim>
  </InputSpace>

  <PartSpace>
    <nInput>8192</nInput>        <!--    8 FROM CONCEPTUAL -->
    <nInputDim>1024</nInputDim>     <!-- 1024 FROM CONCEPTUAL -->
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>         <!-- 8 in parallel mode, looping over 1 in symbolic mode -->
    <nOutputDim>1024</nOutputDim>

    <invertible>true</invertible>
    <!-- radix = the PerceptStore (radix trie + promotion): unfamiliar words
         spell out into byte/prefix percepts (the parts); promoted words come
         back as ONE percept (the singleton, post-climb). -->
    <synthesis>radix</synthesis>
  </PartSpace>

  <ConceptualSpace>
    <nInput>8</nInput>           <!-- 1024 FROM SYMBOLIC -->
    <nInputDim>1024</nInputDim>  <!--    8 FROM SYMBOLIC -->
    <nVectors>8</nVectors>
    <stmCapacity>8</stmCapacity>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>1024</nOutputDim>

    <invertible>true</invertible>
  </ConceptualSpace>

  <WholeSpace>
    <analysis>raw</analysis>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>1024</nOutput>
    <nOutputDim>8</nOutputDim>

    <invertible>true</invertible>
    <codebook>none</codebook>
  </WholeSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>1</nVectors>
    <nDim>1</nDim>
    <nOutput>1</nOutput>
    <nOutputDim>1</nOutputDim>
  </OutputSpace>

</model>
