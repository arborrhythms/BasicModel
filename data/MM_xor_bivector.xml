<?xml version="1.0" ?>
<model>
  <!-- MM_xor_bivector: PerceptualSpace + ConceptualSpace + SymbolicSpace
       bivector regime on the XOR dataset. Exercises spec §B3 (Perceptual)
       alongside Stage 4-6 of the 2026-05-08 conceptual-loopback design:
         - PerceptualSpace.bivectorOutput=true: forward applies Q2
           promotion (max(0, x), max(0, -x)) per slot; activation
           shape becomes [B, N, 2].
         - ConceptualSpace.bivectorOutput=true: forward returns
           [B, V_C, 2]; reverse lifts via cached SVD pseudo-inverse.
         - SymbolicSpace.bivectorOutput=true: same shape on its
           output, mirror of the C-tier.
         - svdOrthogonalInit=true on both codebooks so the lift is
           well-conditioned from t=0.
         - useButterflies=false: butterfly schedule is incompatible
           with the [P||S] widening (Note A in the spec).
         - conceptualOrder=1: single C-S step, no per-stage halving.
         - subsymbolicEnabled marker (documentation-only; loopback is
           unconditional under bivector regime). -->
  <architecture>
    <!-- Documentation marker: the symbolic loopback (P_event || S_event
         concat into ConceptualSpace's PiLayer) is unconditional under
         the bivector regime per
         doc/2026-05-08-bivector-activation-conceptual-loopback-design.md
         Stage 2. The actual gate is <ConceptualSpace><bivectorOutput>;
         no code reads this flag. -->
    <subsymbolicEnabled>true</subsymbolicEnabled>
    <modelType>embedding</modelType>
    <!-- Pure forward-only smoke: zero out truth weights and learning so
         the bivector decode path is the only thing exercised. -->
    <truthBiasScale>0.0</truthBiasScale>
    <LuminosityWeight>0.0</LuminosityWeight>
    <UniversalityWeight>0.0</UniversalityWeight>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>4</batchSize>
      <learningRate>0.0</learningRate>
      <reverseScale>0.0</reverseScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <InputSpace>
    <nVectors>8</nVectors>
    <nDim>4</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>4</nOutputDim>
  </InputSpace>

  <PerceptualSpace>
    <nInput>8</nInput>
    <nInputDim>4</nInputDim>
    <nVectors>8</nVectors>
    <!-- nDim is the codebook prototype width; the P-tier output is the
         per-slot catuskoti bivector [B, N, 2], so nOutputDim is 2
         regardless of nDim. Mirrors the ConceptualSpace block below. -->
    <nDim>2</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>2</nOutputDim>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <nonlinear>false</nonlinear>
    <bivectorOutput>true</bivectorOutput>
  </PerceptualSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>2</nInputDim>
    <nVectors>8</nVectors>
    <!-- nDim is the codebook prototype content width. Under bivector
         projection it equals nInputDim so PiLayer can stay a square
         isomorphism (2x2) and Codebook.project does the dim adaptation
         to the bivector handoff via per-prototype accumulators. The
         right-half loopback widening was retired in favour of per-
         order input sourcing on ConceptualSpace.forward, so nDim no
         longer needs to absorb S.nOutputDim. -->
    <nDim>2</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>2</nOutputDim>
    <invertible>true</invertible>
    <codebook>true</codebook>
    <nonlinear>false</nonlinear>
    <bivectorOutput>true</bivectorOutput>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>8</nInput>
    <nInputDim>2</nInputDim>
    <nVectors>8</nVectors>
    <nDim>2</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>2</nOutputDim>
    <!-- Bivector smoke: zero out the codebook regularizers. -->
    <l1Lambda>0.0</l1Lambda>
    <commitmentBeta>0.0</commitmentBeta>
    <accumulateTruth>0</accumulateTruth>
    <codebook>true</codebook>
    <nonlinear>false</nonlinear>
    <bivectorOutput>true</bivectorOutput>
  </SymbolicSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>2</nInputDim>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
  </OutputSpace>

  <WordSpace>
    <language>
      <start>S</start>
      <grammar>
        <S>S = not(S)</S>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
