<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_5M_AR: autoregressive sibling of MM_5M_IR. Same word/lexicon
       tokenization and lexicon size as MM_5M_IR so AR vs IR can be
       compared directly without confounding tokenization differences.
       Differs from MM_20M only on the input-side lexicon path. -->
  <architecture>
    <subsymbolicOrder>3</subsymbolicOrder>
    <l1Lambda>0.01</l1Lambda>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <symbolicOrder>1</symbolicOrder>
    <weightsPath>MM_5M_AR.ckpt</weightsPath>
    <amp>bf16</amp>

    <data>
      <dataType>embedding</dataType>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>BACKPROP</trainEmbedding>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
    </training>

    <server>
      <port>8005</port>
    </server>

  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): re-architected to a
       uniform 8*1024=8192 slab; mirrors MM_5M_IR and MM_20M. -->
  <InputSpace>
    <nInput>1024</nInput>
    <nDim>14</nDim>
    <nVectors>1024</nVectors>
    <nOutput>1024</nOutput>
  </InputSpace>

  <PartSpace>
    <nInput>1024</nInput>
    <nVectors>1000000</nVectors>
    <nDim>14</nDim>
    <nOutput>1024</nOutput>
    <wordLearning>1</wordLearning>
  </PartSpace>

  <!-- ConceptualSpace: final level shape is 8x1024 (flat slab 8192).
       Hierarchical mode computes per-level shapes dynamically via _level_shapes. -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>1030</nDim>
    <nVectors>512</nVectors>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <WholeSpace>
    <nInput>1024</nInput>
    <nDim>1030</nDim>
    <nInputDim>1030</nInputDim>
    <!-- Stage 1.B paired-row contract: doubled for orth + semantic. -->
    <nVectors>2000000</nVectors>
    <nOutput>1024</nOutput>
  </WholeSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>


  <SymbolSpace>
    <language>
      <!-- Start nonterminal: SyntacticLayer.compose marks a soft sentence
           boundary when row b's parse stack reduces to a single live leaf
           of this category. Outer doc-streaming loop (runEpoch) drains
           the per-row signal and dispatches soft_reset(batch=b). -->
      <start>S</start>
      <grammar>
        <S>S = intersection(S, S)</S>
        <S>S = join(S, S)</S>
      </grammar>
    </language>
  </SymbolSpace>

</model>
