<?xml version="1.0" ?>
<model>
  <!-- MM_5M_AR: autoregressive sibling of MM_5M_IR. Same word/lexicon
       tokenization and lexicon size as MM_5M_IR so AR vs IR can be
       compared directly without confounding tokenization differences.
       Differs from MM_5M only on the input-side lexicon path. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <useButterflies>true</useButterflies>
    <l1Lambda>0.01</l1Lambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <modelType>embedding</modelType>
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>
    <maxResponseLength>4096</maxResponseLength>
    <weightsPath>MM_5M_AR.ckpt</weightsPath>
    <embeddingPath>MM_5M_AR.kv</embeddingPath>
    <amp>bf16</amp>

    <data>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reverseScale>0.1</reverseScale>
      <maskedPrediction>ARIR</maskedPrediction>
      <trainEmbedding>AR</trainEmbedding>
      <autoload>true</autoload>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
      <sentenceContextWindow>5</sentenceContextWindow>
      <sentenceCentroidHistory>3</sentenceCentroidHistory>
      <sentenceLambda>1.01</sentenceLambda>
      <sentencePredictionScale>0.1</sentencePredictionScale>
      <certainty>false</certainty>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8005</port>
      <timeout>120</timeout>
    </server>

  </architecture>

  <InputSpace>
    <nInput>4096</nInput>
    <nDim>6</nDim>
    <nVectors>4096</nVectors>
    <nOutput>4096</nOutput>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <lexer>word</lexer>
    <codebook>false</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>1000000</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <nOutput>1024</nOutput>
    <hasAttention>false</hasAttention>
    <invertible>false</invertible>
    <codebook>true</codebook>
    <chunking>lexicon</chunking>
    <chunkingFrequency>1</chunkingFrequency>
  </PerceptualSpace>

  <!-- ConceptualSpace: final level shape is 4x1024.
       Hierarchical mode computes per-level shapes dynamically via _level_shapes. -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>1024</nDim>
    <nVectors>512</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <hasAttention>false</hasAttention>
    <invertible>false</invertible>
    <codebook>true</codebook>
    <chunking>lexicon</chunking>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1024</nInput>
    <nInputDim>8</nInputDim>
    <nVectors>1024</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <nOutput>1024</nOutput>
    <codebook>true</codebook>
    <accumulateTruth>0</accumulateTruth>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>


  <WordSpace>
    <useGrammar>none</useGrammar>

    <language>
      <!-- Start nonterminal: SyntacticLayer.compose marks a soft sentence
           boundary when row b's parse stack reduces to a single live leaf
           of this category. Outer doc-streaming loop (runEpoch) drains
           the per-row signal and dispatches soft_reset(batch=b). -->
      <start>S</start>
      <grammar>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>

</model>
