<?xml version="1.0" ?>
<model>
  <!-- MM_xor: MentalModel topology on XOR dataset for convergence testing.
       Based on MM_1B architecture (iterative [Percept,Symbol]->Concept->Symbol)
       but scaled to XOR-sized dims. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <modelType>embedding</modelType>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <InputSpace>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nOutput>32</nOutput>
    <lexer>byte</lexer>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>512</nVectors>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
    <chunking>bpe</chunking>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <accumulateTruth>0</accumulateTruth>
    <codebook>quantize</codebook>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>

  <WordSpace>
    <language>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>union(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
