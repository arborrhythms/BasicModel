<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_xor: MentalModel topology on XOR dataset for convergence testing.
       Based on MM_1B architecture (iterative [Percept,Symbol]->Concept->Symbol)
       but scaled to XOR-sized dims. -->
  <architecture>
    <subsymbolicOrder>3</subsymbolicOrder>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <symbolicOrder>1</symbolicOrder>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): IS.nOutput aligned
       to PS/CS (8) so the flat slab is uniform 8*10=80 across the
       IS->PS->CS pipeline. Previously IS.nOutput=32 widened the byte
       span 4x relative to PS; the BPE chunker on PS still emits per
       its own merging logic from the lexed byte input. -->
  <InputSpace>
    <nDim>14</nDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
  </InputSpace>

  <PartSpace>
    <nOutput>8</nOutput>
    <nDim>14</nDim>
    <nVectors>512</nVectors>
    <invertible>true</invertible>
    <synthesis>bpe</synthesis>
  </PartSpace>

  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>14</nDim>
    <nVectors>8</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <WholeSpace>
    <lexer>byte</lexer>
    <nOutput>8</nOutput>
    <nDim>14</nDim>
    <nVectors>8</nVectors>
    <codebook>quantize</codebook>
  </WholeSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>

  <SymbolicSpace>
    <language>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>union(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
      </grammar>
    </language>
  </SymbolicSpace>

</model>
