<?xml version="1.0" ?>
<model>
  <!-- BasicModel chatbot: ~80K params, masked-word prediction with reconstruction -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <weightsPath>BasicModel.ckpt</weightsPath>
    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>2</numEpochs>
      <batchSize>128</batchSize>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>BACKPROP</trainEmbedding>
      <autosave>true</autosave>
      <checkpointEveryBatches>500</checkpointEveryBatches>
      <sentencePrediction>true</sentencePrediction>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <lexer>sentence</lexer>
    <codebook>quantize</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <invertible>true</invertible>
    <!-- PerceptualSpace codebook is mandatory in the converged modality
         architecture; quantize (was none). -->
    <codebook>quantize</codebook>
  </PerceptualSpace>

  <!-- ConceptualSpace: nVectors = 2 * PerceptualSpace.nVectors = 128
       (invertible doubles sequence length). nActive = 2 * InputSpace.nActive = 256. -->
  <ConceptualSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <!-- SymbolicSpace: — nActive = nVectors = ConceptualSpace.nActive = 256 -->
  <SymbolicSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>100</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

</model>
