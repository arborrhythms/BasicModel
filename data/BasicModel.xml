<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- BasicModel chatbot: ~80K params, masked-word prediction with reconstruction -->
  <architecture>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <symbolicOrder>0</symbolicOrder>
    <weightsPath>BasicModel.ckpt</weightsPath>
    <data>
      <dataType>embedding</dataType>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>2</numEpochs>
      <batchSize>128</batchSize>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>BACKPROP</trainEmbedding>
      <autosave>true</autosave>
      <checkpointEveryBatches>500</checkpointEveryBatches>
      <sentencePrediction>true</sentencePrediction>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <codebook>quantize</codebook>
  </InputSpace>

  <PartSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <invertible>true</invertible>
    <!-- PartSpace is subsymbolic: its <codebook> element was retired
         (2026-06-09 asymmetric-VQ plan, sec 7 task 7); PS is hardwired to
         "none". -->
  </PartSpace>

  <!-- ConceptualSpace: nVectors = 2 * PartSpace.nVectors = 128
       (invertible doubles sequence length). nActive = 2 * InputSpace.nActive = 256. -->
  <ConceptualSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <!-- WholeSpace: — nActive = nVectors = ConceptualSpace.nActive = 256 -->
  <WholeSpace>
    <lexer>sentence</lexer>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
  </WholeSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>100</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

</model>
