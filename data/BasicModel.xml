<?xml version="1.0" ?>
<model>
  <!-- BasicModel chatbot: ~80K params, masked-word prediction with reconstruction -->
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <modelType>embedding</modelType>
    <maxResponseLength>4096</maxResponseLength>
    <weightsPath>BasicModel.ckpt</weightsPath>
    <embeddingPath>BasicModel.kv</embeddingPath>

    <data>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>2</numEpochs>
      <batchSize>8</batchSize>
      <learningRate>0.001</learningRate>
      <reverseScale>0.1</reverseScale>
      <maskedPrediction>ARLM</maskedPrediction>
      <trainEmbedding>ARLM</trainEmbedding>
      <autoload>true</autoload>
      <autosave>true</autosave>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8001</port>
      <timeout>120</timeout>
    </server>
  </architecture>

  <InputSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <lexer>sentence</lexer>
    <quantized>true</quantized>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>false</passThrough>
    <hasAttention>true</hasAttention>
    <invertible>true</invertible>
    <quantized>false</quantized>
  </PerceptualSpace>

  <!-- ConceptualSpace: nVectors = 2 * PerceptualSpace.nVectors = 128
       (invertible doubles sequence length). nActive = 2 * InputSpace.nActive = 256. -->
  <ConceptualSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <hasAttention>false</hasAttention>
    <hasNorm>false</hasNorm>
    <flatten>true</flatten>
    <invertible>true</invertible>
    <quantized>true</quantized>
  </ConceptualSpace>

  <!-- SymbolicSpace: passThrough — nActive = nVectors = ConceptualSpace.nActive = 256 -->
  <SymbolicSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>104</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>

</model>
