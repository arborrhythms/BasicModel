<?xml version="1.0" ?>
<model>
  <!-- BasicModel chatbot: ~80K params, masked-word prediction with reconstruction -->
  <architecture>
    <reconstruct>symbols</reconstruct>
    <reshape>false</reshape>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <modelType>embedding</modelType>
    <maskedPrediction>ARLM</maskedPrediction>
    <maxResponseLength>4096</maxResponseLength>

    <data>
      <dataset>text</dataset>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>2</numEpochs>
      <batchSize>8</batchSize>
      <learningRate>0.001</learningRate>
      <reconRatio>0.1</reconRatio>
      <train>CBOW</train>
      <weightsPath>BasicModel.ckpt</weightsPath>
      <embeddingPath>BasicModel.kv</embeddingPath>
      <autoload>true</autoload>
      <autosave>true</autosave>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8001</port>
      <timeout>120</timeout>
    </server>
  </architecture>

  <InputSpace>
    <nActive>128</nActive>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <tokenizer>traditional</tokenizer>
    <quantized>true</quantized>
  </InputSpace>

  <PerceptualSpace>
    <nActive>32</nActive>
    <nDim>100</nDim>
    <nVectors>0</nVectors>
    <passThrough>false</passThrough>
    <hasAttention>true</hasAttention>
    <invertible>true</invertible>
    <quantized>false</quantized>
  </PerceptualSpace>

  <!-- ConceptualSpace: nActive = 2 * InputSpace.nActive = 256
       InvertiblePiLayer in 3D (reshape=false) doubles the sequence axis,
       so the SigmaLayer receives 256 objects and outputs 256 objects. -->
  <ConceptualSpace>
    <nActive>256</nActive>
    <nDim>100</nDim>
    <nVectors>0</nVectors>
    <hasAttention>true</hasAttention>
    <hasNorm>false</hasNorm>
    <invertible>true</invertible>
    <quantized>false</quantized>
  </ConceptualSpace>

  <!-- SymbolicSpace: nActive = ConceptualSpace.nActive = 256 (1:1 mapping required) -->
  <SymbolicSpace>
    <nActive>256</nActive>
    <nDim>100</nDim>
    <nVectors>256</nVectors>
    <passThrough>false</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>1</nActive>
    <nDim>100</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

</model>
