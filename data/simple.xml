<?xml version="1.0" ?>
<model>
  <architecture>
    <dataset>mnist</dataset>
    <modelType>simple</modelType>
    <numTrials>1</numTrials>
    <numEpochs>10</numEpochs>
    <batchSize>64</batchSize>
  </architecture>

  <InputSpace>
    <nVectors>784</nVectors>
    <dim>1</dim>
  </InputSpace>

  <PerceptualSpace>
    <nVectors>784</nVectors>
    <dim>1</dim>
    <passThrough>true</passThrough>
  </PerceptualSpace>

  <ConceptualSpace>
    <nVectors>20</nVectors>
    <dim>1</dim>
  </ConceptualSpace>

  <SymbolicSpace>
    <nVectors>20</nVectors>
    <dim>1</dim>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nVectors>10</nVectors>
    <dim>1</dim>
  </OutputSpace>
</model>
