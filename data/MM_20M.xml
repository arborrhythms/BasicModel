<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <architecture>
    <modelType>embedding</modelType>
    <!-- parallel: per-stage forward via _forward_per_stage (no grammar;
         the serial sibling is MM_5M_grammar.xml). -->
    <symbolicOrder>0</symbolicOrder>
    <!-- subsymbolicOrder reverted 3->1 for a green handoff: sO=3 needs the
         multi-stage wide<->deep x combine reconciliation (the t>0 WholeSpace
         emits the wide [1024,8] form, the combine wants deep N=8 -> bind None).
         See the 2026-06-19 handoff doc; sO=3 is the desired target. -->
    <subsymbolicOrder>1</subsymbolicOrder>
    <l1Lambda>0.01</l1Lambda>
    <!-- sigmaPi=butterfly: PS.Pi and SS.Sigma use O(N log N) cross-position
         butterfly cascade (moved from per-space to architecture-level). -->
    <sigmaPi>butterfly</sigmaPi>

    <data>
      <dataset>xor</dataset>
    </data>
    <training>
      <numEpochs>600</numEpochs>
      <batchSize>12</batchSize>
      <learningRate>0.001</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>8192</nOutput>
    <nDim>5</nDim> <!-- 1 byte + 2 where + 2 when -->
    <!-- lexer>word</lexer -->
  </InputSpace>

  <PartSpace>
    <nInput>8192</nInput>        <!--    8 FROM CONCEPTUAL -->
    <nInputDim>5</nInputDim>     <!-- 1024 FROM CONCEPTUAL -->
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>         <!-- 8 in parallel mode, looping over 1 in symbolic mode -->
    <nOutputDim>1024</nOutputDim> 

    <invertible>true</invertible>
    <!-- Chunking strategy: analyse | radix | lexicon | bpe | mphf | none.
         analyse = meronymic analyzer with a space-lexer front end
         (whitespace boundary; word runs resolve through the word codebook):
         this is what reduces an 8192-char input to a small number of
         words in parallel mode without needing attention. radix = the
         PerceptStore (radix trie + promotion); flip here to experiment. -->
    <synthesis>bpe</synthesis>
    <!-- codebook>quantize</codebook -->
  </PartSpace>

  <WholeSpace>
    <!-- Phase 4b (2026-06-10) moved lexers to WholeSpace; this
         config carried only the commented-out legacy InputSpace lexer
         and so had NO live lexer at all — the content tier never
         lexed, every sentence staged as the same slab (row-identical
         [B, 8, 1024] at PS input) and no objective could learn from
         input-invariant features. Byte is the design lexer (the
         InputSpace is byte-shaped: nDim 5 = 1 byte + 2 where +
         2 when, matching MM_xor) and keeps train.py's Phase-1
         embedding skip (byte-lexer configs need no word-embedding
         pretrain; train.py reads this knob). -->
    <lexer>byte</lexer>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>1024</nOutput>
    <nOutputDim>8</nOutputDim>

    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </WholeSpace>

  <ConceptualSpace>
    <nInput>8</nInput>           <!-- 1024 FROM SYMBOLIC -->
    <nInputDim>1024</nInputDim>  <!--    8 FROM SYMBOLIC -->
    <nVectors>8</nVectors>
    <stmCapacity>8</stmCapacity>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>1024</nOutputDim>

    <invertible>true</invertible>
    <codebook>none</codebook>
  </ConceptualSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>1</nVectors>
    <nDim>1</nDim>
    <nOutput>1</nOutput>
    <nOutputDim>1</nOutputDim>
    <!-- nVectors==1 => unquantised REGRESSION head (Task #11): a 1-vector
         codebook can only name one prototype (collapses every XOR row to the
         row-mean), so the head is a bare linear nInputDim->nOutputDim with a
         sigmoid readout so the binary {0,1} XOR label is representable. -->
    <readout>sigmoid</readout>
  </OutputSpace>

</model>
