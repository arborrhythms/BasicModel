<?xml version="1.0" ?>
<model>
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <modelType>embedding</modelType>
    <ergodic>true</ergodic>
    <naive>false</naive>
    <weightsPath></weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numEpochs>600</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>false</autosave>
      <autoload>false</autoload>

      <reverseScale>0.5</reverseScale>
      <maskedPrediction>NONE</maskedPrediction>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>

    </training>
  </architecture>

  <!-- InputSpace: nOutput=6 tokens per sentence (e.g. "hello world" has 3 tokens;
       nOutput=6 allows headroom for punctuation / longer sentences). -->
  <InputSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </InputSpace>

  <!-- PerceptualSpace: invertible+flatten.
       Constraint: 2 * nInput * inputDim == nOutput * outputDim  -->
  <PerceptualSpace>
    <nOutput>12</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <!-- ConceptualSpace: nOutput=6, nVectors=6 (non-quantized: nVectors==nOutput). -->
  <ConceptualSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
    <invertible>true</invertible>
  </ConceptualSpace>

  <!-- SymbolicSpace: nOutput = ConceptualSpace.nOutput = 6 -->
  <SymbolicSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
