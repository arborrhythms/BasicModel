<?xml version="1.0" ?>
<model>
  <architecture>
    <reconstruct>symbols</reconstruct>
    <reshape>true</reshape>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <modelType>embedding</modelType>
    <ergodic>false</ergodic>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <weightsPath>xor_exact_weights.ckpt</weightsPath>
      <autosave>false</autosave>
      <autoload>false</autoload>
      <reconRatio>0.3</reconRatio>
    </training>
  </architecture>

  <!-- InputSpace: 3 tokens per sentence ("hello world" → ["hello"," ","world"])
       nActive=6 to allow headroom for punctuation / longer sentences. -->
  <InputSpace>
    <nActive>6</nActive>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <nWhere>0</nWhere>
  </InputSpace>

  <!-- PerceptualSpace: invertible+reshape requires 2*input == output.
       input = 6*10 = 60, getLayerIO output = nActive*10/2 = 120 → nActive = 24. -->
  <PerceptualSpace>
    <nActive>24</nActive>
    <nDim>10</nDim>
    <nVectors>24</nVectors>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <!-- ConceptualSpace: nVectors = 2 × PerceptualSpace.nVectors = 48. -->
  <ConceptualSpace>
    <nActive>6</nActive>
    <nDim>10</nDim>
    <nVectors>48</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <!-- SymbolicSpace: nActive = ConceptualSpace.nActive = 6 -->
  <SymbolicSpace>
    <nActive>6</nActive>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>1</nActive>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
