<?xml version="1.0" ?>
<model>
  <!-- XOR_exact: end-to-end XOR with reconstruction.

       This fixture intentionally keeps the reconstruction path
       full-width. The scalar project codebook is useful for compact
       truth activation, but it collapses per-slot content and cannot
       support this exact word-level reconstruction smoke test. -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>

    <training>
      <numEpochs>600</numEpochs>
      <learningRate>0.005</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <!-- InputSpace: text-mode lexer, full content width. -->
  <InputSpace>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <lexer>word</lexer>
  </InputSpace>

  <!-- PerceptualSpace: WIDE codebook so 1000 word prototypes have room
       to sit pairwise-distinct. Stays content-wide on the output
       (nOutputDim=nDim=10) so reconstruction lookups operate in the
       full vocabulary space. -->
  <PerceptualSpace>
    <nInput>8</nInput>
    <nVectors>1000</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <invertible>true</invertible>
    <!-- PerceptualSpace codebook is mandatory (modality re-architecture); was
         none for the project-style exact-XOR reconstruction (now superseded). -->
    <codebook>none</codebook>
    <!-- Butterfly cascade on pi (and historically sigma) gives pi
         cross-element reach across the flattened [B, N*D] view.
         Without it, pi is per-slot and cannot compute XOR (or any
         function that requires combining information across slot
         positions). XOR_exact relies on this for the exact-XOR
         convergence property. -->
    <butterfly>true</butterfly>
    <chunking>lexicon</chunking>
  </PerceptualSpace>

  <!-- ConceptualSpace: full-width, invertible reconstruction carrier. -->
  <ConceptualSpace>
    <nInput>8</nInput>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <invertible>true</invertible>
    <codebook>none</codebook>
    <butterfly>true</butterfly>
  </ConceptualSpace>

  <!-- SymbolicSpace: full-width passthrough for the exact smoke test. -->
  <SymbolicSpace>
    <nInput>8</nInput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
    <!-- XOR_exact overrides the codebook defaults: drop the SymbolicSpace
         l1 / VQ-VAE commitment for the exact-reconstruction smoke test. -->
    <l1Lambda>0.0</l1Lambda>
    <commitmentBeta>0.0</commitmentBeta>
    <!-- SymbolicSpace codebook is mandatory (modality re-architecture); was none. -->
    <codebook>none</codebook>
    <butterfly>true</butterfly>
  </SymbolicSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
  </OutputSpace>
</model>
