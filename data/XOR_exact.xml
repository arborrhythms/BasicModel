<?xml version="1.0" ?>
<model>
  <architecture>
    <reversible>true</reversible>
    <reshape>true</reshape>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <dataset>xor</dataset>
    <modelType>lm</modelType>
    <pretrained>false</pretrained>
    <numEpochs>1000</numEpochs>
    <learningRate>0.01</learningRate>
    <weightsPath>output/xor_exact_weights.pt</weightsPath>
    <autosave>false</autosave>
    <autoload>false</autoload>
    <ergodic>false</ergodic>
  </architecture>

  <InputSpace>
    <nActive>2</nActive>
    <nDim>10</nDim>
    <nVectors>2</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nActive>4</nActive>
    <nDim>10</nDim>
    <nVectors>16</nVectors>
    <invertible>false</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <ConceptualSpace>
    <nActive>4</nActive>
    <nDim>10</nDim>
    <nVectors>16</nVectors>
    <invertible>false</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nActive>4</nActive>
    <nDim>10</nDim>
    <nVectors>4</nVectors>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>1</nActive>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
