<?xml version="1.0" ?>
<model>
  <architecture>
    <conceptualOrder>1</conceptualOrder>
    <modelType>embedding</modelType>
    <ergodic>true</ergodic>
    <naive>false</naive>
    <weightsPath></weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>false</autosave>
      <autoload>false</autoload>

      <reverseScale>0.5</reverseScale>
      <maskedPrediction>NONE</maskedPrediction>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>

    </training>
  </architecture>

  <!-- InputSpace: nOutput=6 tokens per sentence (e.g. "hello world" has 3 tokens;
       nOutput=6 allows headroom for punctuation / longer sentences). -->
  <InputSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nInputDim>-1</nInputDim>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <lexer>word</lexer>
    <codebook>false</codebook>
  </InputSpace>

  <!-- PerceptualSpace: invertible, flattened input. -->
  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>1000</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
    <codebook>true</codebook>
    <chunking>lexicon</chunking>
  </PerceptualSpace>

  <!-- ConceptualSpace: nOutput=6, nVectors=6 (non-quantized: nVectors==nOutput). -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
    <nonlinear>true</nonlinear>
  </ConceptualSpace>

  <!-- SymbolicSpace: nOutput = ConceptualSpace.nOutput = 6 -->
  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nInputDim>-1</nInputDim>
    <nonlinear>true</nonlinear>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
