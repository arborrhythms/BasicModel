<?xml version="1.0" ?>
<model>
  <!-- XOR_exact: end-to-end XOR with reconstruction.

       Bivector regime starts at ConceptualSpace. PerceptualSpace stays
       wide (nDim=10, nVectors=1000) so the word codebook can pack 1000
       prototypes pairwise-distinct, which the reconstruction snap
       relies on. ConceptualSpace and SymbolicSpace use the continuous
       SVD-pseudo-inverse projection (no quantize), with the per-order
       input switch on ConceptualSpace.forward replacing the legacy
       loopback concat. -->
  <architecture>
    <modelType>embedding</modelType>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <!-- InputSpace: text-mode lexer, full content width. -->
  <InputSpace>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
  </InputSpace>

  <!-- PerceptualSpace: WIDE codebook so 1000 word prototypes have room
       to sit pairwise-distinct. Stays content-wide on the output
       (nOutputDim=nDim=10) so reconstruction lookups operate in the
       full vocabulary space. -->
  <PerceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>1000</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </PerceptualSpace>

  <!-- ConceptualSpace: bivector boundary. Forward does Pi then projects
       onto the codebook to emit per-prototype catuskoti bivector
       [B, V_C, 2]; reverse uses the cached SVD pseudo-inverse to lift
       back to [B, V_C, nDim]. -->
  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <!-- nDim is the codebook prototype content width. It equals
         nInputDim so PiLayer stays a square isomorphism (10x10); the
         scalar projection codebook (<codebook>project</codebook>) does
         the 10->1 dim adaptation, emitting one signed Degree-of-Truth
         per prototype. ProjectionBasis.reverse lifts back to nDim-wide
         content which pi.reverse consumes intact. -->
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>1</nOutputDim>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>project</codebook>
  </ConceptualSpace>

  <!-- SymbolicSpace: width-1 throughout. Symbols carry the signed
       Degree-of-Truth scalar arriving from Conceptual; their scalar
       projection codebook stores width-1 prototypes. -->
  <SymbolicSpace>
    <nInput>8</nInput>
    <nDim>1</nDim>
    <nInputDim>1</nInputDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
    <nOutputDim>1</nOutputDim>
    <!-- XOR_exact overrides the codebook defaults: drop the SymbolicSpace
         l1 / VQ-VAE commitment for the exact-reconstruction smoke test. -->
    <l1Lambda>0.0</l1Lambda>
    <commitmentBeta>0.0</commitmentBeta>
    <codebook>project</codebook>
  </SymbolicSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>1</nInputDim>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
  </OutputSpace>
</model>
