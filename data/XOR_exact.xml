<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- XOR_exact: end-to-end XOR with reconstruction.

       This fixture intentionally keeps the reconstruction path
       full-width. The scalar project codebook is useful for compact
       truth activation, but it collapses per-slot content and cannot
       support this exact word-level reconstruction smoke test. -->
  <architecture>
    <modelType>embedding</modelType>
    <subsymbolicOrder>3</subsymbolicOrder>
    <symbolicOrder>0</symbolicOrder>

    <training>
      <numEpochs>600</numEpochs>
      <learningRate>0.005</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <!-- InputSpace: text-mode lexer, full content width. -->
  <InputSpace>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
  </InputSpace>

  <!-- PartSpace: WIDE codebook so 1000 word prototypes have room
       to sit pairwise-distinct. Stays content-wide on the output
       (nOutputDim=nDim=10) so reconstruction lookups operate in the
       full vocabulary space. -->
  <PartSpace>
    <nInput>8</nInput>
    <nVectors>1000</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <invertible>true</invertible>
    <!-- PartSpace is subsymbolic: its <codebook> element was retired
         (2026-06-09 asymmetric-VQ plan, sec 7 task 7); PS is hardwired to
         "none". The 1000 word prototypes live on the .what Embedding, not a
         VQ snap on .event. -->
    <!-- Butterfly cascade on pi (and historically sigma) gives pi
         cross-element reach across the flattened [B, N*D] view.
         Without it, pi is per-slot and cannot compute XOR (or any
         function that requires combining information across slot
         positions). XOR_exact relies on this for the exact-XOR
         convergence property. -->
    <butterfly>true</butterfly>
    <synthesis>lexicon</synthesis>
  </PartSpace>

  <!-- ConceptualSpace: full-width, invertible reconstruction carrier. -->
  <ConceptualSpace>
    <nInput>8</nInput>
    <nVectors>8</nVectors>
    <nDim>14</nDim>
    <nOutput>8</nOutput>
    <invertible>true</invertible>
    <codebook>none</codebook>
    <butterfly>true</butterfly>
  </ConceptualSpace>

  <!-- WholeSpace: full-width passthrough for the exact smoke test. -->
  <WholeSpace>
    <lexer>word</lexer>
    <nInput>8</nInput>
    <nDim>14</nDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
    <!-- XOR_exact overrides the codebook defaults: drop the WholeSpace
         l1 / VQ-VAE commitment for the exact-reconstruction smoke test. -->
    <l1Lambda>0.0</l1Lambda>
    <commitmentBeta>0.0</commitmentBeta>
    <!-- WholeSpace codebook is mandatory (modality re-architecture); was none. -->
    <codebook>none</codebook>
    <butterfly>true</butterfly>
  </WholeSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
    <!-- The XOR readout is ill-conditioned (the class-FLIPPING word axis is
         ~10x lower variance than the dominant word axis) and co-adapts with
         the upstream features during joint training. At the full model LR the
         readout chases the moving features and settles near the data mean
         (~0.5: 100% accurate but mushy, MSE ~0.22). Training the readout at
         HALF the model LR makes it a slower, stable target the faster-moving
         features organise toward -> crisp 0/1 (MSE ~0.004). The features are
         separable (Adam reads them out crisp in 600 steps when frozen); the
         only issue was the two-timescale convergence. -->
    <lrScale>0.5</lrScale>
  </OutputSpace>
</model>
