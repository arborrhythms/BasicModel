<?xml version="1.0" ?>
<model>
  <!-- MM_grammar: MentalModel on XOR via non-default grammar-directed
       composition (derived from the grammar block) with VQ-VAE enabled.
       Sibling: MM_xor_grammar.xml is the useVQVAE=false variant used for
       isolated regression of the recurrent Pi-Sigma + pairwise compose
       without VQ-VAE muddying the variable. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <InputSpace>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
    <codebook>quantize</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <accumulateTruth>0</accumulateTruth>
    <codebook>quantize</codebook>
    <useVQVAE>true</useVQVAE>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>

  <WordSpace>
    <!-- Stage 3 cleanup: chartTau retired alongside the chart. The
         signal router (LanguageLayer) is the canonical parser. -->
    <language>
      <grammar>
        <compose>
          <rule>S = S</rule>
          <rule>S = not.forward(S)</rule>
          <rule>S = intersection.forward(S, S)</rule>
          <rule>S = union.forward(S, S)</rule>
          <rule>S = lower.forward(S, S)</rule>
          <rule>S = lift.forward(S, S)</rule>
        </compose>
        <generate>
          <rule>S = not.reverse(S)</rule>
          <rule>S,S = intersection.reverse(S)</rule>
          <rule>S,S = union.reverse(S)</rule>
          <rule>S,S = lower.reverse(S)</rule>
          <rule>S,S = lift.reverse(S)</rule>
        </generate>
      </grammar>
    </language>
  </WordSpace>

</model>
