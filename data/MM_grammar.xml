<?xml version="1.0" ?>
<model>
  <!-- MM_grammar: MentalModel on XOR via the grammar-directed composition
       path (useGrammar=true, useButterflies=false) with VQ-VAE enabled.
       Sibling: MM_xor_grammar.xml is the useVQVAE=false variant used for
       isolated regression of the recurrent Pi-Sigma + pairwise compose
       without VQ-VAE muddying the variable. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <useButterflies>false</useButterflies>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <processSymbols>false</processSymbols>
    <type>mental</type>
    <ergodic>false</ergodic>
    <modelType>embedding</modelType>
    <maskedPrediction>NONE</maskedPrediction>
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>
    <weightsPath></weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>400</numEpochs>
      <batchSize>64</batchSize>
      <learningRate>0.01</learningRate>
      <reverseScale>0.1</reverseScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
      <autosave>false</autosave>
      <certainty>false</certainty>
    </training>

  </architecture>

  <InputSpace>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <lexer>word</lexer>
    <codebook>true</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <nVectors>8</nVectors>
    <passThrough>true</passThrough>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <passThrough>false</passThrough>
    <l1Lambda>0.01</l1Lambda>
    <accumulateTruth>0</accumulateTruth>
    <codebook>true</codebook>
    <useVQVAE>true</useVQVAE>
    <commitmentBeta>0.25</commitmentBeta>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>

  <WordSpace>
    <useGrammar>all</useGrammar>
    <softChartCompose>true</softChartCompose>
    <chartTau>2.0</chartTau>
    <language>
      <grammar>
        <compose>
          <rule>S = not.forward(S)</rule>
          <rule>S = intersection.forward(S, S)</rule>
          <rule>S = union.forward(S, S)</rule>
          <rule>S = lower.forward(S, S)</rule>
          <rule>S = lift.forward(S, S)</rule>
        </compose>
        <generate>
          <rule>S = not.reverse(S)</rule>
          <rule>S,S = intersection.reverse(S)</rule>
          <rule>S,S = union.reverse(S)</rule>
          <rule>S,S = lower.reverse(S)</rule>
          <rule>S,S = lift.reverse(S)</rule>
        </generate>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>

</model>
