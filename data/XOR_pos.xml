<?xml version="1.0" ?>
<model>
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <modelType>embedding</modelType>
    <ergodic>false</ergodic>
    <weightsPath></weightsPath>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numEpochs>600</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>false</autosave>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <!-- InputSpace: nOutput=6; objectSize=4, embSize=nDim+objectSize=10+4=14. -->
  <InputSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
  </InputSpace>

  <!-- PerceptualSpace: invertible+flatten.
       Constraint: 2 * nInput * inputDim == nOutput * outputDim
       2 * 6 * 14 = 168 = 12 * 14  -->
  <PerceptualSpace>
    <nOutput>12</nOutput>
    <nDim>10</nDim>
    <nVectors>12</nVectors>
    <flatten>true</flatten>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <!-- ConceptualSpace: nOutput=6, nVectors=6 (non-quantized: nVectors==nOutput). -->
  <ConceptualSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
    <invertible>true</invertible>
  </ConceptualSpace>

  <!-- SymbolicSpace: nOutput = ConceptualSpace.nOutput = 6 -->
  <SymbolicSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>
</model>
