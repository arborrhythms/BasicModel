<?xml version="1.0" ?>
<model>
  <architecture>
    <conceptualOrder>2</conceptualOrder>
    <modelType>embedding</modelType>
    <weightsPath>tomatoes_weights.ckpt</weightsPath>
    <data>
      <dataset>tomatoes</dataset>
    </data>

    <training>
      <numEpochs>100</numEpochs>
      <learningRate>0.00001</learningRate>
      <autosave>true</autosave>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>8</nOutput>
    <nVectors>8</nVectors>
  </InputSpace>

  <!-- VQ codebook spaces: nVectors=16 > nOutput=8 — codebook=quantize. -->
  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nVectors>8</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
