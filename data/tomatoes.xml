<?xml version="1.0" ?>
<model>
  <architecture>
    <conceptualOrder>2</conceptualOrder>
    <dataset>tomatoes</dataset>
    <modelType>embedding</modelType>
    <pretrained>true</pretrained>
    <numEpochs>100</numEpochs>
    <learningRate>0.00001</learningRate>
    <weightsPath>output/tomatoes_weights.pt</weightsPath>
    <autosave>true</autosave>
  </architecture>

  <InputSpace>
    <nActive>8</nActive>
    <nVectors>8</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nActive>8</nActive>
    <nVectors>16</nVectors>
  </PerceptualSpace>

  <ConceptualSpace>
    <nActive>8</nActive>
    <nVectors>16</nVectors>
  </ConceptualSpace>

  <SymbolicSpace>
    <nActive>8</nActive>
    <nVectors>8</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>1</nActive>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
