<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <architecture>
    <subsymbolicOrder>2</subsymbolicOrder>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <symbolicOrder>0</symbolicOrder>
    <weightsPath>tomatoes_weights.ckpt</weightsPath>
    <data>
      <dataset>tomatoes</dataset>
    </data>

    <training>
      <numEpochs>100</numEpochs>
      <learningRate>0.00001</learningRate>
      <autosave>true</autosave>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>8</nOutput>
    <nVectors>8</nVectors>
  </InputSpace>

  <!-- PartSpace is subsymbolic (codebook retired 2026-06-09): nVectors
       (16) may exceed nOutput (8); percept prototypes live on .what. The
       ConceptualSpace below keeps its VQ codebook=quantize. -->
  <PartSpace>
    <nOutput>8</nOutput>
    <nVectors>16</nVectors>
  </PartSpace>

  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <WholeSpace>
    <nOutput>8</nOutput>
    <nVectors>8</nVectors>
  </WholeSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
