<?xml version="1.0" ?>
<model>
  <architecture>
    <conceptualOrder>2</conceptualOrder>
    <modelType>embedding</modelType>
    <data>
      <dataset>tomatoes</dataset>
    </data>

    <training>
      <numEpochs>100</numEpochs>
      <learningRate>0.00001</learningRate>
      <embeddingPath>data/embeddings/enwiki_20180420_100d.txt</embeddingPath>
      <weightsPath>output/tomatoes_weights.ckpt</weightsPath>
      <autosave>true</autosave>
    </training>
  </architecture>

  <InputSpace>
    <nActive>8</nActive>
    <nVectors>8</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nActive>8</nActive>
    <nVectors>16</nVectors>
  </PerceptualSpace>

  <ConceptualSpace>
    <nActive>8</nActive>
    <nVectors>16</nVectors>
  </ConceptualSpace>

  <SymbolicSpace>
    <nActive>8</nActive>
    <nVectors>8</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>1</nActive>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
