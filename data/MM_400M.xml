<?xml version="1.0" ?>
<model>
  <!-- MM_1B: Enhanced MM_5M scaled to ~1B params.
       True MM_5M architecture: low-dim percepts/symbols (4), high-dim
       conceptual lifting (16 verbs x 7296^2 = ~852M params).
       Butterfly path: pair_dim=8, conceptualOrder=14.
       BPE chunk merging: 1024 bytes -> 512 percepts.
       Volume: 512 percepts x 4 = 512 symbols x 4. -->
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>14</conceptualOrder>
    <useButterflies>true</useButterflies>
    <l1Lambda>0.01</l1Lambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <type>mental</type>
    <ergodic>false</ergodic>
    <modelType>embedding</modelType>
    <maskedPrediction>ARLM</maskedPrediction>
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>
    <maxResponseLength>4096</maxResponseLength>
    <weightsPath>MM_400M.ckpt</weightsPath>
    <embeddingPath>MM_400M.kv</embeddingPath>

    <data>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>2</numEpochs>
      <batchSize>64</batchSize>
      <learningRate>0.0003</learningRate>
      <reverseScale>0.1</reverseScale>
      <trainEmbedding>ARLM</trainEmbedding>
      <autoload>false</autoload>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
      <sentenceContextWindow>5</sentenceContextWindow>
      <sentenceCentroidHistory>3</sentenceCentroidHistory>
      <sentenceLambda>1.01</sentenceLambda>
      <sentencePredictionScale>0.1</sentencePredictionScale>
    </training>

    <certainty>false</certainty>

    <server>
      <host>127.0.0.1</host>
      <port>8003</port>
      <timeout>600</timeout>
    </server>

  </architecture>

  <InputSpace>
    <nDim>4</nDim>
    <nVectors>65535</nVectors>
    <nOutput>2048</nOutput>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <lexer>byte</lexer>
    <codebook>true</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nVectors>2048</nVectors>
    <nDim>4</nDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <nOutput>2048</nOutput>

    <passThrough>false</passThrough>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
  </PerceptualSpace>

  <!-- ConceptualSpace: high-dim for conceptual lifting.
       nOutput/nVectors=0 auto-resolve to nPercepts (512).
       LiftingLayer: 16 verb matrices of ~6148x6148 = ~604M params. -->
  <!-- ConceptualSpace: flatten percepts → one 12288-dim vector,
       sigma 12288→12288, then reshape to [6, 2048].
       nVectors=0 auto-resolves to nConcepts (6) for non-codebook. -->
  <ConceptualSpace>
    <nInput>1</nInput>
    <nInputDim>-1</nInputDim>
    <nVectors>6</nVectors>
    <nDim>2048</nDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <nOutput>6</nOutput>
    <nOutputDim>2048</nOutputDim>

    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>true</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1</nInput>
    <nInputDim>-1</nInputDim>
    <nVectors>8192</nVectors>
    <nDim>4</nDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <nOutput>2048</nOutput>
    <nOutputDim>6</nOutputDim>

    <passThrough>false</passThrough>
    <accumulateTruth>0</accumulateTruth>
    <codebook>true</codebook>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>

  <WordSpace>
    <useGrammar>none</useGrammar>
    <nWhere>2</nWhere>

    <language>
      <grammar>
        <S>true(S)</S>
        <S>false(S)</S>
        <S>non(S)</S>
        <S>conjunction(S, S)</S>
        <S>disjunction(S, S)</S>
        <S>what(S)</S>
        <S>where(S)</S>
        <S>when(S)</S>
        <S>query(S, S)</S>
        <S>swap(S, S)</S>
        <S>equals(S, S)</S>
        <S>part(S, S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>union(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
        <S>lift(S, S, S)</S>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>

</model>
