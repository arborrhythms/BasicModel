<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_1B: Enhanced MM_20M scaled to ~1B params.
       True MM_20M architecture: low-dim percepts/symbols (4), high-dim
       conceptual lifting (16 verbs x 7296^2 = ~852M params).
       BPE chunk merging: 1024 bytes -> 512 percepts.
       Volume: 512 percepts x 4 = 512 symbols x 4. -->
  <architecture>
    <conceptualOrder>4</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <weightsPath>MM_400M.ckpt</weightsPath>
    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>2</numEpochs>
      <learningRate>0.0003</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>BACKPROP</trainEmbedding>
      <autoload>false</autoload>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
    </training>

    <server>
      <port>8003</port>
      <!-- Long-running batched generation. -->
      <timeout>600</timeout>
    </server>

  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): IS, PS, CS must
       carry the same flat slab. CS terminal is 6*2048=12288; raise
       IS/PS slot dim from 4 to 6 so 2048*6=12288 matches. -->
  <InputSpace>
    <nDim>10</nDim>
    <nVectors>65535</nVectors>
    <nOutput>2048</nOutput>
    <lexer>byte</lexer>
    <codebook>quantize</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nVectors>2048</nVectors>
    <nDim>10</nDim>
    <nOutput>2048</nOutput>
    <invertible>true</invertible>
  </PerceptualSpace>

  <!-- ConceptualSpace: high-dim for conceptual lifting.
       nOutput/nVectors=0 auto-resolve to nPercepts (512).
       LiftingLayer: 16 verb matrices of ~6148x6148 = ~604M params. -->
  <!-- ConceptualSpace: flatten percepts → one 12288-dim vector,
       sigma 12288→12288, then reshape to [6, 2048].
       nVectors=0 auto-resolves to nConcepts (6) for non-codebook. -->
  <ConceptualSpace>
    <nInput>1</nInput>
    <nInputDim>-1</nInputDim>
    <nVectors>6</nVectors>
    <nDim>2052</nDim>
    <nOutput>6</nOutput>
    <nOutputDim>2052</nOutputDim>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1</nInput>
    <nDim>2052</nDim>
    <nInputDim>-1</nInputDim>
    <nVectors>8192</nVectors>
    <nOutput>2048</nOutput>
    <nOutputDim>10</nOutputDim>
    <codebook>quantize</codebook>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

  <WordSpace>

    <language>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>true(S)</S>
        <S>false(S)</S>
        <S>non(S)</S>
        <S>conjunction(S, S)</S>
        <S>disjunction(S, S)</S>
        <S>what(S)</S>
        <S>where(S)</S>
        <S>when(S)</S>
        <S>query(S, S)</S>
        <S>swap(S, S)</S>
        <S>isEqual(S, S)</S>
        <S>part(S, S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>union(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
        <S>lift(S, S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
