<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- XOR_recon: XOR with reconstruction symbols (last 5 WholeSpace
       slots reserved for reconstruction targets). Scalar codebook regime:
       PiLayer stays a square isomorphism inside conceptual content space. -->
  <architecture>
    <data>
      <dataType>embedding</dataType>
    </data>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <symbolicOrder>0</symbolicOrder>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): IS, PS, CS share
       the same flat slab. CS terminal projects to nOutputDim=2; align
       IS/PS to 8*2=16 to preserve the bottleneck shape end-to-end. -->
  <InputSpace>
    <nVectors>3</nVectors>
    <nDim>6</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>6</nOutputDim>
  </InputSpace>

  <PartSpace>
    <nInput>8</nInput>
    <nInputDim>6</nInputDim>
    <nVectors>1000</nVectors>
    <nDim>6</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>6</nOutputDim>
    <invertible>true</invertible>
  </PartSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>6</nInputDim>
    <nVectors>8</nVectors>
    <nDim>6</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>6</nOutputDim>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <!-- WholeSpace: nOutput > OutputSpace.nOutput so recon symbols exist (nRecon=5). -->
  <WholeSpace>
    <nInput>8</nInput>
    <!-- 2026-06-06 uniform-band migration: nDim is the EVENT width
         (nWhat + nWhere + nWhen). SS now carries (2, 2) like every other
         tier, so nDim/nInputDim/nOutputDim were bumped 2 -> 6 to preserve
         nWhat=2 (the binary truth state). -->
    <nDim>6</nDim>
    <nInputDim>6</nInputDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
    <nOutputDim>6</nOutputDim>
  </WholeSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <!-- C2 (handoff migration): OS.nInputDim 2->6 to match the uniform-band
         widened SS event (SS slab nOutput*nOutputDim = 8*6 = 48); the band
         slots ride along as inert padding into the (0,0)-band OutputSpace. -->
    <nInputDim>6</nInputDim>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
