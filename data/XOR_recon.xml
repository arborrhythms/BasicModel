<?xml version="1.0" ?>
<model>
  <architecture>
    <conceptualOrder>1</conceptualOrder>
    <modelType>embedding</modelType>
    <ergodic>false</ergodic>
    <naive>false</naive>
    <weightsPath></weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <useLibraryVQ>false</useLibraryVQ>
    <codebookRetire>false</codebookRetire>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>false</autosave>
      <autoload>false</autoload>

      <reverseScale>0.5</reverseScale>
      <maskedPrediction>NONE</maskedPrediction>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>3</nVectors>
    <nInputDim>-1</nInputDim>
    <lexer>word</lexer>
    <codebook>false</codebook>
  </InputSpace>

  <!-- PerceptualSpace: invertible, flattened input. -->
  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>1000</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
    <codebook>true</codebook>
    <chunking>lexicon</chunking>
  </PerceptualSpace>


  <!-- ConceptualSpace: nOutput=6, nVectors=6 (non-quantized: nVectors==nOutput). -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </ConceptualSpace>

  <!-- SymbolicSpace: nOutput > OutputSpace.nOutput so recon symbols exist (nRecon=5). -->
  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nInputDim>-1</nInputDim>
  </SymbolicSpace>

  <!-- OutputSpace: nOutput=1 so nReconSymbols = SymbolicSpace.nOutput - 1 = 5 -->
  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>
</model>
