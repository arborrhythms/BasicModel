<?xml version="1.0" ?>
<model>
  <!-- XOR_recon: XOR with reconstruction symbols (last 5 SymbolicSpace
       slots reserved for reconstruction targets). Bivector regime:
       PiLayer stays a square isomorphism inside conceptual content
       space; Codebook.project does the dim adaptation to the bivector
       handoff downstream. -->
  <architecture>
    <conceptualOrder>1</conceptualOrder>
    <useButterflies>false</useButterflies>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <processSymbols>false</processSymbols>
    <modelType>embedding</modelType>
    <ergodic>false</ergodic>
    <naive>false</naive>
    <weightsPath></weightsPath>
    <useLibraryVQ>false</useLibraryVQ>
    <codebookRetire>false</codebookRetire>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>false</autosave>
      <autoload>false</autoload>

      <reverseScale>0.5</reverseScale>
      <maskedPrediction>NONE</maskedPrediction>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <InputSpace>
    <nInput>0</nInput>
    <nInputDim>0</nInputDim>
    <nVectors>3</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
    <lexer>word</lexer>
    <codebook>false</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>1000</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>10</nOutputDim>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>true</codebook>
    <chunking>lexicon</chunking>
  </PerceptualSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>10</nInputDim>
    <nVectors>8</nVectors>
    <nDim>10</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>2</nOutputDim>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>true</codebook>
    <bivectorOutput>true</bivectorOutput>
  </ConceptualSpace>

  <!-- SymbolicSpace: nOutput > OutputSpace.nOutput so recon symbols exist (nRecon=5). -->
  <SymbolicSpace>
    <nInput>8</nInput>
    <nInputDim>2</nInputDim>
    <nVectors>8</nVectors>
    <nDim>2</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>2</nOutputDim>
    <codebook>true</codebook>
    <bivectorOutput>true</bivectorOutput>
  </SymbolicSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>2</nInputDim>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>
</model>
