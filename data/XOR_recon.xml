<?xml version="1.0" ?>
<model>
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <modelType>embedding</modelType>
    <ergodic>false</ergodic>
    <naive>false</naive>
    <weightsPath></weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <nWhere>2</nWhere>
    <nWhen>2</nWhen>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>false</autosave>
      <autoload>false</autoload>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>3</nOutput>
    <nDim>10</nDim>
    <nVectors>3</nVectors>
    <flatten>true</flatten>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
  </InputSpace>

  <!-- PerceptualSpace: invertible+flatten. -->
  <PerceptualSpace>
    <nOutput>3</nOutput>
    <nDim>10</nDim>
    <nVectors>3</nVectors>
    <flatten>true</flatten>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>


  <!-- ConceptualSpace: nOutput=6, nVectors=6 (non-quantized: nVectors==nOutput). -->
  <ConceptualSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
    <invertible>true</invertible>
  </ConceptualSpace>

  <!-- SymbolicSpace: nOutput > OutputSpace.nOutput so recon symbols exist (nRecon=5). -->
  <SymbolicSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <flatten>true</flatten>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <!-- OutputSpace: nOutput=1 so nReconSymbols = SymbolicSpace.nOutput - 1 = 5 -->
  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>
</model>
