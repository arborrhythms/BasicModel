<?xml version="1.0" ?>
<model>
  <architecture>
    <reconstruct>symbols</reconstruct>
    <reshape>true</reshape>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <modelType>embedding</modelType>
    <ergodic>false</ergodic>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numEpochs>400</numEpochs>
      <learningRate>0.01</learningRate>
      <weightsPath>xor_recon_weights.ckpt</weightsPath>
      <autosave>false</autosave>
      <autoload>false</autoload>
    </training>
  </architecture>

  <!-- InputSpace: 3 tokens per sentence ("hello world" -> ["hello"," ","world"]) -->
  <InputSpace>
    <nActive>3</nActive>
    <nDim>10</nDim>
    <nVectors>3</nVectors>
  </InputSpace>

  <!-- PerceptualSpace: nActive = 4 * InputSpace.nActive = 12
       Satisfies invertible=true+reshape=true constraint: 2*input == output -->
  <PerceptualSpace>
    <nActive>12</nActive>
    <nDim>10</nDim>
    <nVectors>12</nVectors>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <!-- ConceptualSpace: nVectors = 2 * PerceptualSpace.nVectors = 24 (required) -->
  <ConceptualSpace>
    <nActive>6</nActive>
    <nDim>10</nDim>
    <nVectors>24</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <!-- SymbolicSpace: nActive > OutputSpace.nActive for recon symbols to exist -->
  <SymbolicSpace>
    <nActive>6</nActive>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <!-- OutputSpace: nActive=1 so nReconSymbols = SymbolicSpace.nActive - 1 = 5 -->
  <OutputSpace>
    <nActive>1</nActive>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
