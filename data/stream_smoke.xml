<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- Streaming-path micro smoke: 200 docs, 1 epoch, batchSize=4.
       Exercises SentenceStreamDataset + _runEpoch_streaming end-to-end
       without the cost of a full BasicModel training run. -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <weightsPath>stream_smoke.ckpt</weightsPath>
    <data>
      <dataset>text</dataset>
      <shardDir>data/fineweb</shardDir>
      <maxDocs>200</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>4</batchSize>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>BACKPROP</trainEmbedding>
      <autoload>false</autoload>
      <sentencePrediction>true</sentencePrediction>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <lexer>sentence</lexer>
    <codebook>quantize</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <invertible>true</invertible>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>104</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

</model>
