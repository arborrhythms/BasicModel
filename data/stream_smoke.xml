<?xml version="1.0" ?>
<model>
  <!-- Streaming-path micro smoke: 200 docs, 1 epoch, batchSize=4.
       Exercises SentenceStreamDataset + _runEpoch_streaming end-to-end
       without the cost of a full BasicModel training run. -->
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <modelType>embedding</modelType>
    <maxResponseLength>4096</maxResponseLength>
    <weightsPath>stream_smoke.ckpt</weightsPath>
    <embeddingPath>stream_smoke.kv</embeddingPath>

    <data>
      <dataset>text</dataset>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>200</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>1</numEpochs>
      <batchSize>4</batchSize>
      <numWorkers>0</numWorkers>
      <learningRate>0.001</learningRate>
      <reverseScale>0.1</reverseScale>
      <maskedPrediction>ARLM</maskedPrediction>
      <trainEmbedding>ARLM</trainEmbedding>
      <autoload>false</autoload>
      <autosave>false</autosave>
      <sentencePrediction>true</sentencePrediction>
      <sentenceContextWindow>5</sentenceContextWindow>
      <sentenceCentroidHistory>3</sentenceCentroidHistory>
      <sentenceLambda>1.01</sentenceLambda>
      <sentencePredictionScale>0.1</sentencePredictionScale>
      <certainty>false</certainty>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8001</port>
      <timeout>120</timeout>
    </server>
  </architecture>

  <InputSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <lexer>sentence</lexer>
    <codebook>true</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>false</passThrough>
    <hasAttention>true</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <hasAttention>false</hasAttention>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
    <codebook>true</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>104</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>

</model>
