<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_symbol_attention: LIGHTS ON (2026-06-22). Derived from
       MM_symbol_tower.xml. This config turns the attention path LIVE rather
       than leaving it dark/parked:

         <globalAttention>      free attention ranges over the TYPED addressable
                                space (input window / STM / LTM / codebook),
                                emitting a typed `.where` + a soft-read; today it
                                addresses the whole/percept codebook (the SS
                                symbol codebook feed is the next switch).
         <globalAttentionConsume> feeds the parked soft-read BACK into the head
                                as a zero-init gated residual, so the output loss
                                trains the retrieval (gradient through the read ->
                                alpha -> the scorer). The consumer is already
                                wired (Models._forward + GlobalAttention.consume).
         <learning>/<exploreTemperature> the two-pass stochastic element the free
                                attention needs to break symmetry (it has no
                                next-word target of its own).

       Inherits symbolTower + mereologyRaise from the symbol-tower experiment.
       Off-path (every other config) is untouched -> byte-identical. -->
  <architecture>
    <!-- parallel mereology: per-stage forward, no serial grammar loop. -->
    <symbolicOrder>0</symbolicOrder>
    <subsymbolicOrder>3</subsymbolicOrder>
    <l1Lambda>0.01</l1Lambda>
    <sigmaPi>butterfly</sigmaPi>
    <mereologyRaise>true</mereologyRaise>
    <symbolTower>true</symbolTower>

    <!-- LIGHTS ON: the attention path, live + consumed. -->
    <learning>true</learning>
    <exploreTemperature>0.5</exploreTemperature>
    <globalAttention>true</globalAttention>
    <globalAttentionConsume>true</globalAttentionConsume>

    <basicLevelMinSize>0</basicLevelMinSize>
    <basicLevelMaxSize>24</basicLevelMaxSize>

    <data>
      <dataType>embedding</dataType>
      <dataset>xor</dataset>
    </data>
    <training>
      <numEpochs>300</numEpochs>
      <batchSize>12</batchSize>
      <learningRate>0.01</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>8192</nOutput>
    <nVectors>256</nVectors>
    <nDim>1024</nDim>
  </InputSpace>

  <PartSpace>
    <nInput>8192</nInput>        <!--    8 FROM CONCEPTUAL -->
    <nInputDim>1024</nInputDim>     <!-- 1024 FROM CONCEPTUAL -->
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>         <!-- 8 in parallel mode, looping over 1 in symbolic mode -->
    <nOutputDim>1024</nOutputDim>

    <invertible>true</invertible>
    <synthesis>radix</synthesis>
  </PartSpace>

  <ConceptualSpace>
    <nInput>8</nInput>           <!-- 1024 FROM SYMBOLIC -->
    <nInputDim>1024</nInputDim>  <!--    8 FROM SYMBOLIC -->
    <nVectors>8</nVectors>
    <stmCapacity>8</stmCapacity>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>1024</nOutputDim>

    <invertible>true</invertible>
  </ConceptualSpace>

  <WholeSpace>
    <analysis>raw</analysis>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>1024</nOutput>
    <nOutputDim>8</nOutputDim>

    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </WholeSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>1</nVectors>
    <nDim>1</nDim>
    <nOutput>1</nOutput>
    <nOutputDim>1</nOutputDim>
  </OutputSpace>

</model>
