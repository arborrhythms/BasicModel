<?xml version="1.0" ?>
<model>
  <!-- MM_shamatha: Dakpo Tashi Namgyel one-pointedness via convex-hull
       fusion. Mirrors MM_boolean's DNF stack (NegationLayer + Sigma AND-fold
       + Pi OR-fold) and adds the `Contiguous(S)` rule that fires
       ContiguousLayer before NegationLayer when thought_free is on.
       The four SymbolicSpace regularizer knobs (l1Lambda,
       discontinuityLambda, impenetrableOverlap, impenetrableVariance)
       apply regardless of mode. -->
  <architecture>
    <!-- conceptualOrder=0 is structurally required by useGrammar="thoughtFree"
         (Models.py: thoughtFree => no higher-order P/C/S cycles). -->
    <conceptualOrder>0</conceptualOrder>
    <useButterflies>false</useButterflies>
    <l1Lambda>0.01</l1Lambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <type>mental</type>
    <ergodic>false</ergodic>
    <modelType>embedding</modelType>
    <maskedPrediction>NONE</maskedPrediction>
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>
    <monotonic>true</monotonic>
    <weightsPath></weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>400</numEpochs>
      <batchSize>64</batchSize>
      <learningRate>0.01</learningRate>
      <reverseScale>0.1</reverseScale>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
      <autoload>false</autoload>
      <autosave>false</autosave>
    </training>

  </architecture>

  <WordSpace>
    <useGrammar>thoughtFree</useGrammar>
    <language>
      <start>S</start>
      <grammar>
        <!-- Contiguous(S) was retired 2026-05-04 (duplicate of
             disjunction at S-tier). Migrated to disjunction(S, S);
             the post-codebook scalar-max semantics deliver the
             same hull-style fold the rule used to provide.

             Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C) listed below. -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>disjunction(S, S)</S>
        <S>not(S)</S>
        <S>union(C, C)</S>
        <S>C</S>
        <C>intersection(C, C)</C>
        <C>P</C>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>

  <InputSpace>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nOutput>8</nOutput>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <lexer>word</lexer>
    <codebook>true</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <hasAttention>false</hasAttention>
    <invertible>false</invertible>
    <codebook>false</codebook>
  </PerceptualSpace>

  <!-- ConceptualSpace: hierarchical mode computes per-level shapes from
       nPercepts=8 × dim=12.  Final level: 1 vector × 96 dim.
       XML nDim/nVectors describe the final level for non-hierarchical compat. -->
  <ConceptualSpace>
    <nOutput>16</nOutput>
    <nDim>12</nDim>
    <nVectors>16</nVectors>
    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>8</nOutput>
    <nDim>10</nDim>
    <nVectors>8</nVectors>
    <accumulateTruth>0</accumulateTruth>
    <!-- codebook=true is required so the SparsityRegLayer / VQ-VAE
         path is active; the four regularizer knobs below operate on
         the codebook tensor. -->
    <codebook>true</codebook>
    <l1Lambda>0.01</l1Lambda>
    <discontinuityLambda>0.01</discontinuityLambda>
    <impenetrableOverlap>0.1</impenetrableOverlap>
    <impenetrableVariance>0.01</impenetrableVariance>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
  </OutputSpace>

</model>
