<?xml version="1.0" ?>
<model>
  <!-- BasicModel configuration -->
  <architecture>
    <conceptualOrder>1</conceptualOrder>
    <!-- Enable reverse (reconstruction) pass -->
    <reversePass>true</reversePass>
    <!-- Training hyperparameters -->
    <numEpochs>10</numEpochs>
    <batchSize>10</batchSize>
    <learningRate>0.01</learningRate>
    <stoppingCriterion>0.1</stoppingCriterion>
    <!-- Dataset: mnist | xor | tomatoes -->
    <dataset>mnist</dataset>
    <modelType>passthrough</modelType>
    <!-- Path to saved weights (relative to basicmodel/ root) -->
    <weightsPath>output/weights.pt</weightsPath>
    <!-- Auto-load weights on startup if available -->
    <autoload>true</autoload>
    <!-- Auto-save weights after training -->
    <autosave>true</autosave>
  </architecture>

  <InputSpace>
    <nVectors>32</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nVectors>64</nVectors>
    <prototypes>128</prototypes>
  </PerceptualSpace>

  <ConceptualSpace>
    <nVectors>256</nVectors>
    <prototypes>512</prototypes>
  </ConceptualSpace>

  <SymbolicSpace>
    <nVectors>2</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nVectors>32</nVectors>
  </OutputSpace>

  <server>
    <!-- HTTP interface settings (for WikiOracle integration) -->
    <host>127.0.0.1</host>
    <port>8001</port>
    <timeout>120</timeout>
  </server>
</model>
