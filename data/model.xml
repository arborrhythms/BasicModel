<?xml version="1.0" ?>
<!--
  model.xml — canonical defaults for BasicModel.

  Every parameter that create_from_config() reads must appear here.
  Model-specific XML files (XOR_exact.xml, BasicModel.xml, …) override
  individual values; anything they omit inherits from this file.

  Sentinels:
    nInput=0   InputSpace: derive from TheData; other spaces: derive
               from the previous space's outputShape[0].
    nOutput=0  Same as nInput for this space (passthrough count).
    nVectors=0 Same as nOutput (used for non-codebook spaces).
-->
<model>
  <architecture>
    <!-- Model archetype: simple (feedforward), embedding (LM/chat),
         passthrough (identity bench), vq (VQ-only). -->
    <modelType>simple</modelType>

    <!-- Reconstruction-loss target: none | symbols | concepts | both.
         'symbols' / 'concepts' compare the body's tier event at masked
         positions to a derived target (lifted through sigma_percept
         on the fly); 'both' fires both losses.  Forward-only — there
         is no reverse pipeline. 2026-05-28: 'concepts' is the only
         supported reconstructor today (it routes reverse through
         ``_run_pipeline_rev_from_concepts``); other values fall
         through to the legacy OutputSpace reverse path. Default is
         'concepts'; per-config overrides should not be needed and
         have been stripped from non-default XMLs. -->
    <reconstruct>concepts</reconstruct>

    <!-- Iteration depth of the P→C→S pipeline.  order > 1 partitions
         the symbolic codebook geometrically (see Reasoning.md). -->
    <conceptualOrder>1</conceptualOrder>

    <!-- Stage 1.E (doc/plans/2026-05-26-two-loop-pi-sigma-substrate.md):
         explicit two-mode forward dispatch.
           serial    = GRAMMATICAL: per-word body via
                       _forward_body_per_word (one IS_t per word, push
                       to STM per word). Grammar configs default here.
           parallel  = per-stage body via _forward_per_stage
                       (T iterations from <conceptualOrder>). Non-grammar
                       configs (whole-slab path) default here.
         The default is OMITTED here so each config inherits via the
         grammar-derived default: ``serial`` when the XML enables a
         non-substrate rule (``useGrammar != 'none'``), else
         ``parallel``. Concrete configs should set this explicitly so
         the mode is documented at the config level. -->
    <!-- <conceptualMode>serial|parallel</conceptualMode> -->

    <!-- Task 4 (doc/plans/2026-05-29-stm-serial-parallel-modes.md §4):
         per-word router-fire gating for serial mode.
           per-word  = fire wordSubSpace.compose once per word in the
                       serial per-word loop (the intra-predictor's
                       routing context); boundary fire OFF.
           boundary  = fire only at the sentence boundary
                       (_chart_compose_at_C / _chart_generate_from_stm);
                       the inter-sentence predictor's routing snapshot.
           both      = (DEFAULT) per-word during training so the
                       intra-predictor sees routing context, AND boundary
                       still fires for the inter-sentence predictor.
           off       = neither fires.
         Default ``both`` preserves the pre-existing boundary-fire
         behaviour. -->
    <routerWireSerial>both</routerWireSerial>


    <!-- Apply extra symbolic processing steps after Sigma. -->
    <processSymbols>false</processSymbols>

    <!-- Constrain invertible Sigma / Pi to W ≥ 0 so the lift / lower
         chain is order-preserving on the parthood cone (Spaces.md). -->
    <monotonic>false</monotonic>

    <!-- Ergodic exploration: every Layer uses
         W_eff = bias * W + temp * noise. -->
    <ergodic>false</ergodic>

    <!-- Materialise W_eff densely in InvertibleLinearLayer (slower;
         debugging only).  False uses sequential L/D/U triangular solves. -->
    <naive>false</naive>

    <!-- Positional / temporal encoding dimensions appended to each
         vector.  > 0 enables PositionalEncoding / TemporalEncoding
         across the whole model. -->
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>

    <!-- gensim KeyedVectors path; empty disables embedding load. -->
    <embeddingPath></embeddingPath>
    <!-- Checkpoint path for the neural model weights. -->
    <weightsPath></weightsPath>

    <!-- Inference token budget (characters / bytes / tokens).  Caps
         output alongside InputSpace.nActive. -->
    <maxResponseLength>4096</maxResponseLength>

    <!-- AMP autocast mode: off | fp16 | bf16. -->
    <amp>off</amp>

    <!-- TruthLayer integration (see Reasoning.md, Ethics.md).
         truthBiasScale: luminosity bias on concept input during forward.
         LuminosityWeight: multiplicative loss penalty for incoherent truths.
         UniversalityWeight: multiplicative loss penalty for unkind props. -->
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>

    <!-- Quaternary-corner balance (catuskoti / tetralemma).
         allowExcludedMiddle:  1=permit NEITHER (default), -1=classical LEM
         allowContradiction:   0=forbid BOTH (default), 1=paraconsistent
         See BuddhistParallels.md for the 4-valued truth semantics. -->
    <allowExcludedMiddle>1</allowExcludedMiddle>
    <allowContradiction>0</allowContradiction>

    <!-- L1 sparsity penalty on lift / lower gates.  Opt-in; 0 disables. -->
    <gateL1Lambda>0.0</gateL1Lambda>

    <!-- Sparse-MoE load-balance loss weight (Shazeer et al. 2017).
         Originally active only when WordSpace.chartTopK > 0; chart
         retired Stage 3 and the knob now stands by for any future
         signal-router rule load-balancing. -->
    <loadBalanceWeight>0.0</loadBalanceWeight>

    <!-- Architecture-wide L1 / discontinuity penalties (legacy hooks).
         Most configs leave these at 0 and use SymbolicSpace.l1Lambda. -->
    <l1Lambda>0.0</l1Lambda>
    <discontinuityLambda>0.0</discontinuityLambda>

    <!-- Symbol-partition geometry for conceptualOrder > 1.
         tapered = geometrically narrowing slices (default);
         uniform = equal-width slices. -->
    <conceptualWidth>tapered</conceptualWidth>
    <maxActivePerLayer>8</maxActivePerLayer>
    <codebookRetire>false</codebookRetire>

    <!-- Single continuous truth bar in [0, 1] (read onto BOTH
         ConceptualSpace and SymbolicSpace; overridable per-space).
         1 = nothing learned/recorded (highest bar); 0 = everything
         learned/recorded (no bar). Governs BOTH content-aware
         learned-relation insertion into the relative-sentence codebook
         AND SymbolicSpace truth recording (gold ingestion + training).
         Replaces the retired binary accumulateTruth / truthMinMagnitude
         switches. Default 1.0: truth-learning is OFF by default (opt-in by
         lowering toward 0). -->
    <truthCriterion>1.0</truthCriterion>

    <!-- Runtime symbol-learning hooks. Disabled by default. -->
    <symbolLearning>
      <enabled>false</enabled>
    </symbolLearning>


    <data>
      <!-- Dataset key: xor | mnist | tomatoes | text | inline.
           Omit for inference-only models. -->
      <dataset>xor</dataset>
      <!-- Shard count and per-shard document cap (streaming datasets). -->
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <!-- Directory containing text shards (e.g. data/fineweb). -->
      <shardDir></shardDir>
      <!-- Vocabulary admission threshold (fraction of corpus).
           0.0 admits all words immediately. -->
      <minFrequency>0.0</minFrequency>
      <!-- Optional bounds for classification-accuracy reporting. -->
      <classificationMin></classificationMin>
      <classificationMax></classificationMax>
    </data>

    <training>
      <!-- Number of independent training runs per invocation. -->
      <numTrials>1</numTrials>
      <!-- Training epochs per trial. -->
      <numEpochs>3</numEpochs>
      <!-- Contiguous streams through the dataset; each row b receives
           the next item from stream b so context stays coherent. -->
      <batchSize>64</batchSize>
      <!-- DataLoader prefetch workers; 0 = synchronous in-process. -->
      <numWorkers>0</numWorkers>
      <!-- Adam learning rate. -->
      <learningRate>0.001</learningRate>
      <!-- Weight of reconstruction loss vs prediction loss in [0,1]:
           total = (1-r)*output + r*recon. -->
      <reconstructionScale>0.5</reconstructionScale>
      <!-- Per-channel triple loss scales (what / where / when). -->
      <whatScale>0.7</whatScale>
      <whereScale>0.2</whereScale>
      <whenScale>0.1</whenScale>
      <!-- Negative samples per positive for CBOW / SBOW training. -->
      <negSamples>64</negSamples>
      <!-- Additive penalty for propositions contradicting the TruthSet;
           uses union-norm reduction.  0 disables. -->
      <TruthLoss>0.0</TruthLoss>

      <!-- Within-sentence training is IR-only (masked-LM at the P-tier).
           IR-mode Bernoulli probability that a percept is replaced by
           NULL_PERCEPT.  Range [0,1]; BERT default 0.15. -->
      <maskRate>0.15</maskRate>

      <!-- Embedding update mode:
           NONE | CBOW | SBOW | BACKPROP | BOTH | JOINT. -->
      <trainEmbedding>NONE</trainEmbedding>
      <!-- Embedding co-occurrence loss weight λ in JOINT mode. -->
      <embeddingScale>0.25</embeddingScale>

      <!-- Load weights from weightsPath at construction. Training configs
           default to true so runs resume from existing checkpoints; stale
           incompatible checkpoints fail fast and should be moved/deleted
           or regenerated. -->
      <autoload>true</autoload>
      <!-- Persist weights when training completes. -->
      <autosave>false</autosave>
      <!-- Mid-training checkpoint cadence (optimizer steps).  0 disables. -->
      <checkpointEveryBatches>0</checkpointEveryBatches>
      <!-- cProfile the training loop. -->
      <profile>false</profile>
      <!-- Per-neuron certainty tracking in ergodic layers. -->
      <certainty>false</certainty>

      <!-- Inter-sentence ARMA(p, q) next-sentence prediction
           (InterSentenceLayer).  The layer's AR/MA orders + hidden
           dim live under <WordSpace> (armaP/armaQ/armaHiddenDim);
           this scale is the loss weight applied on top of the
           per-batch ARMA MSE.  Off by default. -->
      <sentencePrediction>false</sentencePrediction>
      <armaScale>0.1</armaScale>
      <!-- Priming: ARMA prediction cast into concept_dim and added as
           a bias to concept_input before the sigma-pi loop.  Scaled
           by confidence * sentencePrimingScale.  Default small. -->
      <sentencePrimingScale>0.05</sentencePrimingScale>

      <!-- In-STM autoregressive prediction (IntraSentenceLayer, STM
           serial/parallel modes plan).  Loss weight on the per-word
           L_intra = MSE(predicted idea, observed idea) added to the
           IR-loss path.  The PI-then-Sigma predictor itself is owned by
           ConceptualSpace; this scales its contribution to the total
           loss. -->
      <intraLossWeight>0.1</intraLossWeight>

      <!-- Inter-sentence end-state prediction (InterSentenceLayer's
           inter-level IntraSentenceLayer instance, STM serial/parallel
           modes plan §9).  Loss weight on the per-sentence L_inter =
           MSE(predicted next-end-state root, observed root) summed over
           the discourse window and added to the loss path.  Mirrors
           <intraLossWeight>; the predictor reads the LTM end-state chain
           on the InterSentenceLayer. -->
      <interLossWeight>0.1</interLossWeight>
    </training>

    <server>
      <!-- HTTP serve.py bind address. -->
      <host>127.0.0.1</host>
      <!-- HTTP serve.py port (override per model to run in parallel). -->
      <port>8001</port>
      <!-- Per-request timeout in seconds. -->
      <timeout>120</timeout>
    </server>

  </architecture>

  <WordSpace>
    <!-- SyntacticLayer MLP hidden size (prev hardcoded 64..256). -->
    <syntacticHiddenDim>64</syntacticHiddenDim>

    <!-- Truth memory capacity (TruthLayer is owned by WordSpace). -->
    <truthMaxEntries>1024</truthMaxEntries>

    <!-- Long-term-memory (LTM) chain capacity (InterSentenceLayer):
         bounds the per-row chain of STM end-states (the AR sequence
         used for inter-sentence prediction).  Separate from
         <truthMaxEntries>.  Default 1024. -->
    <ltmCapacity>1024</ltmCapacity>

    <!-- Stage 3 cleanup (2026-05-27): the chart and STM shift-reduce
         parsers retired in favour of the signal router (LanguageLayer).
         The retired knobs (parserBackend, routerKind, chartTau,
         wMax, chartTopK, chartNoiseEps) raise a loud ValueError at
         config load time. See
         Language._assert_retired_chart_knobs_absent. -->

    <!-- Soft-superposition output collapse mode; preserved for the
         signal router's root-state writeback contract. -->
    <chartCollapse>root</chartCollapse>

    <!-- Per-word P->C loop count before parser/body composition. -->
    <iterationsPerWord>1</iterationsPerWord>

    <!-- Phase D: emit a codebook head via WordSpace.reconstruct().
         false = forward() does not populate ``_predicted_head``. -->
    <downwardGeneration>false</downwardGeneration>

    <language>
      <grammar>
        <!-- Default grammar: trivial unary pi / sigma folds at every
             tier.  PiLayer and SigmaLayer are first-class arity=1
             GrammarLayer subclasses; their forward(x) is the
             always-on multiplicative AND-fold (concepts) and OR-fold
             (percepts / symbols) respectively.

             A grammar containing only these unary rules is the
             "default-only" case: WordSpace.compose detects it and
             skips parser selection entirely.

             Per the 2026-05-07 rollback, the grammar XML is the sole
             source of truth for which rule fires at each tier.  There
             is no ``default_rule`` code-level fallback.  WordSpace
             populates ``current_rules`` / ``generate_rules`` from the
             rules listed below in the default-only fast path so per-space SyntacticLayer
             dispatch resolves to the PiLayer / SigmaLayer registered
             at space construction.  End-to-end cost matches the legacy
             y = self.pi(x) call site.

             Configs that need real grammar (constituency / negation /
             min-max ops) override this entire block via
             _NON_MERGING_PATHS (util.py); their grammar block fully
             replaces this one.  Configs that previously relied on the
             default_rule code-level fallback for sigma / pi at any
             tier need explicit ``S = sigma(S)``, ``C = pi(C)``,
             ``P = sigma(P)`` (and matching ``.reverse`` rules)
             listed; otherwise the per-tier dispatch is a no-op. -->
        <compose>
          <percepts>
            <rule>P = sigma(P)</rule>
          </percepts>
          <concepts>
            <rule>C = pi(C)</rule>
          </concepts>
          <symbols>
            <rule>S = sigma(S)</rule>
          </symbols>
        </compose>
        <generate>
          <percepts>
            <rule>P = sigma.reverse(P)</rule>
          </percepts>
          <concepts>
            <rule>C = pi.reverse(C)</rule>
          </concepts>
          <symbols>
            <rule>S = sigma.reverse(S)</rule>
          </symbols>
        </generate>
      </grammar>
      <!-- Soft-interpolation weight between forward and generation. -->
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>


  <InputSpace>
    <!-- Sequence-length sentinels; create_from_config() resolves
         nOutput=0 -> data-derived; nInput=0 -> data-derived. -->
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <!-- Per-vector content dimensionality. -->
    <nDim>1</nDim>
    <!-- Raw data dims; 0 = use the loader's native dim. -->
    <nInputDim>0</nInputDim>
    <nOutputDim>0</nOutputDim>
    <!-- Codebook size; 0 means defer to nOutput. -->
    <nVectors>0</nVectors>
    <!-- Discrete (codebook) input values. -->
    <codebook>none</codebook>
    <!-- Tokenization for text inputs: word | sentence | byte. -->
    <!-- raw: InputSpace emits the unanalyzed [B,1,N] byte buffer; the
         meronymic analyzer (chunking=analyse, the default) owns all
         tokenization. Non-analyse models (radix/bpe/lexicon) pin their own
         lexer (byte/word) so they keep the pre-lexed buffer. -->
    <lexer>raw</lexer>
  </InputSpace>

  <PerceptualSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nInputDim>0</nInputDim>
    <nOutputDim>0</nOutputDim>
    <nVectors>0</nVectors>
    <!-- Attention reweighting of percepts before the Pi fold. -->
    <hasAttention>true</hasAttention>
    <!-- Shared invertible PiLayer (vs separate pi1 / pi2). -->
    <invertible>false</invertible>
    <!-- Tanh-bound the output to [-1, 1]. -->
    <nonlinear>true</nonlinear>
    <!-- Discrete (codebook) percepts; false = passthrough Tensor. -->
    <codebook>none</codebook>
    <!-- Multi-token chunking strategy: analyse | lexicon | bpe | mphf | none | radix.
         R3-live default: the meronymic analyzer (space-lexer front end);
         with a word codebook it reproduces lexicon word lexing. -->
    <chunking>analyse</chunking>
    <!-- BPE merges per chunking pass (lexicon mode ignores this). -->
    <wordLearning>2</wordLearning>
  </PerceptualSpace>

  <ModalSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nInputDim>0</nInputDim>
    <nOutputDim>0</nOutputDim>
    <nVectors>0</nVectors>
    <!-- Modal-channel attention. -->
    <hasAttention>true</hasAttention>
    <!-- Shared invertible layer for the modal mux / demux. -->
    <invertible>false</invertible>
    <!-- Codebook quantization on the modal output. -->
    <codebook>none</codebook>
  </ModalSpace>

  <ConceptualSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nInputDim>0</nInputDim>
    <nOutputDim>0</nOutputDim>
    <nVectors>0</nVectors>
    <!-- Attention on ConceptualSpace violates position locality
         required by serial_mode; keep false unless a config opts in. -->
    <hasAttention>false</hasAttention>
    <!-- Shared invertible SigmaLayer (vs separate sigma1 / sigma2). -->
    <invertible>false</invertible>
    <!-- Tanh-bound the output to [-1, 1]. -->
    <nonlinear>true</nonlinear>
    <!-- Codebook quantization of concept directions. -->
    <codebook>none</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <!-- symbol_dim must equal concept_dim under the ownership rule
         (SymbolicSpace owns no SigmaLayer/PiLayer). nDim=0 means
         "inherit from ConceptualSpace.nDim". Concrete configs may set
         a positive value, but it must match ConceptualSpace.nDim. -->
    <nDim>0</nDim>
    <nInputDim>0</nInputDim>
    <nOutputDim>0</nOutputDim>
    <nVectors>0</nVectors>
    <!-- Tanh-bound the symbolic activation. -->
    <nonlinear>true</nonlinear>
    <!-- Discrete symbol prototypes (required for the full symbolic
         pipeline). -->
    <codebook>none</codebook>
    <!-- Bitonic-sort regularizer on the codebook ordering. -->
    <sortNetwork>false</sortNetwork>
    <!-- Sort-network depth; 0 disables. -->
    <sortPasses>0</sortPasses>
    <!-- L1 sparsity penalty on the symbolic activation. -->
    <l1Lambda>0.01</l1Lambda>
    <!-- Symbol-residual injection scales (legacy mereology hooks). -->
    <symbolResidualScale>1.0</symbolResidualScale>
    <outputSymbolResidualScale>0.0</outputSymbolResidualScale>
    <commitmentBeta>0.25</commitmentBeta>
    <!-- Enable VQ-VAE-style quantization rather than EMA codebook. -->
    <!-- ImpenetrableLayer regularizers (decorrelation / spectral
         flatness on codebook rows).  0 disables. -->
    <decorrelationWeight>0.0</decorrelationWeight>
    <spectralFlatnessWeight>0.0</spectralFlatnessWeight>
    <!-- Truth recording + learned-relation acceptance are both governed by
         the single continuous <truthCriterion> bar (declared under
         <architecture>; 0 = record/accept all, 1 = none). The binary
         truthMinMagnitude / accumulateTruth switches are retired. -->
  </SymbolicSpace>

  <OutputSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nInputDim>0</nInputDim>
    <nOutputDim>0</nOutputDim>
    <nVectors>0</nVectors>
    <!-- Invertible projection (rarely set on OutputSpace). -->
    <invertible>false</invertible>
    <!-- Codebook quantization of the output. -->
    <codebook>none</codebook>
    <!-- Linear (no tanh) output; OutputSpace rescales via Data.denormalize. -->
    <nonlinear>false</nonlinear>
  </OutputSpace>

</model>
