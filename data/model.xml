<?xml version="1.0" ?>
<!--
  model.xml — canonical defaults for BasicModel.

  Every parameter that create_from_config() reads must appear here.
  Model-specific XML files (XOR_exact.xml, BasicModel.xml, …) override
  individual values; anything they omit inherits from this file.

  nInput=0  sentinel: for InputSpace, derive from TheData; for other spaces,
            derive from the previous space's outputShape[0].
  nOutput=0 sentinel: same as nInput for this space (passthrough count).
  nVectors=0 sentinel: same as nOutput (used for non-quantized spaces).
-->
<model>
  <architecture>
    <type>basic</type>
    <modelType>simple</modelType>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <naive>false</naive>
    <syntax>false</syntax>
    <reconstruct>none</reconstruct>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <embeddingPath></embeddingPath>
    <weightsPath></weightsPath>
    <maxResponseLength>4096</maxResponseLength>

    <data>
      <!-- dataset: xor | mnist | tomatoes | text | inline | (omit for inference-only) -->
      <dataset>xor</dataset>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <shardDir></shardDir>
      <minFrequency>0.0</minFrequency>
      <classificationMin></classificationMin>
      <classificationMax></classificationMax>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>3</numEpochs>
      <batchSize>10</batchSize>
      <learningRate>0.001</learningRate>
      <reverseScale>0.5</reverseScale>
      <whatScale>0.7</whatScale>
      <whereScale>0.2</whereScale>
      <whenScale>0.1</whenScale>
      <negSamples>64</negSamples>

      <maskedPrediction>NONE</maskedPrediction>

      <!-- Embedding training mode: NONE | CBOW | SBOW | BACKPROP | BOTH | JOINT -->
      <trainEmbedding>NONE</trainEmbedding>
      <!-- Embedding loss weight in JOINT mode -->
      <embeddingScale>0.25</embeddingScale>

      <autoload>true</autoload>
      <autosave>false</autosave>
      <profile>false</profile>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8001</port>
      <timeout>120</timeout>
    </server>
  </architecture>

  <InputSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <flatten>false</flatten>
    <quantized>false</quantized>
    <lexer>word</lexer>
    <normalize>true</normalize>
  </InputSpace>

  <PerceptualSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <flatten>false</flatten>
    <passThrough>false</passThrough>
    <hasAttention>true</hasAttention>
    <invertible>false</invertible>
    <quantized>false</quantized>
    <normalize>false</normalize>
  </PerceptualSpace>

  <ModalSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <flatten>false</flatten>
    <passThrough>false</passThrough>
    <hasAttention>true</hasAttention>
    <invertible>false</invertible>
    <quantized>false</quantized>
    <whatPassThrough>false</whatPassThrough>
    <wherePassThrough>true</wherePassThrough>
    <whenPassThrough>true</whenPassThrough>
    <normalize>false</normalize>
  </ModalSpace>

  <ConceptualSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <flatten>false</flatten>
    <hasAttention>false</hasAttention>
    <hasNorm>false</hasNorm>
    <invertible>false</invertible>
    <nonlinear>true</nonlinear>
    <quantized>false</quantized>
    <normalize>false</normalize>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <flatten>false</flatten>
    <passThrough>false</passThrough>
    <quantized>false</quantized>
    <normalize>false</normalize>
  </SymbolicSpace>

  <SyntacticSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <flatten>false</flatten>
    <quantized>false</quantized>
    <normalize>false</normalize>
  </SyntacticSpace>

  <OutputSpace>
    <nInput>0</nInput>
    <nOutput>0</nOutput>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <flatten>true</flatten>
    <invertible>false</invertible>
    <quantized>false</quantized>
    <normalize>true</normalize>
  </OutputSpace>
</model>
