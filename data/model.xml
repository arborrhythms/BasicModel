<?xml version="1.0" ?>
<model>
  <!-- BasicModel configuration -->
  <architecture>
    <conceptualOrder>2</conceptualOrder>
    <reconstruct>symbols</reconstruct>
    <modelType>passthrough</modelType>

    <data>
      <!-- Dataset: mnist | xor | tomatoes -->
      <dataset>mnist</dataset>
    </data>

    <training>
      <numEpochs>10</numEpochs>
      <batchSize>10</batchSize>
      <learningRate>0.01</learningRate>
      <!-- Path to saved weights (relative to basicmodel/ root) -->
      <weightsPath>output/weights.ckpt</weightsPath>
      <!-- Auto-load weights on startup if available -->
      <autoload>true</autoload>
      <!-- Auto-save weights after training -->
      <autosave>true</autosave>
    </training>
  </architecture>

  <InputSpace>
    <nActive>32</nActive>
    <nVectors>32</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nActive>64</nActive>
    <nVectors>128</nVectors>
  </PerceptualSpace>

  <ConceptualSpace>
    <nActive>256</nActive>
    <nVectors>512</nVectors>
  </ConceptualSpace>

  <SymbolicSpace>
    <nActive>2</nActive>
    <nVectors>2</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>32</nActive>
    <nVectors>32</nVectors>
  </OutputSpace>

  <server>
    <!-- HTTP interface settings (for WikiOracle integration) -->
    <host>127.0.0.1</host>
    <port>8001</port>
    <timeout>120</timeout>
  </server>
</model>
