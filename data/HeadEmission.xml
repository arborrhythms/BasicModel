<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- HeadEmission: inline sentences corpus for the downward S -> C
       generation MVP. Each sentence's head word is predicted from the
       final deep symbolic state via WordSpace.reconstruct(). This is the
       plumbing fixture referenced from test_head_emission.py. -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <!-- Pair-scorer contract: D (effective feature dim) == nInput (n_slots).
         The converged modality architecture keeps the SymbolicSpace carrier
         at D=nDim (SS carries no .where/.when; see canonical_shape), so the
         SyntacticLayer's pair_scorer linear is shape-compatible with the
         live tensor during chart compose. -->

    <data>
      <dataset>inline</dataset>
      <input use="train">the teacher helped the student|the cat chased the mouse|the bird sang a song|the child kicked the ball|the farmer fed the dog</input>
      <input use="test">the teacher helped the student</input>
      <output use="train">0|0|0|0|0</output>
      <output use="test">0</output>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>4</batchSize>
      <autoload>false</autoload>
    </training>
  </architecture>

  <InputSpace>
    <!-- nOutput sized to fit the lex's token count for the inline
         5-word sentences (the word lexer doesn't strip null padding,
         so a stringTensor-padded input emits one token per
         contiguous-non-null run, giving up to ~15 tokens before the
         EOS sentinel). Was 8 under the legacy silent-truncation path;
         raised to 32 when §8g of the brick-vectorization handoff
         replaced the truncation with an assert. -->
    <nOutput>32</nOutput>
    <nDim>12</nDim>
    <nVectors>8</nVectors>
    <codebook>quantize</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>32</nOutput>
    <nDim>12</nDim>
    <nVectors>8</nVectors>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>32</nOutput>
    <nDim>12</nDim>
    <nVectors>8</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>32</nOutput>
    <nDim>8</nDim>
    <nVectors>8</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>8</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

  <WordSpace>
	    <downwardGeneration>true</downwardGeneration>
    <language>
      <grammar>
        <compose>
          <rule>S = S VO</rule>
          <rule>VO = V O</rule>
        </compose>
        <generate>
          <rule>S = C</rule>
        </generate>
      </grammar>
    </language>
  </WordSpace>

</model>
