<?xml version="1.0" ?>
<!--
  xor_subspace.xml — XOR config with useSubspaceActivation enabled.

  Mirror of xor.xml but with subspace activation path active.
  Used to verify that the subspace activation pipeline produces
  outputs consistent with the legacy forward() path.
-->
<model>
  <architecture>
    <conceptualOrder>1</conceptualOrder>
    <modelType>embedding</modelType>
    <useSubspaceActivation>true</useSubspaceActivation>
    <weightsPath>xor_subspace_weights.ckpt</weightsPath>

    <data>
      <dataset>xor</dataset>
    </data>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autosave>true</autosave>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>2</nOutput>
    <nDim>1</nDim>
    <nVectors>2</nVectors>
  </InputSpace>

  <!-- PerceptualSpace: VQ codebook (nVectors=16 > nOutput=4) — codebook=true. -->
  <PerceptualSpace>
    <nOutput>4</nOutput>
    <nDim>1</nDim>
    <nVectors>16</nVectors>
    <codebook>true</codebook>
    <invertible>false</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <!-- ConceptualSpace: VQ codebook (nVectors=16 > nOutput=3) — codebook=true. -->
  <ConceptualSpace>
    <nOutput>3</nOutput>
    <nDim>1</nDim>
    <nVectors>16</nVectors>
    <codebook>true</codebook>
    <invertible>false</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>3</nOutput>
    <nVectors>3</nVectors>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
