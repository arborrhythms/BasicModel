<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_20M_fineweb (2026-07-07): MM_20M_grammar on the FineWeb shard with the
       word-slot budget widened to N=64 so a WHOLE sentence fits (FineWeb mean
       ~19.5 words, p90 35; N=64 covers ~99% of sentences vs 38% of words at
       N=8). The word-slot count N = PartSpace.nOutput, propagated to CS
       stmCapacity/nInput/nVectors/nOutput, WS.nInput/nOutputDim, OS.nInput
       (WS.nOutput*nOutputDim == OS.nInput*nInputDim must hold: 1024*64 == 64*1024).

       Feasible ONLY after the per-vector order-raise fix (2026-07-07): the
       sigma/pi mereological fold now raises each word over its own D features
       independently (fold width percept_dim, not nOutput*D), so the serial loop
       is LINEAR in the word count. Before that fix N=32/64 hit an O(N^2) memory
       wall. Runs on MPS with PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.0 (train.py sets
       this) at ~15-20s/step eager; the eager skip-padding loop keeps cost
       tracking the real sentence length. -->
  <!-- MM_20M_grammar: the SERIAL sibling of MM_20M, now on the NEW DEFAULTS
       synthesis=meronomy + analysis=meronomy (Task 6, plan
       doc/plans/2026-07-03-reconstruction-fidelity-execution.md; Alec's
       decision). The space dims are the XOR-proven meronomy shape
       (data/MM_20M_xor.xml) adapted to serial mode, the SAME adaptation the
       committed serial+radix sibling data/MM_mereology_serial.xml already
       carries: IS 8192x1024 raw byte buffer; PS deep [B,8,1024] percepts from
       a 65536-row MPHF codebook; CS deep hub [B,8,1024] (N=8=STM depth); WS
       [8,1024] in, wide [1024,8] symbol slab out. Serial derivation is kept:
       symbolicOrder=1 (no serial tag; derived true), per-word forward via
       _forward_body_per_word, and grammatical composition (complete.grammar)
       instead of the parallel per-stage butterfly bridges.

       Under analysis=meronomy the lexer resolves to raw (Spaces.py
       resolve_lexer), so use_byte_cursor=False and the supervised out_items
       (the 0/1 XOR labels) reach the head; the byte-cursor AR stub-label
       path this config trained on before the switch is retired. -->
  <architecture>
    <!-- legacy serial: per-word forward dispatch via _forward_body_per_word. -->
    <symbolicOrder>1</symbolicOrder>
    <subsymbolicOrder>3</subsymbolicOrder>
    <l1Lambda>0.01</l1Lambda>
    <!-- sigmaPi=butterfly: PS.Pi and SS.Sigma use O(N log N) cross-position
         butterfly cascade (moved from per-space to architecture-level). -->
    <sigmaPi>butterfly</sigmaPi>

    <data>
      <dataType>embedding</dataType>
      <dataset>text</dataset>
      <shardDir>data/fineweb</shardDir>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>64</batchSize>
      <learningRate>0.0005</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
    </training>
  </architecture>

  <!-- InputSpace: raw byte intake, 8192-byte buffer x 1024-wide events (the
       XOR-proven IS; was 1024x12 wide slots). Under the raw lexer the IS
       emits the unanalyzed [B,1,N] byte buffer and PS owns tokenization. -->
  <InputSpace>
    <nOutput>8192</nOutput>
    <nVectors>256</nVectors>
    <nDim>1024</nDim>
  </InputSpace>

  <!-- PartSpace: deep [B, 8, 1024] meronomy percepts (was wide [B,1024,12]
       lexicon slots). nVectors=65536 is the MPHF percept-codebook budget and
       nDim=1024 the percept event width, both from the XOR-proven shape;
       nInput/nInputDim consume the IS byte buffer. Content slab 8*1020
       matches CS (band 4 subtracted per space). -->
  <PartSpace>
    <nInput>8192</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>64</nOutput>
    <nOutputDim>1024</nOutputDim>

    <invertible>true</invertible>
    <synthesis>meronomy</synthesis>
    <!-- Promote a recurring word to a SINGLE percept after 2 sightings
         (default 4) so PS climbs to word-size parts inside the small xor
         dataset budget (mirrors MM_20M_xor; the round-trip decode needs the
         promoted word percepts). -->
    <chunkPromotionThreshold>2</chunkPromotionThreshold>
  </PartSpace>

  <!-- ConceptualSpace: the deep hub [B, 8, 1024]; N=8 = STM depth. PS->CS is
       now an identity handoff (equal widths; was the wide-to-deep 12/1028
       regroup). Dims mirror MM_20M_xor / MM_mereology_serial. -->
  <ConceptualSpace>
    <nInput>64</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>64</nVectors>
    <stmCapacity>64</stmCapacity>
    <nDim>1024</nDim>
    <nOutput>64</nOutput>
    <nOutputDim>1024</nOutputDim>

    <invertible>true</invertible>
  </ConceptualSpace>

  <!-- WholeSpace: analysis=meronomy (the 1-x dual of the PS synthesizer; was
       byte). Consumes the deep CS idea [8,1024] and emits the wide [1024,8]
       symbol slab (the XOR-proven WS shape); the bounded-STM grammar fold is
       still the serial Sigma. nVectors=65536 mirrors the meronomy store
       budget of the proven pair (was 1000, the byte-path grammar-op
       budget). -->
  <WholeSpace>
    <analysis>meronomy</analysis>
    <!-- Per-space sigmaPi override kept from the byte-era config: "last"
         (per-slot square fold, about 1M params/stage) instead of the
         architecture-global butterfly. The serial grammar path sizes the
         WS.pi cascade at next_pow2(preMergeSlots * nInputDim); on the old
         wide grid that was a 2^20 cascade and the bulk of a 114s build.
         The deep shape shrinks preMergeSlots to 8, but the square fold
         stays the measured-safe choice (plan Task 6: KEEP butterfly=false). -->
    <butterfly>false</butterfly>
    <nInput>64</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>1024</nOutput>
    <nOutputDim>64</nOutputDim>

    <invertible>true</invertible>
  </WholeSpace>

  <!-- OutputSpace: the supervised XOR head (labels reach it post-switch).
       nInput*nInputDim = 8*1024 matches the flattened WS symbol slab
       (1024*8); nDim=1 is the 0/1 target width (was 4 under the stub-label
       byte path). Mirrors MM_mereology_serial. -->
  <OutputSpace>
    <nInput>64</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>1</nVectors>
    <nDim>1</nDim>
    <nOutput>1</nOutput>
    <nOutputDim>1</nOutputDim>
  </OutputSpace>

  <SymbolSpace>
    <language>
      <grammar>complete.grammar</grammar>
    </language>
  </SymbolSpace>

</model>
