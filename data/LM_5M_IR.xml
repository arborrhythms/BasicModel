<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- LM_5M_IR: chart/grammar-driven sibling of MM_5M_IR.  Mirrors
       MM_5M_IR's space parameters exactly (word lexer, lexicon
       chunking, 1M-entry perceptual codebook, hierarchical 8-level
       ConceptualSpace shape) so the .kv lexicon and .ckpt embeddings
      are interchangeable with MM_5M_IR.  Differs only in:
        * non-default grammar (parser dispatch is derived from the grammar block)
         * grammar block (full English grammar with PP rules)
         * chart machinery: noisy top-K=4 gating, load-balance loss,
           per-rule width gates (Shazeer 2017 sparse-MoE pattern)
       Distinct ckpt/kv paths only because we may want to keep the
       MM_5M_IR training run separate; once the lexicon is shared,
       you can copy MM_5M_IR.kv → LM_5M_IR.kv as a warm start.
  -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <weightsPath>LM_5M_IR.ckpt</weightsPath>
    <amp>bf16</amp>

    <!-- Retired compatibility knob. Accepted by the schema, ignored by
         runtime: the codebook is the meronymic structure. -->
    <mereologicalTreeSize>1024</mereologicalTreeSize>

    <!-- perStageChartReparse retired 2026-05-12: chart fires at C-tier
         in every body stage by construction. -->
    <loadBalanceWeight>0.01</loadBalanceWeight>

    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reconstructionScale>1.0</reconstructionScale>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
    </training>

    <server>
      <port>8006</port>
    </server>

  </architecture>

  <!-- All space parameters below are identical to MM_5M_IR.xml so
       the .kv lexicon and the perceptual / conceptual / symbolic
       codebooks are share-compatible. -->

  <!-- Stage 1.D flat-slab invariant (2026-05-27): re-architected to a
       uniform 8*1024=8192 slab; mirrors MM_5M_IR / MM_20M. -->
  <InputSpace>
    <nInput>1024</nInput>
    <nDim>12</nDim>
    <nVectors>1024</nVectors>
    <nOutput>1024</nOutput>
    <lexer>word</lexer>
    <codebook>none</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>1000000</nVectors>
    <nDim>12</nDim>
    <nOutput>1024</nOutput>
    <invertible>false</invertible>
    <synthesis>lexicon</synthesis>
    <wordLearning>1</wordLearning>
  </PerceptualSpace>

  <!-- ConceptualSpace: hierarchical-mode shape from MM_5M_IR.
       Per-level shapes are computed dynamically by _level_shapes
       based on conceptualOrder and the conceptualWidth mode. -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>1028</nDim>
    <nVectors>512</nVectors>
    <invertible>false</invertible>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1024</nInput>
    <nDim>1028</nDim>
    <nInputDim>1028</nInputDim>
    <!-- Stage 1.B paired-row contract: doubled for orth + semantic. -->
    <nVectors>2000000</nVectors>
    <nOutput>1024</nOutput>
    <codebook>quantize</codebook>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

  <WordSpace>
    <!-- Stage 3 cleanup: parserBackend, chartTau, wMax, chartTopK,
         chartNoiseEps retired alongside the chart. The signal router
         (LanguageLayer) is the canonical parser. -->
    <downwardGeneration>false</downwardGeneration>
    <language>
      <start>S</start>
      <grammar>
        <compose>
          <symbols>
            <!-- Sentence (with width gates: width=N..M restricts a rule
                 to cells of those widths; "1.." = open lower, "3..5" =
                 fixed range). Sentence-level rules need ≥3 tokens
                 (subject + verb + object minimum); NP=N and VP=V are
                 width-1 leaves only. -->
            <rule width="1..">S = NP</rule>
            <rule width="3..">S = lift(NP, VP)</rule>
            <rule width="3..">S = isEqual(NP, NP)</rule>
            <rule width="3..">S = isEqual(NP, AP)</rule>
            <rule width="3..">S = part(NP, NP)</rule>
            <rule width="2..">S = not(S)</rule>
            <rule width="3..">S = conjunction(S, S)</rule>
            <rule width="3..">S = disjunction(S, S)</rule>

            <!-- Noun Phrase -->
            <rule width="1..1">NP = N</rule>
            <rule width="2..">NP = AP</rule>
            <rule width="3..">NP = conjunction(NP, NP)</rule>
            <rule width="3..">NP = disjunction(NP, NP)</rule>

            <!-- Verb Phrase -->
            <rule width="1..1">VP = V</rule>
            <rule width="2..">VP = intersection(V, O)</rule>
            <rule width="2..">VP = lower(ADV, VP)</rule>
            <rule width="2..">VP = lower(ADJ, VP)</rule>

            <!-- Object -->
            <rule width="1..">O = NP</rule>

            <!-- Adjective Phrase -->
            <rule width="2..">AP = lower(ADJ, NP)</rule>
            <rule width="2..">AP = lower(ADJ, AP)</rule>
            <rule width="2..">AP = lower(DET, NP)</rule>

            <!-- Prepositional Phrase. -->
            <rule width="2..">PP = lift(P, NP)</rule>
            <rule width="3..">NP = lower(NP, PP)</rule>
            <rule width="3..">VP = lower(VP, PP)</rule>
          </symbols>
        </compose>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>

</model>
