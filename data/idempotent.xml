<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- idempotent: minimal MentalModel for discussing the C-S intrinsic
       snap "idempotent loop". Sized to the same regime as
       test/test_idempotent_loop.py (D_C = V_S = 4) so the round trip is
       easy to reason about by hand.

       The idempotent loop is the round-trip:

         x  =>  SymbolicSpace.forward(x)   =>  scalar activation
         activation  =>  SymbolicSpace.reverse(activation)  =>  x'

       Properties:
         (a) For x in span(W) (codebook row space), x' == x: the round
             trip is the identity.
         (b) For x with a component orthogonal to span(W), one cycle
             projects it onto span(W); subsequent cycles are the identity
             (idempotent thereafter).
         (c) For x orthogonal to span(W), x' == 0: bivec is the
             NEITHER corner [0, 0] for every prototype.

       This config exercises that primitive through a full SymbolicSpace
       in the default-only unary sigma/pi substrate grammar; see the WordSpace
       grammar block below for why an empty block would NOT be
       non-grammatical). The C to S codebook snap that CREATES symbols
       is a subsymbolic substrate op and runs unconditionally regardless
       of grammar, so the full lifecycle (resolve / set_event /
       forwardEnd) and the snap are still observed in context, not just
       on a bare Codebook.

       Sizing rationale:
         - V_S = V_C = nDim_C = nDim_S = 4: the V_S = V_C alignment
           (Phase 5 option A) makes per-prototype shape [B, V_S=4, 2]
           coincide with per-slot shape [B, N=4, 2]; no diagonal /
           outer-product disambiguation needed.
         - conceptualOrder = 1: a single ConceptualSpace -> SymbolicSpace
           step with no slot halving, so the round trip is exactly one
           forward + one reverse.
         - codebook training path is the default VQ-VAE / EMA
           dispatch in SymbolicSpace.forward; the prior
           ``<useVQVAE>false</useVQVAE>`` "frozen-codebook" branch was
           retired 2026-05-29 (no learning signal was supplied, so
           prototypes stayed at random init).
         - invertible = true on the Sigma / Pi layers and on the
           codebook: engages the cached-SVD pseudo-inverse
           (project_reverse) path used by the idempotent test.
  -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <!-- idempotent reuses the snap primitive only; disable the truth
         weights so loss = reconstruction error alone. -->
    <truthBiasScale>0.0</truthBiasScale>
    <LuminosityWeight>0.0</LuminosityWeight>
    <UniversalityWeight>0.0</UniversalityWeight>

    <data>
      <dataset>inline</dataset>
    </data>

    <training>
      <numEpochs>0</numEpochs>
      <batchSize>1</batchSize>
      <learningRate>0.0</learningRate>
      <reconstructionScale>0.0</reconstructionScale>
      <autoload>false</autoload>
    </training>

  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): IS, PS, CS must
       carry the same flat slab (nOutput*nDim). Pre-Stage-1.D this
       config had IS slab=1, PS slab=40, CS slab=1000 - intent was
       a "fat concept" C-S round trip. Re-architected so the entire
       pipeline carries a uniform 10*100=1000 slab; the V_S=V_C=10,
       nDim_C=nDim_S=100 idempotent invariants are preserved (the
       points where idempotency is tested). PS widens from 10*4 to
       10*100 to keep the slab consistent. -->
  <InputSpace>
    <nOutput>10</nOutput>
    <nDim>104</nDim>
    <nVectors>40</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nInput>10</nInput>
    <nVectors>10</nVectors>
    <nDim>104</nDim>
    <nOutput>10</nOutput>
    <invertible>true</invertible>
  </PerceptualSpace>

  <ConceptualSpace>
    <nInput>10</nInput>
    <nVectors>10</nVectors>
    <nDim>104</nDim>
    <nOutput>10</nOutput>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
    <nonlinear>false</nonlinear>
    <!-- H2: STM capacity = the classical 7±2 working-memory bound, so
         the [B, 7, concept_dim] STM slab is what passes through the
         widened idempotent C->S->C symbolic-space loop
         (BasicModel._stm_symbolic_roundtrip). Subsymbolic operation
         can override via this knob (ShortTermMemory docstring). -->
    <stmCapacity>7</stmCapacity>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>10</nInput>
    <nVectors>200</nVectors>
    <nDim>104</nDim>
    <nOutput>10</nOutput>
    <!-- idempotent: zero out the symbol regularizers so the snap is the
         only operation training touches. -->
    <l1Lambda>0.0</l1Lambda>
    <commitmentBeta>0.0</commitmentBeta>
    <codebook>quantize</codebook>
    <invertible>true</invertible>
    <nonlinear>false</nonlinear>
  </SymbolicSpace>

  <OutputSpace>
    <nVectors>1</nVectors>
    <nOutput>1</nOutput>
  </OutputSpace>

  <WordSpace>
    <language>
      <start>S</start>
      <grammar>
	        <!-- Idempotent loop: default-only grammar. An EMPTY grammar
	             block does NOT yield this mode: Grammar._ensure_configured
             (bin/Language.py) falls back to _NOOP_GRAMMAR =
             S:not(S) when no inline grammar is present, and the
             ``not`` rule is non-substrate, so _derive_use_grammar
	             (bin/Models.py) returns 'all' (parser + per-stage merge
             glue wired). To be genuinely non-grammatical the grammar
             must be the "default-only" case: ONLY the trivial unary
             pi / sigma substrate folds at every tier (compose +
             generate). That is the one grammar shape
             _derive_use_grammar maps to 'none'. This block mirrors
             data/model.xml's canonical default-only grammar verbatim.

             The symbolic loop still creates symbols in this mode: the
	             C to S codebook snap (SymbolicSpace.forward, bin/Spaces.py)
             is a subsymbolic SUBSTRATE op that runs UNCONDITIONALLY
             regardless of grammar state (same precedent as the
             post-#21 unconditional ``sigma_percept``). Symbol
             creation is the codebook quantize, not a grammatical
	             rule, so it is exercised even without non-default grammar.
             The codebook remains the only learned object in the
             C-S loop. -->
        <compose>
          <percepts>
            <rule>P = sigma(P)</rule>
          </percepts>
          <concepts>
            <rule>C = pi(C)</rule>
          </concepts>
          <symbols>
            <rule>S = sigma(S)</rule>
          </symbols>
        </compose>
        <generate>
          <percepts>
            <rule>P = sigma.reverse(P)</rule>
          </percepts>
          <concepts>
            <rule>C = pi.reverse(C)</rule>
          </concepts>
          <symbols>
            <rule>S = sigma.reverse(S)</rule>
          </symbols>
        </generate>
      </grammar>
    </language>
  </WordSpace>

</model>
