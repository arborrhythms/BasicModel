<?xml version="1.0" ?>
<model>
  <!-- MM_1B: MentalModel scaled to ~1B params with byte input.
       Keeps the MentalModel topology and shifts representational width
       into ConceptualSpace while PerceptualSpace compacts byte spans. -->
  <architecture>
    <reconstruct>concepts</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <type>mental</type>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <modelType>embedding</modelType>
    <maskedPrediction>ARLM</maskedPrediction>
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>
    <maxResponseLength>4096</maxResponseLength>
    <weightsPath>MM_1B.ckpt</weightsPath>
    <embeddingPath>MM_1B.kv</embeddingPath>

    <data>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>2</numEpochs>
      <batchSize>1</batchSize>
      <learningRate>0.0005</learningRate>
      <reverseScale>0.1</reverseScale>
      <trainEmbedding>ARLM</trainEmbedding>
      <autoload>false</autoload>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
      <sentenceContextWindow>5</sentenceContextWindow>
      <sentenceCentroidHistory>3</sentenceCentroidHistory>
      <sentenceLambda>1.01</sentenceLambda>
      <sentencePredictionScale>0.1</sentencePredictionScale>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8003</port>
      <timeout>120</timeout>
    </server>

    <language>
      <grammar>
        <START>S</START>
        <S>true(S)</S>
        <S>swap(S, S)</S>
        <S>equals(S, S)</S>
        <S>part(S, S)</S>
        <S>C</S>
        <C>non(C)</C>
        <C>not(C)</C>
        <C>intersection(C, C)</C>
        <C>union(C, C)</C>
        <C>lower(C, C)</C>
        <C>lift(C, C)</C>
        <C>lift(C, C, C)</C>
        <C>P</C>
        <P>I P</P>
        <P>I</P>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>

  </architecture>

  <InputSpace>
    <nDim>1</nDim>
    <nVectors>4096</nVectors>
    <nOutput>4096</nOutput>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <lexer>byte</lexer>
    <codebook>true</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nInput>4096</nInput>
    <nVectors>512</nVectors>
    <nDim>32</nDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <nOutput>128</nOutput>

    <passThrough>false</passThrough>
    <hasAttention>false</hasAttention>
    <invertible>false</invertible>
    <codebook>false</codebook>
  </PerceptualSpace>

  <!-- ConceptualSpace receives [Percept, Symbol] in iterative MentalModel.
       Keep object counts MentalModel-like, but add the real representational
       width here. -->
  <ConceptualSpace>
    <nInput>256</nInput>
    <nVectors>256</nVectors>
    <nDim>1024</nDim>
    <nOutput>32</nOutput>

    <hasAttention>false</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
    <nInputDim>-1</nInputDim>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>128</nInput>
    <nVectors>1024</nVectors>
    <nDim>4</nDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
    <nOutput>128</nOutput>

    <passThrough>false</passThrough>
    <accumulateTruth>0</accumulateTruth>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>

</model>
