<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- MM_sparse_concept: the sparse-coding Conceptual Space driver
       (doc/plans/2026-06-27-sparse-coding-cs-plan.md; v3 iterated wave,
       doc/plans/2026-07-02-iterated-symbolic-loop.md).

       A concept is a high-dimensional atom stored on CS.subspace.what
       (ConceptDim). Structure lives on ONE square untyped AttentionLayer
       [N x N+1] (bottom-up attention over the concept inventory; a
       SparseLayer subclass): a SNAP block of rows (order-0 concepts =
       codebook rows, no in-edges) plus a RELATION POOL (minted relations);
       edges are untyped fuzzy set-membership degrees, one per symbolic
       constituent, plus the trailing EVERYTHING bias column. The forward is
       the iterated wave a^{i+1} = tanh(W [a^i | 1] + s): s is the order-0
       snap presence, an ADDITIVE source each step, and K = symbolicOrder is
       the ITERATION BUDGET (a depth-d vine completes at iteration d; K=3
       here). concept_code[c] = a[c] * softplus(what[c]). Weights are SIGNED
       (a negative weight = the feature's presence anti-correlates with the
       concept); the atoms are strictly-positive mereological-feature
       signatures. Forward-connected: the gradient reaches the sparse
       weights, the activations, and the dictionary.

       Activation is by symbolicOrder (not a config gate): symbolicOrder>=1
       with <serial>false</serial> (the explicit override of the back-compat
       serial = symbolicOrder>0 default) runs the PARALLEL symbolic loop;
       symbolicOrder=0 is the byte-identical off-path (no snap, no wave).
       <symbolTower>true</symbolTower> routes the CS->SS leg through
       SymbolSpace.forward_concept_to_symbol. A sibling of MM_symbol_tower.xml;
       runs on the xor smoke dataset. -->
  <architecture>
    <subsymbolicOrder>3</subsymbolicOrder>
    <!-- explicit override: parallel symbolic loop at symbolicOrder>=1. -->
    <serial>false</serial>
    <!-- iteration budget K: a depth d vine completes at iteration d; K=3
         covers the XOR presentations (K=1 would leave deep links dark). -->
    <symbolicOrder>3</symbolicOrder>
    <l1Lambda>0.01</l1Lambda>
    <sigmaPi>butterfly</sigmaPi>
    <!-- mint the word/object/meta symbols whose decomposition populates the
         untyped edges on the shared square store (decoupled from the
         transform; gated only on the symbolic order). -->
    <mereologyRaise>true</mereologyRaise>
    <!-- the 3-stream peer bind (PS/WS percepts + the SS symbol leg, now
         forward-mediated via SymbolSpace.forward_concept_to_symbol). -->
    <symbolTower>true</symbolTower>
    <!-- P4 two-phase plan: distinct per-pass sigma/pi layers, the
         subsymbolic reasoning engine driving the pump's settle. -->
    <subsymbolicStack>true</subsymbolicStack>

    <data>
      <dataType>embedding</dataType>
      <dataset>xor</dataset>
    </data>
    <training>
      <numEpochs>300</numEpochs>
      <batchSize>12</batchSize>
      <learningRate>0.01</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <!-- the substitutability SITUATING signal on the grad-bearing concept
           codes (the sparse encoder + dictionary decoder output). -->
      <conceptualSimilarityScale>0.1</conceptualSimilarityScale>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>8192</nOutput>
    <nVectors>256</nVectors>
    <nDim>1024</nDim>
  </InputSpace>

  <PartSpace>
    <nInput>8192</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>1024</nOutputDim>
    <invertible>true</invertible>
    <synthesis>radix</synthesis>
  </PartSpace>

  <ConceptualSpace>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <!-- P5 capacity sizing: the snap/pool blocks must hold the mint load
         (XOR: 4 words x (A word-sym + B object-sym) + metas + joint-chain
         links). Post-P3 the inventory is decoupled from the 8-slot slab
         (content never substitutes), so nVectors > nInput is safe:
         snap 16 rows + pool 16 rows. -->
    <nVectors>32</nVectors>
    <stmCapacity>8</stmCapacity>
    <nDim>1024</nDim>
    <nOutput>8</nOutput>
    <nOutputDim>1024</nOutputDim>
    <invertible>true</invertible>
  </ConceptualSpace>

  <WholeSpace>
    <analysis>raw</analysis>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>65536</nVectors>
    <nDim>1024</nDim>
    <nOutput>1024</nOutput>
    <nOutputDim>8</nOutputDim>
    <invertible>true</invertible>
    <codebook>quantize</codebook>
  </WholeSpace>

  <OutputSpace>
    <nInput>8</nInput>
    <nInputDim>1024</nInputDim>
    <nVectors>1</nVectors>
    <nDim>1</nDim>
    <nOutput>1</nOutput>
    <nOutputDim>1</nOutputDim>
  </OutputSpace>

</model>
