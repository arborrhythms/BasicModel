<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- Step 2: Step 1 + the .where modality (now an architectural constant
       via canonical_shape; the per-config width tag was retired). -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <ergodic>true</ergodic>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </PerceptualSpace>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): CS aligned to IS/PS. -->
  <ConceptualSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
