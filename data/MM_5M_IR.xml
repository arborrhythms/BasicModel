<?xml version="1.0" ?>
<model>
  <!-- MM_5M_IR: bidirectional masked Input Reconstruction sibling of
       MM_5M. Same brick-body architecture (8 hierarchical levels,
       N*D=4096); differs in: prediction mode (IR vs ARIR),
       tokenization (word/lexicon vs byte+BPE), and lexicon size
       (200K vs 4096). See doc/specs/2026-04-29-ir-mode-design.md. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <useButterflies>true</useButterflies>
    <l1Lambda>0.01</l1Lambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <modelType>embedding</modelType>
    <weightsPath>MM_5M_IR.ckpt</weightsPath>
    <embeddingPath>MM_5M_IR.kv</embeddingPath>
    <amp>bf16</amp>

    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reverseScale>1.0</reverseScale>
      <maskedPrediction>IR</maskedPrediction>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
      <sentenceContextWindow>5</sentenceContextWindow>
    </training>

    <server>
      <port>8004</port>
    </server>

  </architecture>

  <InputSpace>
    <nInput>4096</nInput>
    <nDim>6</nDim>
    <nVectors>4096</nVectors>
    <nOutput>4096</nOutput>
    <nWhere>2</nWhere>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>1000000</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nOutput>1024</nOutput>
    <hasAttention>false</hasAttention>
    <codebook>true</codebook>
    <chunkingFrequency>1</chunkingFrequency>
  </PerceptualSpace>

  <!-- ConceptualSpace: final level shape is 4x1024.
       Hierarchical mode computes per-level shapes dynamically via _level_shapes. -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>1024</nDim>
    <nVectors>512</nVectors>
    <codebook>true</codebook>
    <chunking>lexicon</chunking>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1024</nInput>
    <nInputDim>8</nInputDim>
    <nVectors>1024</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nOutput>1024</nOutput>
    <codebook>true</codebook>
    <accumulateTruth>0</accumulateTruth>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>


  <WordSpace>
    <language>
      <!-- Start nonterminal: SyntacticLayer.compose marks a soft sentence
           boundary when row b's parse stack reduces to a single live leaf
           of this category. Outer doc-streaming loop (runEpoch) drains
           the per-row signal and dispatches soft_reset(batch=b). -->
      <start>S</start>
      <grammar>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
