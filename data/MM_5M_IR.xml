<?xml version="1.0" ?>
<model>
  <!-- MM_5M_IR: bidirectional masked Input Reconstruction sibling of
       MM_5M. Same brick-body architecture (8 hierarchical levels,
       N*D=4096); differs in tokenization (word/lexicon vs byte+BPE)
       and lexicon size
       (200K vs 4096). See doc/specs/2026-04-29-ir-mode-design.md. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <weightsPath>MM_5M_IR.ckpt</weightsPath>
    <amp>bf16</amp>

    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reconstructionScale>1.0</reconstructionScale>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
    </training>

    <server>
      <port>8004</port>
    </server>

  </architecture>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): IS, PS, CS must
       carry the same flat slab (nOutput*nDim). Pre-Stage-1.D this had
       IS slab=4096*6=24576, PS slab=1024*6=6144, CS slab=8*1024=8192;
       all three differed. Re-architected to a uniform 8*1024=8192
       (matching the CS terminal width), IS/PS share 1024 wide slots
       at nDim=8 each; mirrors MM_5M.xml's re-architecture. -->
  <InputSpace>
    <nInput>1024</nInput>
    <nDim>12</nDim>
    <nVectors>1024</nVectors>
    <nOutput>1024</nOutput>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>1000000</nVectors>
    <nDim>12</nDim>
    <nOutput>1024</nOutput>
    <codebook>quantize</codebook>
    <wordLearning>1</wordLearning>
  </PerceptualSpace>

  <!-- ConceptualSpace: final level shape is 8x1024 (flat slab 8192).
       Hierarchical mode computes per-level shapes dynamically via _level_shapes. -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>1028</nDim>
    <nVectors>512</nVectors>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1024</nInput>
    <nDim>1024</nDim>
    <nInputDim>8</nInputDim>
    <!-- Stage 1.B paired-row contract: SS.nVectors must be at least 2x
         PS lexicon capacity (1000000) to hold orth + semantic paired
         rows. Doubled to 2000000 for the paired pair. -->
    <nVectors>2000000</nVectors>
    <nOutput>1024</nOutput>
    <codebook>quantize</codebook>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>


  <WordSpace>
    <language>
      <!-- Start nonterminal: SyntacticLayer.compose marks a soft sentence
           boundary when row b's parse stack reduces to a single live leaf
           of this category. Outer doc-streaming loop (runEpoch) drains
           the per-row signal and dispatches soft_reset(batch=b). -->
      <start>S</start>
      <grammar>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
