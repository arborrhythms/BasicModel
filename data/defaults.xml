<?xml version="1.0" ?>
<model>
  <architecture>
    <reshape>false</reshape>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <processSymbols>false</processSymbols>
    <modelType>simple</modelType>
    <maskedPrediction>none</maskedPrediction>
    <reconstruct>none</reconstruct>
    <maxResponseLength>4096</maxResponseLength>

    <data>
      <dataset>xor</dataset>
      <minFrequency>0.0</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>3</numEpochs>
      <batchSize>10</batchSize>
      <learningRate>0.001</learningRate>
      <reconRatio>0.5</reconRatio>
      <train>both</train>
      <weightsPath>output/weights.ckpt</weightsPath>
      <autoload>true</autoload>
      <autosave>false</autosave>
      <negSamples>1024</negSamples>
    </training>
  </architecture>

  <InputSpace>
    <nActive>32</nActive>
    <nDim>1</nDim>
    <nVectors>32</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <quantized>false</quantized>
    <tokenizer>traditional</tokenizer>
  </InputSpace>

  <PerceptualSpace>
    <nActive>32</nActive>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <passThrough>false</passThrough>
    <hasAttention>true</hasAttention>
    <invertible>false</invertible>
    <quantized>false</quantized>
  </PerceptualSpace>

  <ConceptualSpace>
    <nActive>256</nActive>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <hasAttention>false</hasAttention>
    <hasNorm>false</hasNorm>
    <invertible>false</invertible>
    <quantized>false</quantized>
  </ConceptualSpace>

  <SymbolicSpace>
    <nActive>256</nActive>
    <nDim>1</nDim>
    <nVectors>256</nVectors>
    <passThrough>false</passThrough>
  </SymbolicSpace>

  <SyntacticSpace>
    <nActive>16</nActive>
    <nDim>1</nDim>
    <nVectors>16</nVectors>
  </SyntacticSpace>

  <OutputSpace>
    <nActive>32</nActive>
    <nDim>1</nDim>
    <nVectors>32</nVectors>
  </OutputSpace>
</model>
