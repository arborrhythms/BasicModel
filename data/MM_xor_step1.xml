<?xml version="1.0" ?>
<model>
  <!-- Step 1: XOR_exact + type=mental (only change) -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <ergodic>true</ergodic>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </PerceptualSpace>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): CS aligned to IS/PS
       (slab 6*10=60). nOutput halved from 12 to 6 to match. -->
  <ConceptualSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
