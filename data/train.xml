<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <weightsPath>weights.ckpt</weightsPath>

    <data>
      <dataset>text</dataset>
    </data>

    <training>
      <numEpochs>10</numEpochs>
      <learningRate>0.01</learningRate>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>32</nOutput>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>32</nOutput>
  </PerceptualSpace>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): CS aligned to IS/PS. -->
  <ConceptualSpace>
    <nOutput>32</nOutput>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>32</nOutput>
    <nDim>0</nDim>
    <nVectors>256</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>32</nOutput>
    <nVectors>32</nVectors>
  </OutputSpace>

  <embeddings>
    <numShards>1</numShards>
    <maxDocs>10000</maxDocs>
    <vectorSize>100</vectorSize>
    <trainingEpochs>10</trainingEpochs>
    <minCount>5</minCount>
    <artifactPath>BasicModel.kv</artifactPath>
  </embeddings>
</model>
