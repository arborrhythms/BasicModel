<?xml version="1.0" ?>
<model>
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <modelType>embedding</modelType>

    <data>
      <dataset>text</dataset>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>10</numEpochs>
      <batchSize>10</batchSize>
      <learningRate>0.01</learningRate>
      <weightsPath>output/weights.ckpt</weightsPath>
      <autoload>true</autoload>
      <autosave>false</autosave>
    </training>
  </architecture>

  <InputSpace>
    <nActive>32</nActive>
    <nDim>1</nDim>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <tokenizer>grammatical</tokenizer>
    <quantized>false</quantized>
  </InputSpace>

  <PerceptualSpace>
    <nActive>32</nActive>
    <nDim>1</nDim>
    <passThrough>false</passThrough>
    <nVectors>0</nVectors>
    <invertible>false</invertible>
    <quantized>false</quantized>
  </PerceptualSpace>

  <ConceptualSpace>
    <nActive>256</nActive>
    <nDim>1</nDim>
    <nVectors>0</nVectors>
    <hasNorm>false</hasNorm>
    <invertible>false</invertible>
    <quantized>false</quantized>
  </ConceptualSpace>

  <SymbolicSpace>
    <nActive>256</nActive>
    <nDim>0</nDim>
    <nVectors>256</nVectors>
    <passThrough>false</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nActive>32</nActive>
    <nDim>1</nDim>
    <nVectors>32</nVectors>
  </OutputSpace>

  <embeddings>
    <numShards>1</numShards>
    <maxDocs>10000</maxDocs>
    <vectorSize>100</vectorSize>
    <trainingEpochs>10</trainingEpochs>
    <minCount>5</minCount>
    <artifactPath>output/BasicModel.kv</artifactPath>
  </embeddings>
</model>
