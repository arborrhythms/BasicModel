<?xml version="1.0" ?>
<model>
  <architecture>
    <modelType>embedding</modelType>
    <weightsPath>weights.ckpt</weightsPath>

    <data>
      <dataset>text</dataset>
    </data>

    <training>
      <numEpochs>10</numEpochs>
      <learningRate>0.01</learningRate>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>32</nOutput>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>32</nOutput>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>256</nOutput>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>256</nOutput>
    <nDim>0</nDim>
    <nVectors>256</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>32</nOutput>
    <nVectors>32</nVectors>
  </OutputSpace>

  <embeddings>
    <numShards>1</numShards>
    <maxDocs>10000</maxDocs>
    <vectorSize>100</vectorSize>
    <trainingEpochs>10</trainingEpochs>
    <minCount>5</minCount>
    <artifactPath>BasicModel.kv</artifactPath>
  </embeddings>
</model>
