<?xml version="1.0" ?>
<model>
  <architecture>
    <reversePass>true</reversePass>
    <conceptualOrder>0</conceptualOrder>
    <symbolicOrder>0</symbolicOrder>
    <processSymbols>false</processSymbols>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <objectSize>0</objectSize>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <dataset>text</dataset>
    <modelType>lm</modelType>
    <numTrials>1</numTrials>
    <numEpochs>10</numEpochs>
    <batchSize>10</batchSize>
    <learningRate>0.01</learningRate>
    <pretrained>false</pretrained>
    <detectAnomaly>false</detectAnomaly>
    <weightsPath>output/weights.pt</weightsPath>
    <autoload>true</autoload>
    <autosave>false</autosave>
  </architecture>

  <InputSpace>
    <nVectors>32</nVectors>
    <dim>1</dim>
    <tokenizer>grammatical</tokenizer>
    <quantized>false</quantized>
  </InputSpace>

  <PerceptualSpace>
    <nVectors>32</nVectors>
    <dim>1</dim>
    <passThrough>false</passThrough>
    <prototypes>0</prototypes>
    <invertible>false</invertible>
    <quantized>false</quantized>
  </PerceptualSpace>

  <ConceptualSpace>
    <nVectors>256</nVectors>
    <dim>1</dim>
    <prototypes>0</prototypes>
    <hasNorm>false</hasNorm>
    <invertible>false</invertible>
    <quantized>false</quantized>
  </ConceptualSpace>

  <SymbolicSpace>
    <nVectors>256</nVectors>
    <dim>1</dim>
    <passThrough>false</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nVectors>32</nVectors>
    <dim>1</dim>
  </OutputSpace>

  <embeddings>
    <numShards>1</numShards>
    <maxDocs>10000</maxDocs>
    <vectorSize>100</vectorSize>
    <trainingEpochs>10</trainingEpochs>
    <minCount>5</minCount>
    <artifactPath>output/embeddings/sentence.pt</artifactPath>
  </embeddings>
</model>
