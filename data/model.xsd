      <xs:enumeration value="inline"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="lexerEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="word"/>
      <xs:enumeration value="sentence"/>
      <xs:enumeration value="byte"/>
      <!-- raw: InputSpace emits the unanalyzed [B,1,N] byte buffer; the
           meronymic analyzer (chunking="analyse") owns all tokenization. -->
      <xs:enumeration value="raw"/>
      <!-- ``meronomy`` (doc/mereological.md): the canonical analyzer;
           meet-from-top (all-1), the 1-x mirror of the meronomy synthesizer,
           cutting a whole into subordinate parts by boundary properties
           (first approximation: OR(space, punct) word split). -->
      <xs:enumeration value="meronomy"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="unitInterval">
    <xs:restriction base="xs:float">
      <xs:minInclusive value="0.0"/>
      <xs:maxInclusive value="1.0"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="nonNegativeFloat">
    <xs:restriction base="xs:float">
      <xs:minInclusive value="0.0"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="positiveFloat">
    <xs:restriction base="xs:float">
      <xs:minExclusive value="0.0"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Data section
       ═══════════════════════════════════════════════════════════════════ -->
  <xs:complexType name="dataType">
    <!-- xs:choice allows multiple <input>/<output> elements (inline data mode) -->
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <!-- embedding (text/LM, the default for language configs) | numeric
           (dense slab, e.g. MNIST). Was the architecture-level <modelType>. -->
      <xs:element name="dataType" type="dataTypeEnum"/>
      <xs:element name="dataset" type="datasetEnum"/>
      <xs:element name="numShards" type="xs:positiveInteger"/>
      <xs:element name="maxDocs" type="xs:positiveInteger"/>
