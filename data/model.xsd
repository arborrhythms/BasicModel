<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <!-- Root element -->
  <xs:element name="model">
    <xs:complexType>
      <xs:all>
        <!-- architecture is optional: a config may omit it and inherit the
             whole block from the data/model.xml defaults overlay (and
             minimal fixtures, e.g. grammar-only configs, carry no
             architecture at all). -->
        <xs:element name="architecture" type="architectureType" minOccurs="0"/>
        <xs:element name="mentalModel" type="mentalModelType" minOccurs="0"/>
        <xs:element name="InputSpace" type="inputSpaceType" minOccurs="0"/>
        <xs:element name="PartSpace" type="partSpaceType" minOccurs="0"/>
        <xs:element name="ModalSpace" type="modalSpaceType" minOccurs="0"/>
        <xs:element name="ConceptualSpace" type="conceptualSpaceType" minOccurs="0"/>
        <xs:element name="WholeSpace" type="wholeSpaceType" minOccurs="0"/>
        <xs:element name="OutputSpace" type="outputSpaceType" minOccurs="0"/>
        <xs:element name="SymbolSpace" type="symbolSpaceType" minOccurs="0"/>
        <xs:element name="embeddings" type="embeddingsType" minOccurs="0"/>
      </xs:all>
    </xs:complexType>
  </xs:element>

  <!-- TetralemmaPolicy: shared 4-valued (catuskoti) balance policy
       inherited by ConceptualSpace and WholeSpace unless their
       <tetralemmaOverride enabled="true"> opts out. -->
  <xs:complexType name="tetralemmaPolicyType">
    <xs:all>
      <xs:element name="allowExcludedMiddle" type="xs:integer" minOccurs="0"/>
      <xs:element name="allowContradiction" type="xs:integer" minOccurs="0"/>
      <xs:element name="neitherThreshold" type="nonNegativeFloat" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- Per-space override marker. enabled="true" means the space
       block defines its own <TetralemmaPolicy>; default inherits. -->
  <xs:complexType name="tetralemmaOverrideType">
    <xs:attribute name="enabled" type="xs:boolean" use="optional" default="false"/>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Architecture (top-level config shared by all model types)
       ═══════════════════════════════════════════════════════════════════ -->
  <xs:complexType name="architectureType">
    <xs:all>
      <!-- The retired <modelType> (simple | embedding | passthrough | vq)
           moved into <data> as <dataType> (embedding | numeric) 2026-06-19:
           simple+passthrough collapsed to numeric, vq dropped (0 configs). -->
      <!-- subsymbolicOrder = T = number of per-stage ConceptualSpace
           instances in self.conceptualSpaces. Stage 10 (doc/plans/
           2026-05-27-perceptstore-meta-taxonomy-reentrancy.md): each
           stage owns its own Ramsified sigma_in (incoming fold) and
           sigma_cs (PARALLEL-mode residual lift). In PARALLEL mode the
           pipeline walks stages 0..T-1 with each stage's sigma_cs
           applied to the prior stage's CS output; in SERIAL mode
           SyntacticLayer.compose dispatch per stage replaces
           sigma_cs[k] (the per-stage SERIAL dispatch is a follow-up;
           currently the per-word loop uses the terminal CS). -->
      <xs:element name="subsymbolicOrder" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- wherePeriod (2026-07-04 encoding pass): the .where quadrature
           period in input BYTES. Default 8192 (twice the 4096 inputLength
           cap). Decoupled from architecture.nObjects (the retired implicit
           period, Sigma nVectors). The build seam keeps raise-to-fit for
           inputs longer than the period, warning once per build (never
           silent aliasing). -->
      <xs:element name="wherePeriod" type="xs:positiveInteger" minOccurs="0"/>
      <!-- whenPeriod (2026-07-04 encoding pass): the .when v2 LF horizon in
           clock ticks (the LTM event-addressing range). Default 1000000.
           The band is the SIMILARITY channel; absolute addressing rides the
           exact long-int clock (BasicModel.when_time), the Option-C hybrid. -->
      <xs:element name="whenPeriod" type="xs:positiveInteger" minOccurs="0"/>
      <!-- whenRungRatio: LF/HF period ratio of the .when v2 2-rung ladder.
           Default 32 (safe branch bound ~35 at the dense-support floor). -->
      <xs:element name="whenRungRatio" type="xs:positiveInteger" minOccurs="0"/>
      <!-- serial selects the per-word grammatical body. If omitted, code
           derives it from symbolicOrder > 0 for legacy configs. New configs
           should set it explicitly. -->
      <xs:element name="serial" type="xs:boolean" minOccurs="0"/>
      <!-- symbolicOrder is the symbolic iteration budget K of the conceptual
           wave. We are NOT forcing ramsification: the value is the maximum
           possible conceptual order, i.e. the order reached if a novel concept
           were introduced at every iteration. 0 disables the symbolic phase.
           It no longer serves as the primary mode selector; serial does. If
           omitted, the default still derives from the configured grammar for
           legacy configs: 1 when the XML enables a non-substrate rule, else 0. -->
      <xs:element name="symbolicOrder" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- syntacticOrder (doc/specs/orders.md, NEW 2026-06-19): the maximum
           DEPTH of the parse tree the grammatical (serial) reduction may build
           per sentence. A distinct axis from subsymbolicOrder (refinement
           passes), symbolicOrder (relational loop budget), and serial
           (traversal mode). 0 (default) =
           UNBOUNDED: the reduction runs to its natural single-S fixpoint
           (byte-identical). A positive value caps the NULL-seal reduce sweep to
           that many forced fold levels (statically clamped to the buffer
           capacity minus 1, so the CUDA-graph trip count stays static); the
           word-count upper bound holds STRUCTURALLY (a reduce micro-step is a
           no-op once a row's depth reaches 1). Inert in parallel mode:
           no per-sentence parse tree to bound. -->
      <xs:element name="syntacticOrder" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- TransformChooser kind. The placement scorer the structured
           grammar layers use: "anchordot" (default) is the stateless
           inner-product scorer (no params, state_dict / basin unchanged);
           "mlp" is the contextual MLPTransformChooser (a learned MLP over
           slot/pair state, candidate output, tool embedding and position).
           The MLP OWNS parameters, so selecting it changes the state_dict
           and starts a fresh basin (a deliberate cutover). -->
      <xs:element name="transformChooser" type="transformChooserEnum" minOccurs="0"/>
      <!-- Two-pass soft-superposition training for the grammar chooser
           (doc/Language.md "Soft-superposition route"). When true, each
           TRAINING batch runs twice as two separate trials: pass A at
           superposition temperature 0 (sharp, recorded) and pass B at
           exploreTemperature (flatter exploration, trimmed from the batch
           error, no batch-count increment). The chooser is in the gradient
           path directly (no straight-through). Default false keeps the single
           forward (byte-identical). -->
      <xs:element name="learning" type="xs:boolean" minOccurs="0"/>
      <!-- The [0, 1] superposition temperature for pass B of learning (0 =
           the chooser's own sharp softmax, 1 = uniform / flat; route scores
           are scaled by (1 - t)). Default 0.5. -->
      <xs:element name="exploreTemperature" type="xs:decimal" minOccurs="0"/>
      <!-- MetaSymbol role-participation Category codebook (doc/Language.md
           "Participation Categories"). When true, a small role-space
           VectorQuantize starts with one centroid per labelled grammar role
           (op_I[n] inputs + op_O1 outputs). Unsettled MetaSymbols accumulate
           bounded temporary role evidence during PERCEPTION; once stable they
           commit to one category id and discard the pending row. The
           structured grammar layers use those role vectors for all transform
           choosers. Unused centroids decay (natural collapse). Default true. -->
      <xs:element name="categoryCodebook" type="xs:boolean" minOccurs="0"/>
      <!-- Legacy/direct LiftLayer adverb helper flag. The live AdverbLayer
           grammar op force-builds the same zero-init eigenmodifier; this knob
           only affects ordinary LiftLayer instances. When true for plain
           LiftLayer, an adverb modifies a composed VP as a SPARSE eigenvalue
           edit of the verb, masked by the VP's own eigen-signature:
           a2 = atanh(vp) + p_vp (.) delta_adv. Default false leaves plain
           LiftLayer's sigma fold byte-identical. -->
      <xs:element name="adverbEigEdit" type="xs:boolean" minOccurs="0"/>
      <!-- Mereological order-raising (doc/specs/mereological-order-raising.md).
           When true, perception's autobind hook builds a meronymic lattice over
           the two towers: it mints objects at abstraction order 0 and raises
           order as attention requires (subsymbolicOrder sets the max order) by
           synthesizing a higher-order PART when many parts collapse onto one
           whole, relinking it and pruning the moot part-whole edges. The
           ramsification table is enabled at build on the PartSpace + terminal
           WholeSpace codebooks. Default false: no table allocated, no raising
           (byte-identical). -->
      <xs:element name="mereologyRaise" type="xs:boolean" minOccurs="0"/>
      <!-- RETIRED (2026-07-02 P3 two-phase forward, decision 10): phase
           separation makes non-replacement structural; the symbolic
           phase's outputs feed the SS leg, the head-side losses, and the
           concept table, never substituting the subsymbolic advance.
           Parsed only to emit a DeprecationWarning. -->
      <xs:element name="sparseReplace" type="xs:boolean" minOccurs="0"/>
      <!-- P4 sigma/pi stacks (2026-07-02 two-phase plan): distinct per-pass
           subsymbolic layers, PS sigmas[t] / WS pis[t], t in
           0..subsymbolicOrder-1 (depth IS mereological order; the stack is
           the subsymbolic reasoning engine). Default false: the single
           reused sigma/pi, byte-identical (construction is RNG-neutral). -->
      <xs:element name="subsymbolicStack" type="xs:boolean" minOccurs="0"/>
      <!-- Pass indices whose stack layer is the IDENTITY pass-through, e.g.
           "0,2"; the slot still occupies its pass so the pump always runs
           to subsymbolicOrder. Consumed only when subsymbolicStack=true. -->
      <xs:element name="subsymbolicNoop" type="xs:string" minOccurs="0"/>
      <!-- SymbolSpace 3-stream peer bind (2026-06-21, Slice B). When true, the
           terminal ConceptualCombine is built with n_streams=3 and bind_streams
           routes a third (symbol) peer leg (PS/WS percepts + SS symbols). Default
           false -> the 2-stream (PS, WS) bind -> byte-identical. -->
      <xs:element name="symbolTower" type="xs:boolean" minOccurs="0"/>
      <!-- Reading attention (doc/specs/reading-attention.md "(A) Reading
           attention"). When true, a learned .where producer runs at each t>0
           subsymbolic pass and writes _passback_scope_where (the normalized
           [start, end] reading scope) on the stage-0 WholeSpace for the
           <mereologyRaise> top-down handoff to consume. The producer scores the
           staged analysis spans (the word brackets) from a query built off the
           prior pass's concept + the active STM symbols (a small learned MLP
           over detached features; the gradient stops at the primed symbols, so
           the EMA-only VQ codebooks are untouched), under a monotonic/coverage
           mask + a shift bootstrap (init selects the next span = the for-loop).
           In text mode (dataType embedding) training, a next-word cross-entropy
           term trains the producer to land on the next word. Default false: no
           module allocated, no scope written, no loss (byte-identical). -->
      <xs:element name="readingAttention" type="xs:boolean" minOccurs="0"/>
      <!-- Global attention (doc/specs/reading-attention.md "(B) Global
           attention"). When true, a free, content/relation-driven attention
           ranges over a TYPED addressable space - the input window, STM, LTM,
           and the symbol/whole codebook (the meronomy+taxonomy inventory) -
           emitting a typed .where (which space + the [start,end] bracket) and a
           soft-read of the addressed content (parked on _global_attention_obs).
           Unlike reading attention it has no monotonic mask and no next-word
           target, so it REQUIRES the stochastic element (the two-pass
           <learning>/<exploreTemperature>) to explore. The gradient stops at the
           keys (the codebook/LTM rows are EMA/persistent, detached); only the
           scorer readout trains. Dark by default: no module, the soft-read is
           parked not fed back, so the forward is byte-identical (the consumer
           that feeds the read into the task is a later slice). -->
      <xs:element name="globalAttention" type="xs:boolean" minOccurs="0"/>
      <!-- Global-attention CONSUMER (doc/specs/reading-attention.md "(B)").
           When true, the parked soft-read is fed BACK into the head (the
           "answer") as a zero-init gated residual, so the answer/output loss
           trains the retrieval (gradient through the read, the attention
           distribution, the scorer; the codebook/LTM stores stay detached).
           This closes global attention's loop: the retrieval-augmented answer
           mechanism for the question-answering stages. The LTM address space is
           the parsed TruthSet (ltm_store), so "reading over the TruthSet stored
           in LTM" is the SPACE_LTM read fed back here. Requires
           globalAttention. Default false keeps the soft-read parked (B
           unchanged), byte-identical. -->
      <xs:element name="globalAttentionConsume" type="xs:boolean" minOccurs="0"/>
      <!-- Idea decoding (doc/old/2026-06-20-idea-decoder.md): generation as the
           dual of comprehension. When true, the reverse pass drives the seed
           from the grammar <generate> decode of the idea (idea -> symbol ->
           concept) and skips the chart rule rebuild. Default false -> the
           rule-driven reverse is unchanged (byte-identical). -->
      <xs:element name="ideaDecode" type="xs:boolean" minOccurs="0"/>
      <!-- Reconstruct from the idea rather than replaying the forward parse.
           When true, reverse() clears SymbolSpace's current/generate rules and
           the signal-router's last route, then calls generate on the supplied
           idea snapshot to infer which reverse operations should run. Default
           false preserves the ordinary cached-derivation reverse path. -->
      <xs:element name="reconstructFromIdea" type="xs:boolean" minOccurs="0"/>
      <!-- Truth-grounded reasoning, N-step (doc/plans/2026-06-23-reasoning-
           live-wiring.md). N = the number of intervening-idea iterations = the
           reasoning steps = the max chain depth leading to the answer. The
           recurrent tool-use loop proposes N ideas (the soft policy over the
           hard isTrue/isPart tools), verifies each hop, and realizes the chain
           to N sentences ranked by subsymbolic (attention) relevancy. This knob
           is the on/off SWITCH: absent ⇒ reasoning off (byte-identical); a
           positive value (10 recommended) turns it on with that chain depth;
           0 is explicitly off. -->
      <xs:element name="reasoningIterations" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- DEPRECATED alias for reasoningIterations (the prior boolean gate).
           When true it enables reasoning at the default depth (10); prefer
           <reasoningIterations>. Default false. -->
      <xs:element name="queryReasoning" type="xs:boolean" minOccurs="0"/>
      <!-- Serial word-at-a-time object/meta (doc/specs/mereological-order-
           raising.md "Serial-mode word-at-a-time loop"). When true (serial
           traversal only), the per-word body HARD-MASKS each step to
           the active word's span (PartSpace processes the word block via
           word_span_window instead of the soft gaussian window) and the STM
           push + the eager A/B/C mint fire ONCE PER WORD (the last-slot commit
           gate). Whole-sentence context re-enters via the §6c prelude's
           gist/intent. Independent of <mereologyRaise>. Default false ->
           gaussian window + per-slot push (byte-identical). -->
      <xs:element name="serialObjectMeta" type="xs:boolean" minOccurs="0"/>
      <!-- Truth / Ideas routing is structural, not flag-gated: accepted
           relative relations reduce to WS META when both entity operands snap
           to existing WS codebook rows; otherwise the composed-idea relation is
           stored explicitly with scalar trust. The <trust> multiplier below
           applies to incoming assertions/testimony before they enter the
           TruthSet, LTM, or learned-relation stores. -->
      <!-- LTM consolidation (doc/specs/mereological-order-raising.md "Truth /
           Ideas processing", "Two consolidation questions"; Alec 2026-06-18).
           When true, the discourse LTM (InterSentenceLayer end-state chain) and
           the RelativeTruthStore are COMBINED into ONE unified TernaryTruthStore
           tensor (Layers.TernaryTruthStore): rows (NP1, VP, NP2) of FULL idea
           vectors + a per-row timestamp + a scalar trust, stored UNSCALED. The
           store is constructed on SymbolicSubSpace (ltm_store), written at the
           observe site (every end-state appends a row), retired RelativeTruthStore
           (relative_store is built ONLY when this gate is OFF), persists via
           submodule registration (rides the state_dict) and survives Reset
           (it is an attribute, not in self.layers). reason/verify_relation read
           it on the content-width slice. Augmentable from an XML <truthSet> at
           load (provision_ltm). Off by default -> the legacy two-store path
           (byte-identical). This gate governs the storage home; the
           reduce-or-describe routing itself is structural. -->
      <xs:element name="ltmConsolidation" type="xs:boolean" minOccurs="0"/>
      <!-- LTM provisioning (doc/specs/mereological-order-raising.md "Augment the
           LTM by parsing a TruthSet from XML config"; Alec 2026-06-18). A set of
           trusted truths appended to the consolidated LTM at model load
           (provision_ltm), earliest timestamps. Each <truth> carries the text
           (the 'text' attribute or element content) and a 'trust' value in
           [-1, 1]; optional 'kind' (partOf | implies | other) tags the relation
           type. The row trust is multiplied by architecture.<trust>. Read only
           when <ltmConsolidation> is on and an ltm_store exists; otherwise
           ignored. See <trust>/<truthCriterion> for the runtime (JSON)
           truth-ingest path; this is the static, config-time provisioning path. -->
      <xs:element name="truthSet" minOccurs="0">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="truth" minOccurs="0" maxOccurs="unbounded">
              <xs:complexType>
                <xs:simpleContent>
                  <xs:extension base="xs:string">
                    <xs:attribute name="text" type="xs:string"/>
                    <xs:attribute name="trust" type="xs:decimal"/>
                    <xs:attribute name="kind" type="xs:string"/>
                  </xs:extension>
                </xs:simpleContent>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <!-- GrammarOpsPass §6c (author sign-off 2026-06-11): the sentence
           protocol. In serial mode every sentence opens with an
           independent PARALLEL prelude of <subsymbolicOrder> pumps
           (pump zero: EMA on, intent-only commit — the gist primes
           both towers via §5 set_intent; nothing enters the
           workspace), then the per-word serial task runs under the
           §6d serial partition; the gist re-pumps on preemption only.
           Default false until the author's cutover. -->
      <xs:element name="sentenceProtocol" type="xs:boolean" minOccurs="0"/>
      <!-- Task 4 (doc/plans/2026-05-29-stm-serial-parallel-modes.md §4):
           per-word router-fire gating for serial mode.
             per-word  = fire symbolSpace.compose once per word in the
                         serial per-word loop (intra-predictor routing
                         context); boundary fire OFF.
             boundary  = fire only at the sentence boundary
                         (_chart_compose_at_C / _chart_generate_from_stm);
                         the inter-sentence predictor's routing snapshot.
             both      = (DEFAULT) per-word AND boundary both fire.
             off       = neither fires. -->
      <xs:element name="routerWireSerial" type="routerWireSerialEnum" minOccurs="0"/>
      <xs:element name="processSymbols" type="xs:boolean" minOccurs="0"/>
      <!-- Meronomy mode (MeronomySpec; MeronomyPlan Stage 9 cutover,
           2026-06-11): "on" binds the meronymic slots (PS.sigma /
           SS.pi) to the membership kernels via the K3-wire adapter and
           enables the interface factoring, the pole-quotient
           reference-half lookup, and the word/object binding table.
           Text on|off (default off in code; the cutover sets "on" in
           model.xml). dMaxStable bounds the contractive diagonal's
           stable clamp (default 4.0). -->
      <xs:element name="meronomy" minOccurs="0">
        <xs:complexType>
          <xs:simpleContent>
            <xs:extension base="xs:string">
              <xs:attribute name="dMaxStable" type="nonNegativeFloat"/>
            </xs:extension>
          </xs:simpleContent>
        </xs:complexType>
      </xs:element>
      <xs:element name="ergodic" type="xs:boolean" minOccurs="0"/>
      <xs:element name="naive" type="xs:boolean" minOccurs="0"/>
      <!-- Master switch for symbolic-priming heat (forward working memory);
           default false = off, zero training-path cost. Plan
           2026-06-06-symbolic-heat-retrieval. -->
      <xs:element name="symbolicPriming" type="xs:boolean" minOccurs="0"/>
      <!-- Retrieval scalar knobs for heat-biased candidate scoring
           (plan §Configuration, doc/plans/2026-06-06-symbolic-heat-retrieval.md).
           All optional; defaults preserved in code (off by default when
           attention=off).  retrievalTopKContent / retrievalTopKHeat: candidate
           union sizes.  retrievalOuterTopK: active rows for outer-heat builders.
           retrievalAlpha / retrievalBeta: content-sim / heat-log weights.
           retrievalGamma / retrievalDelta: first- / second-order carrier weights
           (zero = off = byte-identical to primer mode).
           retrievalUseOuterProduct: reserved for future dense-C gating. -->
      <xs:element name="retrievalTopKContent" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="retrievalTopKHeat" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="retrievalOuterTopK" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="retrievalAlpha" type="xs:decimal" minOccurs="0"/>
      <xs:element name="retrievalBeta" type="xs:decimal" minOccurs="0"/>
      <xs:element name="retrievalGamma" type="xs:decimal" minOccurs="0"/>
      <xs:element name="retrievalDelta" type="xs:decimal" minOccurs="0"/>
      <xs:element name="retrievalUseOuterProduct" type="xs:boolean" minOccurs="0"/>
      <xs:element name="sigmaPi" type="sigmaPiEnum" minOccurs="0"/>
      <xs:element name="prediction" type="predictionEnum" minOccurs="0"/>
      <!-- Trial-split: fraction of training batches run as pure next-idea
           prediction trials (reconstruction terms zeroed). 0.0 -> off ->
           byte-identical. -->
      <xs:element name="predictionTrialRatio" type="unitInterval" minOccurs="0"/>
      <xs:element name="maxResponseLength" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="data" type="dataType" minOccurs="0"/>
      <xs:element name="training" type="trainingType" minOccurs="0"/>
      <!-- Architecture-level embedding-training override. Models.py reads
           ``trainEmbeddings`` (and singular ``trainEmbedding``) from the
           architecture block ahead of ``<training><trainEmbedding>``; the
           boolean plural form maps true -> BOTH, false -> NONE. -->
      <xs:element name="trainEmbeddings" type="xs:boolean" minOccurs="0"/>
      <xs:element name="trainEmbedding" type="trainEnum" minOccurs="0"/>
      <xs:element name="server" type="serverType" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="embeddingPath" type="xs:string" minOccurs="0"/>
      <xs:element name="weightsPath" type="xs:string" minOccurs="0"/>
      <xs:element name="monotonic" type="xs:boolean" minOccurs="0"/>
      <xs:element name="truthBiasScale" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="LuminosityWeight" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="UniversalityWeight" type="nonNegativeFloat" minOccurs="0"/>
      <!-- Quaternary-corner balance knobs (tetralemma / catuskoti): select
           which corners of {T, F, N, B} are permitted during training. See
           basicmodel/doc/Philosophy.md for the 4-valued (quaternary)
           truth semantics.
             allowExcludedMiddle:  1  = permit NEITHER (default)
                                  -1  = forbid NEITHER (classical LEM)
             allowContradiction:   0  = forbid BOTH (default, non-contradiction)
                                   1  = permit BOTH (paraconsistent / LP)
       -->
      <xs:element name="allowExcludedMiddle" type="xs:integer" minOccurs="0"/>
      <xs:element name="allowContradiction" type="xs:integer" minOccurs="0"/>
      <!-- Shared tetralemma policy block for ConceptualSpace /
           WholeSpace; per-space override via that section's
           ``<tetralemmaOverride enabled="true">`` plus its own nested
           <TetralemmaPolicy>. -->
      <xs:element name="TetralemmaPolicy" type="tetralemmaPolicyType" minOccurs="0"/>
      <xs:element name="l1Lambda" type="xs:decimal" minOccurs="0"/>
      <xs:element name="discontinuityLambda" type="xs:decimal" minOccurs="0"/>
      <xs:element name="useSubspaceActivation" type="xs:boolean" minOccurs="0"/>
      <xs:element name="certainty" type="xs:boolean" minOccurs="0"/>
      <xs:element name="amp" type="ampModeEnum" minOccurs="0"/>
      <!-- Runtime device default (cpu | gpu | cuda | mps). Env override:
           BASICMODEL_DEVICE. Gate fixtures pin cpu: MPS kernels are
           nondeterministic, so a seeded gate only reproduces on CPU. -->
      <xs:element name="device" type="xs:string" minOccurs="0"/>
      <!-- L1 penalty on lift / lower gates. 0 disables. -->
      <xs:element name="gateL1Lambda" type="nonNegativeFloat" minOccurs="0"/>
      <!-- Sparse-MoE load-balance loss weight. Currently inert: the
           load-balance bookkeeping retired with the chart and this knob
           has no consumer yet; it stands by for future signal-router
           rule load-balancing. -->
      <xs:element name="loadBalanceWeight" type="nonNegativeFloat" minOccurs="0"/>
      <!-- Symbol-partition geometry for subsymbolicOrder > 1:
           tapered = geometrically narrowing slices (default);
           uniform = equal-width slices. -->
      <xs:element name="conceptualWidth" type="conceptualWidthEnum" minOccurs="0"/>
      <xs:element name="maxActivePerLayer" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Single continuous truth bar in [0, 1] (read onto ConceptualSpace
           AND WholeSpace; overridable per-space). 0 = record/accept all
           truths, 1 = none. Governs BOTH content-aware learned-relation
           codebook insertion and WholeSpace truth recording (gold +
           training). Replaces the retired binary accumulateTruth /
           truthMinMagnitude switches. -->
      <xs:element name="truthCriterion" type="unitInterval" minOccurs="0"/>
      <!-- Model-level trust in incoming assertions/testimony. Effective
           signed DoT = this multiplier * incoming trust. For persisted STM
           descriptions, absolute rows store this event trust and relative rows
           apply it to the relation's collapsed scalar trust. -->
      <xs:element name="trust" type="unitInterval" minOccurs="0"/>
      <xs:element name="codebookRetire" type="xs:boolean" minOccurs="0"/>
      <xs:element name="symbolLearning" type="symbolLearningType" minOccurs="0"/>
      <!-- Per-stage chart re-parse retired 2026-05-12 alongside chart-
           at-stem.  The chart now fires uniformly at C-tier inside
           every body stage; the legacy reparse knob is no longer read. -->
      <!-- Retired compatibility knob. MereologicalTree has been removed;
           values are accepted but ignored. -->
      <xs:element name="mereologicalTreeSize" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Optional: dump POS-labelled syntax tree at end of every
           MentalModel.forward(); see doc/Language.md "POS side-channel". -->
      <xs:element name="writeSyntax" type="xs:boolean" minOccurs="0"/>
      <xs:element name="syntaxOutPath" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       MentalModel section — present only for MentalModel configs
       ═══════════════════════════════════════════════════════════════════ -->
  <xs:complexType name="mentalModelType">
    <xs:all>
      <xs:element name="grammar" type="grammarType" minOccurs="0"/>
      <xs:element name="interpretation" type="unitInterval" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Enumerations
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Data tier (was the architecture-level <modelType>). embedding = the
       text / language-model path (PartSpace owns the byte/word Embedding
       lexicon); numeric = the dense-slab path (InputSpace carries a plain
       Tensor; e.g. MNIST pixels). Lives in <data> as <dataType>. -->
  <xs:simpleType name="dataTypeEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="embedding"/>
      <xs:enumeration value="numeric"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="ampModeEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value="off"/>
      <xs:enumeration value="fp16"/>
      <xs:enumeration value="bf16"/>
    </xs:restriction>
  </xs:simpleType>

