  <!-- ═══════════════════════════════════════════════════════════════════
       WordSpace section — unified container for grammar infrastructure
       (SyntacticLayers, TruthLayer) and the per-batch inter-sentence
       ARMA(p, q) predictor (InterSentenceLayer). Sentence-level AR
       lives here, not in the within-sentence body — the body is now
       a pure IR (masked-LM) forward.

       InterSentenceLayer shape knobs live in this section
       (armaP / armaQ / armaHiddenDim); the loss weight lives under
       <architecture><training> as <armaScale>.
       ═══════════════════════════════════════════════════════════════════ -->
  <xs:complexType name="wordSpaceType">
    <xs:all>
      <xs:element name="syntacticHiddenDim" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="truthMaxEntries" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- InterSentenceLayer ARMA(p, q) shape knobs. p = AR lag count
           (number of previous sentence reps); q = MA lag count
           (number of previous prediction errors); armaHiddenDim is
           the MLP predictor's hidden layer width.  Defaults: p=5,
           q=2, hiddenDim=2*sentence_dim (computed at construction
           time when omitted). -->
      <xs:element name="armaP" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="armaQ" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="armaHiddenDim" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Long-term-memory (LTM) chain capacity: the InterSentenceLayer
           bounds its per-row chain of STM end-states (the AR sequence
           used for inter-sentence prediction) at this many entries.
           Separate from <truthMaxEntries> (TruthLayer's SS-codebook
           capacity). Default 1024. -->
      <xs:element name="ltmCapacity" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Stage 3 cleanup (2026-05-27): parserBackend, routerKind,
           chartTau, wMax, chartTopK, chartNoiseEps retired alongside
           the chart. The signal router (LanguageLayer) is the
           canonical parser. The retired elements raise loud
           ValueError at config load time; see
           Language._assert_retired_chart_knobs_absent. -->
      <!-- Soft-superposition output collapse mode; preserved for the
           signal router's root-state writeback contract. -->
      <xs:element name="chartCollapse" type="chartCollapseEnum" minOccurs="0"/>
      <!-- Per-word stem is the only path. Each word does an individual
           P->C->S->C round trip in the stem, ideas accumulate on
           ConceptualSpace.stm, and the chart fires at C over STM in the
           body. ``perWordStem`` knob removed 2026-05-12; legacy chart-
           at-stem launch retired in the same pass. -->
      <!-- Number of P->C iterations per word in the per-word stem path. -->
      <xs:element name="iterationsPerWord" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Downward generation: when true, MentalModel.forward() emits a
           codebook head via WordSpace.reconstruct() and stashes it on
           self._predicted_head for downstream (e.g. loss) consumption. -->
      <xs:element name="downwardGeneration" type="xs:boolean" minOccurs="0"/>
      <xs:element name="language" type="languageType" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="embeddingsType">
    <xs:all>
      <xs:element name="numShards" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="maxDocs" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="vectorSize" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="trainingEpochs" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="minCount" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="artifactPath" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Language section (inside <WordSpace>)
       ═══════════════════════════════════════════════════════════════════ -->
  <!-- ``start`` may repeat: multiple ``<start>`` tags define accepted
       unreduced forms / start patterns (see test_grammar_start_rule), so
       this uses xs:sequence (start* then grammar? then interpretation?)
       rather than xs:all (which caps each child at one). -->
  <xs:complexType name="languageType">
    <xs:sequence>
      <xs:element name="start" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="grammar" type="grammarType" minOccurs="0"/>
      <xs:element name="interpretation" type="unitInterval" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="grammarType" mixed="true">
    <!-- Grammar XML is intentionally open: configs may carry inline
         tier tags (<P>, <C>, <S>) and structured sections such as
         <compose>/<generate>, OR a bare text filename reference
         (``<grammar>complete.grammar</grammar>``) that
         ``WordSubSpace.load_from_grammar_file`` resolves under
         ``data/``. ``mixed="true"`` admits both forms. Language.py
         owns rule parsing. -->
    <xs:sequence>
      <xs:any processContents="skip" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="grammarSectionType">
    <xs:sequence>
      <xs:any processContents="skip" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

</xs:schema>
