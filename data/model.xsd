  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Training section
       ═══════════════════════════════════════════════════════════════════ -->
  <xs:complexType name="trainingType">
    <xs:all>
      <xs:element name="numTrials" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="numEpochs" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- RNG seed for the whole run (torch/python/numpy). Pins
           construction-time init and data order so single CLI runs are
           reproducible; the XOR_exact gates rely on this. Env override:
           BASIC_SEED. -->
      <xs:element name="seed" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="batchSize" type="xs:positiveInteger" minOccurs="0"/>
      <!-- DataLoader prefetch workers. 0 means synchronous in-process
           batch assembly. -->
      <xs:element name="numWorkers" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="learningRate" type="nonNegativeFloat" minOccurs="0"/>
      <!-- reconstructionScale: blend weight between OutputSpace
           prediction loss and reconstruction loss. Higher value =
           more reconstruction. 0 = output-only training.
           Legacy name reverseScale still parsed (with deprecation
           warning) by util.TheXMLConfig. -->
      <xs:element name="reconstructionScale" type="unitInterval" minOccurs="0"/>
      <!-- Deprecated legacy alias for reconstructionScale; util.TheXMLConfig
           remaps it (with a deprecation warning). Accepted here so
           unmigrated configs still validate. -->
      <xs:element name="reverseScale" type="unitInterval" minOccurs="0"/>
      <xs:element name="whatScale" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="whereScale" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="whenScale" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="negSamples" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="TruthLoss" type="nonNegativeFloat" minOccurs="0"/>
      <!-- Weight of the truth-grounded reasoning answer (policy) loss
           (doc/plans/2026-06-23-truth-grounded-reasoning.md, Phase 5): NLL on
           the [0,1] proof-success score vs the gold answer, backpropagated
           through the SOFT route (the intervening-idea generator's query head +
           the attention alpha) only, never the hard deduction. Default 0.0 =
           off (no answer loss term). Requires <queryReasoning>. -->
      <xs:element name="answerLossWeight" type="nonNegativeFloat" minOccurs="0"/>
      <!-- Step 2: the next-idea POLICY loss weight. Trains the reasoner's
           {arma, retrieval, deduction} blend to predict the observed next
           end-state root (gradient through the blend weights + scorer only,
           not the detached candidates). 0.0 = off (byte-identical). -->
      <xs:element name="predictNextLossWeight" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="maskRate" type="unitInterval" minOccurs="0"/>
      <xs:element name="trainEmbedding" type="trainEnum" minOccurs="0"/>
      <xs:element name="embeddingScale" type="nonNegativeFloat" minOccurs="0"/>
      <!-- Weight of the conceptual-similarity SBOW loss (the rotation SBOW that
           situates ConceptualSpace.similarity_codebook, which is always built).
           Default 0.0 = the SBOW does not fire and the forward is byte-identical;
           > 0 trains the codebook in the parallel (symbolicOrder=0) forward. -->
      <xs:element name="conceptualSimilarityScale" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="autoload" type="xs:boolean" minOccurs="0"/>
      <xs:element name="autosave" type="xs:boolean" minOccurs="0"/>
      <xs:element name="checkpointEveryBatches" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="profile" type="xs:boolean" minOccurs="0"/>
      <xs:element name="certainty" type="xs:boolean" minOccurs="0"/>
      <!-- Inter-sentence ARMA(p, q) next-sentence prediction
           (InterSentenceLayer). The layer's AR/MA orders and hidden
           dim live under <SymbolSpace> (armaP/armaQ/armaHiddenDim);
           this scale is the loss weight applied on top of the
           per-batch ARMA MSE. -->
      <xs:element name="sentencePrediction" type="xs:boolean" minOccurs="0"/>
      <xs:element name="armaScale" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="sentencePrimingScale" type="nonNegativeFloat" minOccurs="0"/>
      <!-- In-STM autoregressive prediction (IntraSentenceLayer). Loss
           weight on the per-word L_intra = MSE(predicted idea, observed
           idea), added to the IR-loss path. The PI-then-Sigma predictor
           is owned by ConceptualSpace. -->
      <xs:element name="intraLossWeight" type="nonNegativeFloat" minOccurs="0"/>
      <!-- Inter-sentence end-state prediction (InterSentenceLayer's
           inter-level IntraSentenceLayer instance). Loss weight on the
           per-sentence L_inter = MSE(predicted next-end-state root,
           observed root), summed over the discourse window. Mirrors
           intraLossWeight. -->
      <xs:element name="interLossWeight" type="nonNegativeFloat" minOccurs="0"/>
      <!-- InfoNCE next-idea contrastive term: weight + softmax temperature.
           Reuses the InterSentenceLayer end-state chain (positive next root
           ranked above the chain's past roots). 0.0 weight -> MSE-only
           (byte-identical). -->
      <xs:element name="interContrastiveWeight" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="interContrastiveTemp" type="positiveFloat" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Server section
       ═══════════════════════════════════════════════════════════════════ -->
  <xs:complexType name="serverType">
    <xs:all>
      <xs:element name="host" type="xs:string" minOccurs="0"/>
      <xs:element name="port" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="timeout" type="xs:positiveInteger" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Space types
       ═══════════════════════════════════════════════════════════════════ -->

  <xs:complexType name="inputSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <!-- Phase 4b (analysis/synthesis dual-input plan, rev. 2026-06-09):
           the <lexer> element moved to WholeSpace - lexing is analytic
           cutting, owned by the analysis side. An InputSpace-side <lexer>
           now fails schema validation AND the runtime reader. -->
    </xs:all>
  </xs:complexType>

  <xs:complexType name="partSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="passThrough" type="xs:boolean" minOccurs="0"/>
      <!-- DEPRECATED QKV legacy alias; inert. See attentionModeEnum. -->
      <xs:element name="hasAttention" type="xs:boolean" minOccurs="0"/>
      <!-- Symbolic-retrieval mode (off|primer|second-order|low-rank);
           default off. Supersedes <hasAttention>. See attentionModeEnum
           and doc/plans/2026-06-06-symbolic-heat-retrieval.md. -->
      <xs:element name="attention" type="attentionModeEnum" minOccurs="0"/>
      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="nonlinear" type="xs:boolean" minOccurs="0"/>
      <!-- Stage 5 (doc/plans/2026-05-26-two-loop-pi-sigma-substrate.md):
           optional butterfly cascade on PartSpace.pi for
           cross-element FFT-style mixing over the flattened [B, N*D]
           view. When ``butterfly=true`` the PiLayer is built with the
           cascade enabled. The cascade length N is AUTO-COMPUTED from
           the space shape (nInput * nInputDim) and internally padded to
           the next power of two; there is no explicit length knob (the
           former ``<butterflyN>`` element was retired 2026-06-05; the
           cascade derives N from the shape). Default off; configs that
           don't opt in see the legacy PiLayer construction unchanged. -->
      <!-- DEPRECATED alias for <sigmaPi> (true -> butterfly, false/absent
           -> last). New configs should use architecture-level <sigmaPi> instead. -->
      <xs:element name="butterfly" type="xs:boolean" minOccurs="0"/>
      <!-- PartSpace is subsymbolic: its <codebook> element was retired
           (2026-06-09, asymmetric-VQ plan §7 task 7). PS behaviour is fixed
           to "none" (continuous .event passthrough; percept prototypes live
           on the .what Embedding). Only WholeSpace carries a <codebook>. -->
      <!-- VQ-VAE EMA / growing-codebook knobs (shared semantics with
           wholeSpaceType; see comments there). -->
      <xs:element name="commitmentDecay" type="positiveFloat" minOccurs="0"/>
      <xs:element name="codebookRetire" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebookEmaDeadThreshold" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="codebookGrowthEpsilon" type="nonNegativeFloat" minOccurs="0"/>
      <!-- wordLearning (formerly chunkingFrequency): controls active
           lexicon growth. 0 = frozen codebook (training-time default);
           >=1 = on first sight of a new word, insert it into the
           lexicon and tag it as a part of the "words" symbol on the
           meronomy. Only embed.py sets >0 at lexicon-build time. -->
      <xs:element name="wordLearning" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- Phase 4 of the analysis/synthesis dual-input plan (rev.
           2026-06-09): the perceptual front-end knob is SYNTHESIS,
           the bottom-up union of atoms into chunks/surface forms. It
           was named ``<chunking>``; the legacy spelling is REJECTED
           LOUDLY by the PartSpace reader (no silent aliasing).
           ``analyse`` is accepted here only until Phase 4b moves the
           meronymic analyzer to WholeSpace <analysis>. -->
      <xs:element name="synthesis" minOccurs="0">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="bpe"/>
            <xs:enumeration value="mphf"/>
            <xs:enumeration value="lexicon"/>
            <!-- ``none``: byte-direct.  Each byte becomes its own
                 perceptual slot via a 256-entry codebook lookup; no
                 BPE walker, no Python trie, no graph break at the
                 chunking boundary.  ``\0`` (byte 0) doubles as the
                 sentence-end / pad sentinel.  Requires nVectors>=256
                 and dataType=embedding.  See doc/Spaces.md
                 §"Chunking modes" for the cognitive rationale.
                 ``byte`` is the canonical spelling; ``none`` is its
                 legacy alias. -->
            <xs:enumeration value="none"/>
            <xs:enumeration value="byte"/>
            <!-- Stage 7 (doc/plans/2026-05-27-perceptstore-meta-
                 taxonomy-reentrancy.md): ``radix`` routes chunking
                 through a ``PerceptStore`` (radix trie + hash map +
                 inverse table + learned codebook + byte fallback +
                 promotion). An alternative to Lexicon/MPHF/BPE for
                 the surface-form authoritative store; opt in with
                 ``<synthesis>radix</synthesis>``. -->
            <xs:enumeration value="radix"/>
            <!-- ``meronomy`` (doc/mereological.md): the canonical synthesizer.
                 Combines parts into a DOMINATING whole (join-from-bottom +
                 isotonic .where projection = the concept lattice, inert until
                 wired) AND isolates words (tags each percept by its WORD via
                 Meronomy.word_spans over the raw surface, so word_groups is one
                 agreed WORD grid for PS/WS/CS; the serial per-word commit +
                 autobind mint one word/object/meta per word). Paired with the
                 WholeSpace <analysis>meronomy</analysis>. -->
            <xs:enumeration value="meronomy"/>
            <!-- the PartSpace ``analyse`` synthesis was REMOVED (Phase 4b, rev.
                 2026-06-09): the meronymic analyzer is top-down ANALYSIS and
                 lives on WholeSpace as <analysis>grammatical. Configs that ran
                 PS analyse migrate to <synthesis>lexicon (the closest surviving
                 word-resolution mode). -->
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <!-- Stage 7: radix-mode promotion knobs. ``chunkPromotionThreshold``
           is the byte-fallback hit count at which an unknown chunk
           gets promoted into the trie + codebook (default 4).
           ``chunkPromotionMinLength`` is the minimum chunk length
           (in bytes) below which promotion never fires (default 2).
           Both are ignored when chunking != "radix". -->
      <xs:element name="chunkPromotionThreshold"
                  type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="chunkPromotionMinLength"
                  type="xs:positiveInteger" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="modalSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="passThrough" type="xs:boolean" minOccurs="0"/>
      <!-- DEPRECATED QKV legacy alias; inert. See attentionModeEnum. -->
      <xs:element name="hasAttention" type="xs:boolean" minOccurs="0"/>
      <!-- Symbolic-retrieval mode; default off. See attentionModeEnum. -->
      <xs:element name="attention" type="attentionModeEnum" minOccurs="0"/>
      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <xs:element name="whatPassThrough" type="xs:boolean" minOccurs="0"/>
      <xs:element name="wherePassThrough" type="xs:boolean" minOccurs="0"/>
      <xs:element name="whenPassThrough" type="xs:boolean" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="conceptualSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- DEPRECATED QKV legacy alias; inert. See attentionModeEnum. -->
      <xs:element name="hasAttention" type="xs:boolean" minOccurs="0"/>
      <!-- Symbolic-retrieval mode; default off. Supersedes <hasAttention>.
           See attentionModeEnum. -->
      <xs:element name="attention" type="attentionModeEnum" minOccurs="0"/>
      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="nonlinear" type="xs:boolean" minOccurs="0"/>
      <!-- Optional butterfly cascade on the ConceptualSpace sigma fold
           (cross-element mixing; the cascade length is auto-computed from
           the space shape; see partSpaceType/butterfly). -->
      <!-- DEPRECATED alias for <sigmaPi> (true -> butterfly, false/absent
           -> last). New configs should use architecture-level <sigmaPi> instead. -->
      <xs:element name="butterfly" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <!-- VQ-VAE EMA / growing-codebook knobs (shared semantics with
           wholeSpaceType; see comments there). -->
      <xs:element name="commitmentDecay" type="positiveFloat" minOccurs="0"/>
      <xs:element name="codebookRetire" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebookEmaDeadThreshold" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="codebookGrowthEpsilon" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="tetralemmaOverride" type="tetralemmaOverrideType" minOccurs="0"/>
      <xs:element name="TetralemmaPolicy" type="tetralemmaPolicyType" minOccurs="0"/>
      <xs:element name="stmCapacity" type="xs:positiveInteger" minOccurs="0"/>
      <!-- perWordStemSerial: when true, the per-word stem uses a
           causal cursor loop (option (a) from the K-microbatch
           design discussion) instead of the parallel-over-AR-windows
           default.  Serial path: B-sized STM accumulates one new
           word per step; after the K-loop the snapshots are staged
           as [B*K, K, D_c] for the body's chart-at-C parallelism.
           Work drops from O(B*K*N) to O(B*K) in the stem.  Inductor
           unrolls the loop when K is shape-bucketed (BPE power-of-
           two quantisation). -->
      <xs:element name="perWordStemSerial" type="xs:boolean" minOccurs="0"/>
      <!-- Per-space override of architecture.truthCriterion. -->
      <xs:element name="truthCriterion" type="unitInterval" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="wholeSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- Phase 4b (analysis/synthesis dual-input plan, rev. 2026-06-09):
           WholeSpace owns the top-down ANALYSIS knobs.
           <lexer> (moved here from InputSpace): the intake granularity
           InputSpace executes - lexing is analytic cutting.
           <analysis>: the division strategy over the unity view.
             byte    = uniform contiguous regions (default; the stage-0
                       region-mean pooling).
             word    = whitespace-cut parts; per-part coarse means.
             analyse = the meronymic analyzer front end (space-lexer cut
                       today; the bottom-up merge integration follows with
                       the deeper SS analyzer work, Phases 5-6). -->
      <xs:element name="lexer" type="lexerEnum" minOccurs="0"/>
      <!-- <analyzer> REPLACES <lexer> (doc/mereological.md): tokenization is
           analytic cutting, owned by the analysis side (the meet-from-top
           mereological analyzer). <lexer> is the deprecated spelling; the
           config reader accepts both, preferring <analyzer>. -->
      <xs:element name="analyzer" type="lexerEnum" minOccurs="0"/>
      <!-- Task 5 (C-13, asymmetric-vq sec.6): the post-sentence semantic
           arrangement weight over SS heat (pode attraction + antipode
           repulsion on the activated codebook rows). Default 0 = OFF:
           the mechanism is validated under D (corpus, serial path). -->
      <xs:element name="semanticArrangement" type="nonNegativeFloat"
                  minOccurs="0"/>
      <xs:element name="analysis" minOccurs="0">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <!-- <analysis> is the UNIFIED WholeSpace knob; it absorbs the lexer
                 options (raw/byte/word/sentence; <lexer>/<analyzer> are the
                 deprecated spellings) PLUS the analysis-only modes. The
                 lexer-valued options set the surface lexer; the analysis-only
                 values (grammatical/meronomy) leave the lexer at raw and select
                 the division. -->
            <xs:enumeration value="byte"/>
            <xs:enumeration value="word"/>
            <xs:enumeration value="raw"/>
            <xs:enumeration value="sentence"/>
            <!-- ``grammatical`` (formerly ``analyse``): the property/boundary
                 analysis that cuts a whole into grammatical parts. -->
            <xs:enumeration value="grammatical"/>
            <!-- ``meronomy``: the meronymic word-isolation cut (1-x dual of the
                 meronomy synthesizer), paired with <synthesis>meronomy. -->
            <xs:enumeration value="meronomy"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="passThrough" type="xs:boolean" minOccurs="0"/>
      <!-- Symbolic-retrieval mode (off|primer|second-order|low-rank);
           default off. WholeSpace has no hasAttention legacy alias:
           it never constructed a QKV AttentionLayer. See attentionModeEnum
           and doc/plans/2026-06-06-symbolic-heat-retrieval.md. -->
      <xs:element name="attention" type="attentionModeEnum" minOccurs="0"/>
      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="nonlinear" type="xs:boolean" minOccurs="0"/>
      <!-- Optional butterfly cascade on the WholeSpace sigma operator
           (cross-slot mixing, needed for tasks like XOR that combine
           positions; the cascade length is auto-computed from the space
           shape; see partSpaceType/butterfly). -->
      <!-- DEPRECATED alias for <sigmaPi> (true -> butterfly, false/absent
           -> last). New configs should use architecture-level <sigmaPi> instead. -->
      <xs:element name="butterfly" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <xs:element name="sortNetwork" type="xs:boolean" minOccurs="0"/>
      <xs:element name="sortPasses" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- Gate WholeSpace's stack-rewrite LanguageLayer dispatch
           (``self.use_stack_router``). Default false keeps the legacy
           forward path. -->
      <xs:element name="useStackRouter" type="xs:boolean" minOccurs="0"/>
      <xs:element name="l1Lambda" type="xs:decimal" minOccurs="0"/>
      <xs:element name="discontinuityLambda" type="xs:decimal" minOccurs="0"/>
      <xs:element name="symbolResidualScale" type="xs:decimal" minOccurs="0"/>
      <xs:element name="outputSymbolResidualScale" type="xs:decimal" minOccurs="0"/>
      <xs:element name="commitmentBeta" type="nonNegativeFloat" minOccurs="0"/>
      <!-- VQ-VAE EMA decay (``VectorQuantize.decay``).  Higher = slower
           adaptation, more stable assignment across time; lower =
           faster drift but less stable.  Default 0.9 (see
           doc/Spaces.md §"Codebook drift sync"). -->
      <xs:element name="commitmentDecay" type="positiveFloat" minOccurs="0"/>
      <!-- Dead-code retire: when a slot's EMA ``cluster_size`` falls
           below ``codebookEmaDeadThreshold``, replace it with a fresh
           sample from the current input batch.  Off by default
           because reseeding can blow up the effective number of
           distinct codes on non-stationary data; enable for
           growing-codebook semantics where novel inputs should evict
           rarely-used slots. -->
      <xs:element name="codebookRetire" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebookEmaDeadThreshold" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- Novelty insertion threshold for ε-growing codebook semantics.
           When > 0, ``VectorQuantize.grow_on_novelty`` inserts an input
           vector into an empty slot whenever its min-distance to the
           live codebook exceeds this value.  0 disables (use
           dead-code retire above, or fixed-size codebook). -->
      <xs:element name="codebookGrowthEpsilon" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="decorrelationWeight" type="xs:decimal" minOccurs="0"/>
      <xs:element name="spectralFlatnessWeight" type="xs:decimal" minOccurs="0"/>
      <xs:element name="impenetrableAntisymmetry" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="impenetrableTransitivity" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="impenetrableOverlap" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="impenetrableVariance" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="tetralemmaOverride" type="tetralemmaOverrideType" minOccurs="0"/>
      <xs:element name="TetralemmaPolicy" type="tetralemmaPolicyType" minOccurs="0"/>
      <!-- Stage 8 (doc/plans/2026-05-27-perceptstore-meta-taxonomy-
           reentrancy.md §Stage 8): META taxonomy storage placeholder.
           The actual taxonomy graph (parent -> children, child -> parent,
           and (ps_idx, ws_idx) -> meta_idx) is a runtime structure on
           ``WholeSpace`` (``self.taxonomy``,
           ``self.taxonomy_parent_map``, ``self.meta_pair_to_idx``);
           it serialises through ``vocab_extras`` (the same sidecar that
           carries WordVectors mappings). This optional XSD element exists
           so configs can ship a comment about the storage location and
           future seeded-taxonomy bootstraps without schema drift. The
           string contents are advisory only; no runtime knob is
           consumed from here. -->
      <xs:element name="taxonomy" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="outputSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <xs:element name="nonlinear" type="xs:boolean" minOccurs="0"/>
      <!-- lrScale: multiplier on the base learning rate for the OutputSpace
           (readout) parameters only; they go in their own Adam group at
           lr*lrScale. Default 1.0 (single group, byte-identical). >1 lets the
           ill-conditioned, co-adapting regression readout track the upstream
           features faster so it converges to a crisp solution within the
           epoch budget. -->
      <xs:element name="lrScale" type="xs:decimal" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       SymbolSpace section — unified container for grammar infrastructure
       (SyntacticLayers, TruthLayer) and the per-batch inter-sentence
       ARMA(p, q) predictor (InterSentenceLayer). Sentence-level AR
       lives here, not in the within-sentence body — the body is now
       a pure IR (masked-LM) forward.

       InterSentenceLayer shape knobs live in this section
       (armaP / armaQ / armaHiddenDim); the loss weight lives under
       <architecture><training> as <armaScale>.
       ═══════════════════════════════════════════════════════════════════ -->
  <xs:complexType name="symbolSpaceType">
    <xs:all>
      <xs:element name="syntacticHiddenDim" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="truthMaxEntries" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- InterSentenceLayer ARMA(p, q) shape knobs. p = AR lag count
           (number of previous sentence reps); q = MA lag count
           (number of previous prediction errors); armaHiddenDim is
           the MLP predictor's hidden layer width.  Defaults: p=5,
           q=2, hiddenDim=2*sentence_dim (computed at construction
           time when omitted). -->
      <xs:element name="armaP" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="armaQ" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="armaHiddenDim" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Long-term-memory (LTM) chain capacity: the InterSentenceLayer
           bounds its per-row chain of STM end-states (the AR sequence
           used for inter-sentence prediction) at this many entries.
           Separate from <truthMaxEntries> (TruthLayer's SS-codebook
           capacity). Default 1024. -->
      <xs:element name="ltmCapacity" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Stage 3 cleanup (2026-05-27): parserBackend, routerKind,
           chartTau, chartTopK, chartNoiseEps retired alongside
           the chart. The signal router (LanguageLayer) is the
           canonical parser. The retired elements raise loud
           ValueError at config load time; see
           Language._assert_retired_chart_knobs_absent. -->
      <!-- Soft-superposition output collapse mode; preserved for the
           signal router's root-state writeback contract. -->
      <xs:element name="chartCollapse" type="chartCollapseEnum" minOccurs="0"/>
      <!-- Per-word stem is the only path. Each word does an individual
           P->C->S->C round trip in the stem, ideas accumulate on
           ConceptualSpace.stm, and the chart fires at C over STM in the
           body. ``perWordStem`` knob removed 2026-05-12; legacy chart-
           at-stem launch retired in the same pass. -->
      <!-- Number of P->C iterations per word in the per-word stem path. -->
      <xs:element name="iterationsPerWord" type="xs:positiveInteger" minOccurs="0"/>
      <!-- Downward generation: when true, MentalModel.forward() emits a
           codebook head via SymbolSpace.reconstruct() and stashes it on
           self._predicted_head for downstream (e.g. loss) consumption. -->
      <xs:element name="downwardGeneration" type="xs:boolean" minOccurs="0"/>
      <xs:element name="language" type="languageType" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="embeddingsType">
    <xs:all>
      <xs:element name="numShards" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="maxDocs" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="vectorSize" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="trainingEpochs" type="xs:positiveInteger" minOccurs="0"/>
      <xs:element name="minCount" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="artifactPath" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ═══════════════════════════════════════════════════════════════════
       Language section (inside <SymbolSpace>)
       ═══════════════════════════════════════════════════════════════════ -->
  <!-- ``start`` may repeat: multiple ``<start>`` tags define accepted
       unreduced forms / start patterns (see test_grammar_start_rule), so
       this uses xs:sequence (start* then grammar? then interpretation?)
       rather than xs:all (which caps each child at one). -->
  <xs:complexType name="languageType">
    <xs:sequence>
      <xs:element name="start" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="grammar" type="grammarType" minOccurs="0"/>
      <xs:element name="interpretation" type="unitInterval" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="grammarType" mixed="true">
    <!-- Grammar XML is intentionally open: configs may carry inline
         tier tags (<P>, <C>, <S>) and structured sections such as
         <compose>/<generate>, OR a bare text filename reference
         (``<grammar>complete.grammar</grammar>``) that
         ``SymbolicSubSpace.load_from_grammar_file`` resolves under
         ``data/``. ``mixed="true"`` admits both forms. Language.py
         owns rule parsing. -->
    <xs:sequence>
      <xs:any processContents="skip" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="grammarSectionType">
    <xs:sequence>
      <xs:any processContents="skip" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

</xs:schema>
