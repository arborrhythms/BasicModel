      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <xs:element name="whatPassThrough" type="xs:boolean" minOccurs="0"/>
      <xs:element name="wherePassThrough" type="xs:boolean" minOccurs="0"/>
      <xs:element name="whenPassThrough" type="xs:boolean" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="conceptualSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- DEPRECATED QKV legacy alias; inert. See attentionModeEnum. -->
      <xs:element name="hasAttention" type="xs:boolean" minOccurs="0"/>
      <!-- Symbolic-retrieval mode; default off. Supersedes <hasAttention>.
           See attentionModeEnum. -->
      <xs:element name="attention" type="attentionModeEnum" minOccurs="0"/>
      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="nonlinear" type="xs:boolean" minOccurs="0"/>
      <!-- Optional butterfly cascade on the ConceptualSpace sigma fold
           (cross-element mixing; the cascade length is auto-computed from
           the space shape; see perceptualSpaceType/butterfly). -->
      <!-- DEPRECATED alias for <sigmaPi> (true -> butterfly, false/absent
           -> last). New configs should use architecture-level <sigmaPi> instead. -->
      <xs:element name="butterfly" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <!-- VQ-VAE EMA / growing-codebook knobs (shared semantics with
           symbolicSpaceType; see comments there). -->
      <xs:element name="commitmentDecay" type="positiveFloat" minOccurs="0"/>
      <xs:element name="codebookRetire" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebookEmaDeadThreshold" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="codebookGrowthEpsilon" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="tetralemmaOverride" type="tetralemmaOverrideType" minOccurs="0"/>
      <xs:element name="TetralemmaPolicy" type="tetralemmaPolicyType" minOccurs="0"/>
      <xs:element name="stmCapacity" type="xs:positiveInteger" minOccurs="0"/>
      <!-- perWordStemSerial: when true, the per-word stem uses a
           causal cursor loop (option (a) from the K-microbatch
           design discussion) instead of the parallel-over-AR-windows
           default.  Serial path: B-sized STM accumulates one new
           word per step; after the K-loop the snapshots are staged
           as [B*K, K, D_c] for the body's chart-at-C parallelism.
           Work drops from O(B*K*N) to O(B*K) in the stem.  Inductor
           unrolls the loop when K is shape-bucketed (BPE power-of-
           two quantisation). -->
      <xs:element name="perWordStemSerial" type="xs:boolean" minOccurs="0"/>
      <!-- Per-space override of architecture.truthCriterion. -->
      <xs:element name="truthCriterion" type="unitInterval" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="symbolicSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nOutput" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nActive" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nDim" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nInputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nOutputDim" type="xs:integer" minOccurs="0"/>
      <xs:element name="nVectors" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhere" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="nWhen" type="xs:nonNegativeInteger" minOccurs="0"/>
      <xs:element name="passThrough" type="xs:boolean" minOccurs="0"/>
      <!-- Symbolic-retrieval mode (off|primer|second-order|low-rank);
           default off. SymbolicSpace has no hasAttention legacy alias:
           it never constructed a QKV AttentionLayer. See attentionModeEnum
           and doc/plans/2026-06-06-symbolic-heat-retrieval.md. -->
      <xs:element name="attention" type="attentionModeEnum" minOccurs="0"/>
      <xs:element name="invertible" type="xs:boolean" minOccurs="0"/>
      <xs:element name="nonlinear" type="xs:boolean" minOccurs="0"/>
      <!-- Optional butterfly cascade on the SymbolicSpace sigma operator
           (cross-slot mixing, needed for tasks like XOR that combine
           positions; the cascade length is auto-computed from the space
           shape; see perceptualSpaceType/butterfly). -->
      <!-- DEPRECATED alias for <sigmaPi> (true -> butterfly, false/absent
           -> last). New configs should use architecture-level <sigmaPi> instead. -->
      <xs:element name="butterfly" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebook" type="codebookModeEnum" minOccurs="0"/>
      <xs:element name="sortNetwork" type="xs:boolean" minOccurs="0"/>
      <xs:element name="sortPasses" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- Gate SymbolicSpace's stack-rewrite LanguageLayer dispatch
           (``self.use_stack_router``). Default false keeps the legacy
           forward path. -->
      <xs:element name="useStackRouter" type="xs:boolean" minOccurs="0"/>
      <xs:element name="l1Lambda" type="xs:decimal" minOccurs="0"/>
      <xs:element name="discontinuityLambda" type="xs:decimal" minOccurs="0"/>
      <xs:element name="symbolResidualScale" type="xs:decimal" minOccurs="0"/>
      <xs:element name="outputSymbolResidualScale" type="xs:decimal" minOccurs="0"/>
      <xs:element name="commitmentBeta" type="nonNegativeFloat" minOccurs="0"/>
      <!-- VQ-VAE EMA decay (``VectorQuantize.decay``).  Higher = slower
           adaptation, more stable assignment across time; lower =
           faster drift but less stable.  Default 0.9 (see
           doc/Spaces.md §"Codebook drift sync"). -->
      <xs:element name="commitmentDecay" type="positiveFloat" minOccurs="0"/>
      <!-- Dead-code retire: when a slot's EMA ``cluster_size`` falls
           below ``codebookEmaDeadThreshold``, replace it with a fresh
           sample from the current input batch.  Off by default
           because reseeding can blow up the effective number of
           distinct codes on non-stationary data; enable for
           growing-codebook semantics where novel inputs should evict
           rarely-used slots. -->
      <xs:element name="codebookRetire" type="xs:boolean" minOccurs="0"/>
      <xs:element name="codebookEmaDeadThreshold" type="xs:nonNegativeInteger" minOccurs="0"/>
      <!-- Novelty insertion threshold for ε-growing codebook semantics.
           When > 0, ``VectorQuantize.grow_on_novelty`` inserts an input
           vector into an empty slot whenever its min-distance to the
           live codebook exceeds this value.  0 disables (use
           dead-code retire above, or fixed-size codebook). -->
      <xs:element name="codebookGrowthEpsilon" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="decorrelationWeight" type="xs:decimal" minOccurs="0"/>
      <xs:element name="spectralFlatnessWeight" type="xs:decimal" minOccurs="0"/>
      <xs:element name="impenetrableAntisymmetry" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="impenetrableTransitivity" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="impenetrableOverlap" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="impenetrableVariance" type="nonNegativeFloat" minOccurs="0"/>
      <xs:element name="tetralemmaOverride" type="tetralemmaOverrideType" minOccurs="0"/>
      <xs:element name="TetralemmaPolicy" type="tetralemmaPolicyType" minOccurs="0"/>
      <!-- Stage 8 (doc/plans/2026-05-27-perceptstore-meta-taxonomy-
           reentrancy.md §Stage 8): META taxonomy storage placeholder.
           The actual taxonomy graph (parent -> children, child -> parent,
           and (ps_idx, ss_idx) -> meta_idx) is a runtime structure on
           ``SymbolicSpace`` (``self.taxonomy``,
           ``self.taxonomy_parent_map``, ``self.meta_pair_to_idx``);
           it serialises through ``vocab_extras`` (the same sidecar that
           carries WordVectors mappings). This optional XSD element exists
           so configs can ship a comment about the storage location and
           future seeded-taxonomy bootstraps without schema drift. The
           string contents are advisory only; no runtime knob is
           consumed from here. -->
      <xs:element name="taxonomy" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="outputSpaceType">
    <xs:all>
      <xs:element name="nInput" type="xs:nonNegativeInteger" minOccurs="0"/>
