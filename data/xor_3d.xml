<?xml version="1.0" ?>
<model>
  <architecture>
    <modelType>embedding</modelType>
    <weightsPath>xor_3d_weights.ckpt</weightsPath>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
    </training>
  </architecture>

  <InputSpace>
    <!-- nOutput sized to fit 2-word XOR strings ("hello world" etc.)
         plus one slot for the EOS sentinel reserved by _lex_batch.
         Was 2 under the legacy silent-truncation path; raised to 4
         when §8g of the brick-vectorization handoff replaced the
         truncation with an assert. -->
    <nOutput>4</nOutput>
    <nDim>10</nDim>
    <nVectors>4</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>4</nOutput>
    <nDim>10</nDim>
    <nVectors>16</nVectors>
    <codebook>true</codebook>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>4</nOutput>
    <nDim>10</nDim>
    <nVectors>16</nVectors>
    <codebook>true</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>4</nOutput>
    <nDim>10</nDim>
    <nVectors>4</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
