<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <symbolicOrder>0</symbolicOrder>
    <weightsPath>xor_3d_weights.ckpt</weightsPath>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
    </training>
  </architecture>

  <InputSpace>
    <!-- nOutput sized to fit 2-word XOR strings ("hello world" etc.)
         plus one slot for the EOS sentinel reserved by _lex_batch.
         Was 2 under the legacy silent-truncation path; raised to 4
         when §8g of the brick-vectorization handoff replaced the
         truncation with an assert. -->
    <nOutput>4</nOutput>
    <nDim>14</nDim>
    <nVectors>4</nVectors>
  </InputSpace>

  <PartSpace>
    <nOutput>4</nOutput>
    <nDim>14</nDim>
    <nVectors>16</nVectors>
  </PartSpace>

  <ConceptualSpace>
    <nOutput>4</nOutput>
    <nDim>14</nDim>
    <nVectors>16</nVectors>
    <codebook>quantize</codebook>
  </ConceptualSpace>

  <WholeSpace>
    <nOutput>4</nOutput>
    <nDim>14</nDim>
    <nVectors>4</nVectors>
  </WholeSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
