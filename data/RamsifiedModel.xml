<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- RamsifiedModel: MentalModel with conceptualOrder=2.
       Used by test_reasoning.py::TestWriteMask::test_partition_isolation. -->
  <architecture>
    <conceptualOrder>2</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <weightsPath>RamsifiedModel.ckpt</weightsPath>
    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>2</numEpochs>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>BACKPROP</trainEmbedding>
      <autoload>false</autoload>
    </training>

  </architecture>

  <WordSpace>
    <language>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>true(S)</S>
        <S>swap(S, S)</S>
        <S>isEqual(S, S)</S>
        <S>part(S, S)</S>
        <S>non(S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>union(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
        <S>lift(S, S, S)</S>
      </grammar>
    </language>
  </WordSpace>

  <InputSpace>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <nOutput>128</nOutput>
    <lexer>sentence</lexer>
    <codebook>quantize</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>128</nOutput>
    <nDim>104</nDim>
    <nVectors>128</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>100</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

</model>
