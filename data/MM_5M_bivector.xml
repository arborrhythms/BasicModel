<?xml version="1.0" ?>
<model>
  <!-- MM_5M_bivector: MM_5M with bivectorOutput on the C and S tiers
       only.  PerceptualSpace stays at its native 6-dim BPE codebook
       so the byte-stream embedding path is unchanged.  The narrow
       channel kicks in at the C-tier handoff: ConceptualSpace's
       ProjectionBasis projects from D=10 down to a per-prototype
       catuskoti [B, V_C, 2], SS then mirrors with [B, V_S, 2]
       activations.  The cross-stage chain through the body now
       carries 2 floats per prototype instead of 1028. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <modelType>embedding</modelType>
    <weightsPath>MM_5M_bivector.ckpt</weightsPath>
    <amp>bf16</amp>

    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>AR</trainEmbedding>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
    </training>

    <server>
      <port>8004</port>
    </server>

  </architecture>

  <InputSpace>
    <nInput>1024</nInput>
    <nDim>6</nDim>
    <nVectors>1024</nVectors>
    <nOutput>1024</nOutput>
    <nWhere>2</nWhere>
    <lexer>byte</lexer>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>4096</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nOutput>1024</nOutput>
    <hasAttention>false</hasAttention>
    <codebook>true</codebook>
    <chunking>bpe</chunking>
    <wordLearning>0</wordLearning>
  </PerceptualSpace>

  <ConceptualSpace>
    <!-- Bivector projection at C: input is the wide P-tier event
         [B, V_P=1024, D=10]; ProjectionBasis maps it through an
         LDU [D, V_C=512] kernel to a per-prototype catuskoti
         [B, V_C=512, 2].  PiLayer is the square-iso identity at
         nDim=nInputDim=10 (unchanged from non-bivector); the dim
         compression happens in the codebook's forward projection,
         not in pi. -->
    <nInput>1024</nInput>
    <nInputDim>10</nInputDim>
    <nOutput>8</nOutput>
    <nOutputDim>2</nOutputDim>
    <nDim>128</nDim>
    <nVectors>8</nVectors> <!-- 512 -->
    <codebook>true</codebook> <!-- true -->
    <invertible>true</invertible>
    <nonlinear>false</nonlinear>
    <bivectorOutput>true</bivectorOutput>
  </ConceptualSpace>

  <SymbolicSpace>
    <!-- Bivector pass-through at S: SS receives the [B, V_C=8, 2]
         bivector from C and emits [B, V_S=1024, 2].  D=2 throughout
         keeps the per-stage chain narrow.  nWhere/nWhen override
         the architecture defaults (2, 2); the bivector activation
         carries no positional axes, so the muxed-event width is
         simply nDim=2 and obj_symbol must collapse to 0 (otherwise
         OutputSpace flattens against a phantom 1024*6 stream that
         the actual [B, 1024, 2] bivector can't fill). -->
    <nInput>8</nInput>
    <nInputDim>2</nInputDim>
    <nDim>2</nDim>
    <nVectors>65536</nVectors>
    <nOutput>1024</nOutput>
    <nOutputDim>2</nOutputDim>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <codebook>true</codebook>
    <accumulateTruth>0</accumulateTruth>
    <nonlinear>false</nonlinear>
    <bivectorOutput>true</bivectorOutput>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>


  <WordSpace>
    <language>
      <start>S</start>
      <grammar>
        <P>P = sigma(P)</P>
        <C>C = pi(C)</C>
        <S>S = sigma(S)</S>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
