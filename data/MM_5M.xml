<?xml version="1.0" ?>
<model>
  <!-- MM_5M: MentalModel ~5M params with byte input and hierarchical
       progressive bottleneck. 8 levels from 1024x4 to 4x1024 (N*D=4096). -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <modelType>embedding</modelType>
    <weightsPath>MM_5M.ckpt</weightsPath>
    <amp>bf16</amp>

    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reverseScale>0.1</reverseScale>
      <maskedPrediction>ARIR</maskedPrediction>
      <trainEmbedding>AR</trainEmbedding>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
      <sentenceContextWindow>5</sentenceContextWindow>
    </training>

    <server>
      <port>8003</port>
    </server>

  </architecture>

  <InputSpace>
    <nInput>1024</nInput>
    <nDim>6</nDim>
    <nVectors>1024</nVectors>
    <nOutput>1024</nOutput>
    <nWhere>2</nWhere>
    <lexer>byte</lexer>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>4096</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nOutput>1024</nOutput>
    <hasAttention>false</hasAttention>
    <codebook>true</codebook>
    <chunking>bpe</chunking>
    <!-- wordLearning=0 at training time: the model uses a frozen
         BPE codebook (carried in the .ckpt bundle alongside the other
         weights). embed.py overrides this to 1 when building the
         codebook from scratch — that is the only stage where the
         vocab grows. -->
    <wordLearning>0</wordLearning>
  </PerceptualSpace>

  <!-- ConceptualSpace: final level shape is 4x1024.
       Hierarchical mode computes per-level shapes dynamically via _level_shapes. -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>1024</nDim>
    <nVectors>512</nVectors> <!-- 8 -->
    <codebook>true</codebook>
    <chunking>lexicon</chunking>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1024</nInput>
    <nDim>1024</nDim>
    <nInputDim>8</nInputDim>
    <nVectors>1024</nVectors>
    <nWhere>2</nWhere>
    <nOutput>1024</nOutput>
    <codebook>true</codebook>
    <accumulateTruth>0</accumulateTruth>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>


  <WordSpace>
    <language>
      <!-- Start nonterminal: SyntacticLayer.compose marks a soft sentence
           boundary when row b's parse stack reduces to a single live leaf
           of this category. Outer doc-streaming loop (runEpoch) drains
           the per-row signal and dispatches soft_reset(batch=b). -->
      <start>S</start>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). Previously these were
             supplied by the SyntacticLayer's default_rule
             code-level fallback. -->
        <P>P = sigma(P)</P>
        <C>C = pi(C)</C>
        <S>S = sigma(S)</S>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
