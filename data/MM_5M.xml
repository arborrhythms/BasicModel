<?xml version="1.0" ?>
<model>
  <!-- MM_5M: MentalModel ~5M params with byte input and hierarchical
       progressive bottleneck. 8 levels from 1024x4 to 4x1024 (N*D=4096). -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <weightsPath>MM_5M.ckpt</weightsPath>
    <!-- Pre-built 1M-word lexicon (built via embed.py vocab-extract).
         Freezes the embedding vocab at startup so the per-word route
         does not grow the codebook in-call. Vocab growth re-traces the
         Inductor graph and triggers per-tick recompiles (visible as
         repeated "Online softmax is disabled on the fly" warnings and
         Δ spikes from ~0.5s to 100-300s). -->
    <embeddingPath>output/embeddings/MM_5M_1M_words.kv</embeddingPath>
    <amp>bf16</amp>

    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <!-- batchSize reduced from 128 to 8 on 2026-05-13.  The
           SymbolicSpace.sigma-retirement refactor (commit d3e256b)
           widened SS.nDim from 6 to 1024 so the C->S handoff is
           dimensionally a pass-through, and per-stage ConceptualSpace
           now sources percept-dim input from the stem-cached
           ``perceptualSpace.event`` (kept live across the body's
           per-stage loop).  Together these inflate the per-batch
           activation slab through 3 stages * [B*K, N=1024, D=1028]
           in bf16, which OOMs the 121 GiB GB10 unified pool past
	          batchSize=8.  Sweep on 2026-05-13: bs=2/4/8 fit cleanly,
	          bs=12 OOMs at the codebook commitment-loss MSE. Restore
	          128 after the activation slab is reduced or the per-stage
	          chain re-sources from a narrower representation. -->
      <batchSize>64</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reconstructionScale>0.1</reconstructionScale>
      <trainEmbedding>BACKPROP</trainEmbedding>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
    </training>

    <server>
      <port>8003</port>
    </server>

  </architecture>

  <!-- Stage 1.D re-architecture (2026-05-27): the flat-slab invariant
       requires IS.nOutput*IS.nDim == PS.nOutput*PS.nDim == CS.nOutput*CS.nDim
       so the IS->PS->CS handoff is a pure reshape, not a re-dimensioning.
       The CS terminal width was 8*1024=8192; to satisfy the invariant
       while preserving the 1024-slot input character of the architecture,
       IS/PS slot dim raised from 6 to 8 (1024*8=8192). The progressive
       bottleneck preserved: 1024 wide slots -> 8 wide concept slots,
       same flat slab 8192 carried throughout.

       Other knobs preserved: PS.nVectors=4096 (BPE codebook capacity);
       SS.nVectors=65536 (lexicon capacity); CS.stmCapacity=7. -->
  <InputSpace>
    <nInput>1024</nInput>
    <nDim>12</nDim>
    <nVectors>1024</nVectors>
    <nOutput>1024</nOutput>
    <lexer>byte</lexer>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>4096</nVectors>
    <nDim>12</nDim>
    <nOutput>1024</nOutput>
    <codebook>quantize</codebook>
    <chunking>bpe</chunking>
    <!-- wordLearning=0 at training time: the model uses a frozen
         BPE codebook (carried in the .ckpt bundle alongside the other
         weights). embed.py overrides this to 1 when building the
         codebook from scratch — that is the only stage where the
         vocab grows. -->
    <wordLearning>0</wordLearning>
  </PerceptualSpace>

  <!-- ConceptualSpace: final level shape is 8x1024 (flat slab 8192).
       Hierarchical mode computes per-level shapes dynamically via _level_shapes. -->
  <ConceptualSpace>
    <nOutput>8</nOutput>
    <nDim>1028</nDim>
    <nVectors>8</nVectors> <!-- 512 -->
    <codebook>none</codebook> <!-- true -->
    <!-- H2: STM capacity = the classical 7±2 working-memory bound. The
         [B, 7, concept_dim=1024] STM slab passes through the widened
         idempotent C->S->C symbolic-space loop
         (BasicModel._stm_symbolic_roundtrip), making it the STM
         read/write. Was previously the wMax-or-8 fallback (=8 here:
	         no <stmCapacity>, no <WordSpace><wMax>). Phase-1-D STM-7
	         decision; <wMax> remains the parser span-width fallback. -->
    <stmCapacity>7</stmCapacity>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1024</nInput>
    <nDim>1024</nDim>
    <nInputDim>8</nInputDim>
    <!-- Stage 1.B paired-row contract (2026-05-27): SS.codebook gains
         paired orth + semantic rows per word in PS's lexicon, so
         SS.nVectors must be at least 2*PS_lexicon_capacity to hold
         the paired rows. PS uses Embedding._LEXICON_DEFAULT_CAPACITY=65536,
         doubled to 131072 for the orth+semantic pair. -->
    <nVectors>131072</nVectors>
    <nOutput>1024</nOutput>
    <codebook>quantize</codebook>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>


  <WordSpace>
    <language>
      <!-- Start nonterminal: SyntacticLayer.compose marks a soft sentence
           boundary when row b's parse stack reduces to a single live leaf
           of this category. Outer doc-streaming loop (runEpoch) drains
           the per-row signal and dispatches soft_reset(batch=b). -->
      <start>S</start>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). Previously these were
             supplied by the SyntacticLayer's default_rule
             code-level fallback. -->
        <P>P = sigma(P)</P>
        <C>C = pi(C)</C>
        <S>S = sigma(S)</S>
        <S>S = intersection(S, S)</S>
        <S>S = union(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

</model>
