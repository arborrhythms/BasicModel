<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- Step 4 (legacy name): conceptualOrder=3, nVectors=8. Butterfly path retired
       2026-05-12; this config now matches Step 3 modulo the original flag. -->
  <architecture>
    <conceptualOrder>3</conceptualOrder>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <ergodic>true</ergodic>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>

  </architecture>

  <WordSpace>
    <language>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>union(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): IS, PS, CS share
       the same flat slab. CS terminal is 16*12=192; IS/PS aligned to
       16*12=192 (nOutput=16, nDim=12). -->
  <InputSpace>
    <nOutput>16</nOutput>
    <nDim>16</nDim>
    <nVectors>16</nVectors>
    <nInputDim>-1</nInputDim>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>16</nOutput>
    <nDim>16</nDim>
    <nVectors>16</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>16</nOutput>
    <nDim>16</nDim>
    <nVectors>16</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nDim>12</nDim>
    <nOutput>8</nOutput>
    <nVectors>8</nVectors>
    <nInputDim>-1</nInputDim>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
