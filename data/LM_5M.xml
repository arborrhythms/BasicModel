<?xml version="1.0" ?>
<model>
  <!-- LM_5M: grammar-driven sibling of MM_5M.

       Same data / dim budget as MM_5M, but:
         * useButterflies=false   (constituency structure replaces the
                                   N-halving butterfly permutations)
         * useGrammar=all         (per-space SyntacticLayers dispatch
                                   on the chart's rule selections, not
                                   the unary pi/sigma defaults)
         * conceptualOrder=1      (the per-stage Sigma-Pi cascade is
                                   replaced by single-stage chart-driven
                                   composition; useButterflies+useGrammar
                                   are mutually exclusive at order > 1)
         * softChartCompose=true  (CKY inside pass populates current_rules)
         * <wMax>                 (must be set explicitly because the
                                   chart's default w_max=8 would silently
                                   truncate any sentence > 7 tokens)
         * grammar block          (full English grammar instead of the
                                   trivial S=intersection/union pair)
         * mereologicalTreeSize   (matches symbolic codebook V; the new
                                   tree is writes-disabled by default,
                                   so this only affects the size of the
                                   parents/start/end buffers).

       Distinct ckpt/kv paths so LM_5M and MM_5M training can coexist.
       Server port also distinct so both can serve in parallel.
  -->
  <architecture>
    <!-- conceptualOrder=3: per-stage Sigma-Pi cascade depth.  At least 3
         to give the chart a reasonable tree depth (each conceptual stage
         is one level of the constituency hierarchy; 3 stages cover S ->
         NP/VP -> N/V/AP -> word).  useButterflies must stay false at
         order > 1 because Models.py forbids butterfly+useGrammar='all'. -->
    <conceptualOrder>3</conceptualOrder>
    <l1Lambda>0.01</l1Lambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <modelType>embedding</modelType>
    <weightsPath>LM_5M.ckpt</weightsPath>
    <amp>bf16</amp>

    <!-- MereologicalTree size matches SymbolicSpace nVectors so
         _argmax_prototype indices are always in range. The tree's
         writes_enabled flag stays False until the chart's POS / rule
         pipeline is reliable enough to commit assertions. -->
    <mereologicalTreeSize>1024</mereologicalTreeSize>

    <!-- Per-stage chart re-parse: each conceptualOrder stage runs
         its own chart pass on the previous stage's symbolic output.
         Compounds the chart's compositional capacity across stages
         (stage 0 parses words, stage 1 phrases, stage 2 clauses)
         instead of consuming one parse three times.  Cost: chart
         runs T times per batch (T = conceptualOrder). -->
    <perStageChartReparse>true</perStageChartReparse>

    <!-- Sparse-MoE load-balance loss weight (Shazeer et al. 2017).
         Penalises CV² of per-rule activation counts so the noisy
         top-K gating spreads mass across rules instead of collapsing
         onto 1-2 rules.  Active only when chartTopK > 0. -->
    <loadBalanceWeight>0.01</loadBalanceWeight>

    <data>
      <shardDir>data/fineweb</shardDir>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numEpochs>1</numEpochs>
      <batchSize>128</batchSize>
      <numWorkers>4</numWorkers>
      <learningRate>0.0005</learningRate>
      <reverseScale>0.1</reverseScale>
      <!-- ARIR (autoregressive + masked-fill).  AR loop trains the
           model for next-token generation; IR adds reconstruction loss
           at masked positions on the same forward.  K microbatch
           windows per batch (one per AR step) so chart cost scales as
           K times the per-call inside-pass cost.  The IR-only sibling
           LM_5M_IR.xml runs the chart once per batch and trains the
           same parameter shape, so transferring weights between the
           two configs is straightforward. -->
      <maskedPrediction>ARIR</maskedPrediction>
      <trainEmbedding>AR</trainEmbedding>
      <autosave>true</autosave>
      <sentencePrediction>true</sentencePrediction>
      <sentenceContextWindow>5</sentenceContextWindow>
    </training>

    <server>
      <port>8005</port>
    </server>

  </architecture>

  <InputSpace>
    <nInput>1024</nInput>
    <nDim>6</nDim>
    <nVectors>1024</nVectors>
    <nOutput>1024</nOutput>
    <nWhere>2</nWhere>
    <lexer>byte</lexer>
  </InputSpace>

  <PerceptualSpace>
    <nInput>1024</nInput>
    <nVectors>4096</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nOutput>1024</nOutput>
    <hasAttention>false</hasAttention>
    <codebook>true</codebook>
    <chunking>bpe</chunking>
    <wordLearning>0</wordLearning>
  </PerceptualSpace>

  <!-- ConceptualSpace: 3 stages (conceptualOrder=3 above) replace
       MM_5M's 8-level hierarchical butterfly.  The chart's CKY-driven
       composition is the structural replacement for the per-stage
       Sigma-Pi cascade; 3 stages give the chart enough tree depth for
       basic constituency (S, NP/VP, word). -->
  <ConceptualSpace>
    <nOutput>1024</nOutput>
    <nDim>6</nDim>
    <nVectors>1024</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nInput>1024</nInput>
    <nInputDim>6</nInputDim>
    <nVectors>1024</nVectors>
    <nDim>6</nDim>
    <nWhere>2</nWhere>
    <nOutput>1024</nOutput>
    <codebook>true</codebook>
    <accumulateTruth>0</accumulateTruth>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>4</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>

  <WordSpace>
    <useGrammar>all</useGrammar>
    <chartCompose>true</chartCompose>
    <softChartCompose>true</softChartCompose>
    <chartTau>2.0</chartTau>
    <!-- N=1024 (input length); chart cost scales as N * w_max^2 * R.
         32 covers any sub-sentence chunk from the byte-level lexer
         while keeping per-row cost at ~ N * 1024 * R = 1M cell-rule
         evaluations, which fits the MM_5M perf envelope. Raise to N
         for full-sentence parsing (cost goes ~32x). -->
    <wMax>32</wMax>
    <!-- Sparse-MoE rule gating (Shazeer et al. 2017).  At each
         (cell, split), keep only the top-K rules by (score + Gaussian
         noise); the rest are masked.  Cuts effective per-cell rule
         cost from R=23 to chart_top_k=4 (~6x speedup on the
         per-rule grammar-layer forward pass) while keeping rare-rule
         gradients alive via the noise.  Disabled at eval (no
         exploration during Viterbi). -->
    <chartTopK>4</chartTopK>
    <chartNoiseEps>0.1</chartNoiseEps>
    <language>
      <start>S</start>
      <grammar>
        <compose>
          <symbols>
            <!-- Sentence (root span only - sentence-level rules don't
                 apply to sub-sentence chunks).  Rules without width=
                 fire at any width. -->
            <rule width="1..">S = NP</rule>
            <rule width="3..">S = lift(NP, VP)</rule>
            <rule width="3..">S = equals(NP, NP)</rule>
            <rule width="3..">S = equals(NP, AP)</rule>
            <rule width="3..">S = part(NP, NP)</rule>
            <rule width="2..">S = not(S)</rule>
            <rule width="3..">S = conjunction(S, S)</rule>
            <rule width="3..">S = disjunction(S, S)</rule>

            <!-- Noun Phrase -->
            <rule width="1..1">NP = N</rule>
            <rule width="2..">NP = AP</rule>
            <rule width="3..">NP = conjunction(NP, NP)</rule>
            <rule width="3..">NP = disjunction(NP, NP)</rule>

            <!-- Verb Phrase -->
            <rule width="1..1">VP = V</rule>
            <rule width="2..">VP = intersection(V, O)</rule>
            <rule width="2..">VP = lower(ADV, VP)</rule>
            <rule width="2..">VP = lower(ADJ, VP)</rule>

            <!-- Object -->
            <rule width="1..">O = NP</rule>

            <!-- Adjective Phrase -->
            <rule width="2..">AP = lower(ADJ, NP)</rule>
            <rule width="2..">AP = lower(ADJ, AP)</rule>
            <rule width="2..">AP = lower(DET, NP)</rule>

            <!-- Prepositional Phrase.
                 PP = lift(P, NP): the preposition transforms its NP
                 complement from a thing into a relation/location.
                 Attachment is via lower onto NP / VP heads. -->
            <rule width="2..">PP = lift(P, NP)</rule>
            <rule width="3..">NP = lower(NP, PP)</rule>
            <rule width="3..">VP = lower(VP, PP)</rule>
          </symbols>
        </compose>
      </grammar>
    </language>
  </WordSpace>

</model>
