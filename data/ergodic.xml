<?xml version="1.0" ?>
<model>
  <architecture>
    <ergodic>true</ergodic>
    <certainty>true</certainty>
    <modelType>simple</modelType>

    <data>
      <dataset>mnist</dataset>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>10</numEpochs>
      <batchSize>64</batchSize>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>784</nOutput>
    <nDim>1</nDim>
    <nVectors>784</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>784</nOutput>
    <nDim>1</nDim>
    <nVectors>784</nVectors>
    <passThrough>true</passThrough>
  </PerceptualSpace>

  <ConceptualSpace>
    <nOutput>20</nOutput>
    <nDim>1</nDim>
    <nVectors>20</nVectors>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>20</nOutput>
    <nDim>0</nDim>
    <nVectors>20</nVectors>
    <passThrough>true</passThrough>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>10</nOutput>
    <nDim>1</nDim>
    <nVectors>10</nVectors>
  </OutputSpace>
</model>
