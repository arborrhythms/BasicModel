<?xml version="1.0" ?>
<model>
  <architecture>
    <!-- Stage 1.E: non-grammar (whole-slab) config — per-stage forward
         dispatch via _forward_per_stage's body. -->
    <conceptualMode>parallel</conceptualMode>
    <ergodic>true</ergodic>

    <data>
      <dataset>mnist</dataset>
    </data>

    <training>
      <numEpochs>10</numEpochs>
      <certainty>true</certainty>
    </training>
  </architecture>

  <InputSpace>
    <nOutput>784</nOutput>
    <nVectors>784</nVectors>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>784</nOutput>
    <nVectors>784</nVectors>
  </PerceptualSpace>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): the invariant fires
       only in embedding mode; this config is SimpleModel (no
       <modelType>embedding</modelType>) so the architectural slab
       can re-dimension across tiers. CS shape unchanged. -->
  <ConceptualSpace>
    <nOutput>20</nOutput>
    <nVectors>20</nVectors>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>20</nOutput>
    <nDim>0</nDim>
    <nVectors>20</nVectors>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>10</nOutput>
    <nVectors>10</nVectors>
  </OutputSpace>
</model>
