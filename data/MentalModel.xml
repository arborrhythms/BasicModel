<?xml version="1.0" ?>
<model>
  <!-- MentalModel: iterative [Percept,Symbol]→Concept→Symbol loop.
       ConceptualSpace receives [percepts, symbols] (symbols=0 at T=1).
       SyntacticSpace runs composeSyntax over symbol activations each iteration.
       OutputSpace is fed by the final ConceptualSpace output. -->
  <architecture>
    <type>mental</type>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <symbolicOrder>1</symbolicOrder>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <ergodic>false</ergodic>
    <certainty>false</certainty>
    <syntax>true</syntax>
    <modelType>embedding</modelType>
    <maskedPrediction>ARLM</maskedPrediction>
    <maxResponseLength>4096</maxResponseLength>
    <weightsPath>MentalModel.ckpt</weightsPath>
    <embeddingPath>MentalModel.kv</embeddingPath>

    <data>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>2</numEpochs>
      <batchSize>8</batchSize>
      <learningRate>0.001</learningRate>
      <reverseScale>0.1</reverseScale>
      <trainEmbedding>ARLM</trainEmbedding>
      <autoload>false</autoload>
      <autosave>true</autosave>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8002</port>
      <timeout>120</timeout>
    </server>
  </architecture>

  <InputSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <lexer>sentence</lexer>
    <quantized>true</quantized>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>true</passThrough>
    <hasAttention>false</hasAttention>
    <invertible>false</invertible>
    <quantized>false</quantized>
  </PerceptualSpace>

  <!-- ConceptualSpace receives [Percept, Symbol] in iterative MentalModel,
       so input count = nPercepts + nSymbols. Keeps same dim as BasicModel. -->
  <ConceptualSpace>
    <nOutput>256</nOutput>
    <nDim>100</nDim>
    <nVectors>256</nVectors>
    <hasAttention>true</hasAttention>
    <hasNorm>false</hasNorm>
    <invertible>true</invertible>
    <quantized>false</quantized>
    <normedWeights>false</normedWeights>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>false</passThrough>
    <normedWeights>false</normedWeights>
  </SymbolicSpace>

  <SyntacticSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
  </SyntacticSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>100</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
  </OutputSpace>

</model>
