<?xml version="1.0" ?>
<model>
  <!-- MentalModel: iterative [Percept,Symbol]→Concept→Symbol loop.
       ConceptualSpace receives [percepts, symbols] (symbols=0 at T=1).
       SyntacticSpace runs composeSyntax over symbol activations each iteration.
       OutputSpace is fed by the final ConceptualSpace output. -->
  <architecture>
    <reconstruct>symbols</reconstruct>
    <conceptualOrder>1</conceptualOrder>
    <useButterflies>false</useButterflies>
    <l1Lambda>0.01</l1Lambda>
    <discontinuityLambda>0.0</discontinuityLambda>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <processSymbols>false</processSymbols>
    <type>mental</type>
    <ergodic>false</ergodic>
    <modelType>embedding</modelType>
    <maskedPrediction>ARLM</maskedPrediction>
    <truthBiasScale>0.1</truthBiasScale>
    <LuminosityWeight>0.1</LuminosityWeight>
    <UniversalityWeight>0.1</UniversalityWeight>
    <maxResponseLength>4096</maxResponseLength>
    <weightsPath>MentalModel.ckpt</weightsPath>
    <embeddingPath>MentalModel.kv</embeddingPath>

    <data>
      <shardDir>data/fineweb</shardDir>
      <numShards>1</numShards>
      <maxDocs>10000</maxDocs>
      <minFrequency>0.00001</minFrequency>
    </data>

    <training>
      <numTrials>1</numTrials>
      <numEpochs>2</numEpochs>
      <batchSize>64</batchSize>
      <learningRate>0.001</learningRate>
      <reverseScale>0.1</reverseScale>
      <trainEmbedding>ARLM</trainEmbedding>
      <autoload>false</autoload>
      <autosave>true</autosave>
      <certainty>false</certainty>

      <!-- Inter-sentence (discourse) prediction: ring buffer of
           [S|W] snapshots + per-row linear predictor. Defaults for
           history/context/scale are 8/3/0.1. -->
      <sentencePrediction>true</sentencePrediction>
    </training>

    <server>
      <host>127.0.0.1</host>
      <port>8002</port>
      <timeout>120</timeout>
    </server>

  </architecture>

  <WordSpace>
    <useGrammar>none</useGrammar>

    <!-- LearnedSVO: route compose through the chart-like pair-scorer
         path so SVO rides the grammar's S -> S VO / VO -> V O rules
         instead of the positional heuristic. Generation stays off by
         default; flip to true to populate ``_predicted_head`` via the
         downward S -> C head emission. -->
    <chartCompose>true</chartCompose>
    <downwardGeneration>false</downwardGeneration>

    <language>
      <grammar>
        <upward>
          <!-- Legacy function-call rules (unchanged semantics) -->
          <S>true(S)</S>
          <S>false(S)</S>
          <S>non(S)</S>
          <S>conjunction(S, S)</S>
          <S>disjunction(S, S)</S>
          <S>what(S)</S>
          <S>where(S)</S>
          <S>when(S)</S>
          <S>query(S, S)</S>
          <S>swap(S, S)</S>
          <S>equals(S, S)</S>
          <S>not(S)</S>
          <S>part(S, S)</S>
          <S>intersection(S, S)</S>
          <S>union(S, S)</S>
          <S>lower(S, S)</S>
          <S>lift(S, S)</S>
          <!-- Typed productions (LearnedSVO Phase A.4) -->
          <S>S VO</S>
          <VO>V O</VO>
        </upward>
        <downward>
          <!-- MVP: emit the codebook atom closest to the deep state -->
          <S>C</S>
        </downward>
      </grammar>
      <interpretation>0.5</interpretation>
    </language>
  </WordSpace>

  <InputSpace>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <nOutput>128</nOutput>
    <nWhere>2</nWhere>
    <nWhen>2</nWhen>
    <lexer>sentence</lexer>
    <codebook>true</codebook>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>true</passThrough>
    <hasAttention>false</hasAttention>
    <invertible>false</invertible>
    <codebook>false</codebook>
  </PerceptualSpace>

  <!-- ConceptualSpace: matches percept/symbol row count; state mixing
       happens via iterative Sigma-Pi (not concatenation). -->
  <ConceptualSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <hasAttention>true</hasAttention>
    <invertible>true</invertible>
    <codebook>false</codebook>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>128</nOutput>
    <nDim>100</nDim>
    <nVectors>128</nVectors>
    <passThrough>false</passThrough>
    <accumulateTruth>0</accumulateTruth>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>100</nDim>
    <nVectors>1</nVectors>
    <nWhere>0</nWhere>
    <nWhen>0</nWhen>
    <nonlinear>false</nonlinear>
  </OutputSpace>

</model>
