<?xml version="1.0" ?>
<model>
  <!-- Step 3: Step 2 + grammar -->
  <architecture>
    <modelType>embedding</modelType>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <conceptualMode>serial</conceptualMode>
    <ergodic>true</ergodic>
    <nWhere>2</nWhere>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>

  </architecture>

  <WordSpace>
    <language>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>union(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
      </grammar>
    </language>
  </WordSpace>

  <InputSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
    <nWhere>2</nWhere>
    <nWhen>0</nWhen>
  </InputSpace>

  <PerceptualSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
    <hasAttention>false</hasAttention>
  </PerceptualSpace>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): CS aligned to IS/PS. -->
  <ConceptualSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
    <invertible>true</invertible>
  </ConceptualSpace>

  <SymbolicSpace>
    <nOutput>6</nOutput>
    <nDim>10</nDim>
    <nVectors>6</nVectors>
    <nInputDim>-1</nInputDim>
  </SymbolicSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
