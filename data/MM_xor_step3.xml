<?xml version="1.0" ?>
<model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="model.xsd">
  <!-- Step 3: Step 2 + grammar -->
  <architecture>
    <data>
      <dataType>embedding</dataType>
    </data>
    <!-- Stage 1.E: grammar config (non-substrate rules below) — per-word
         forward dispatch via _forward_body_per_word. -->
    <symbolicOrder>1</symbolicOrder>
    <ergodic>true</ergodic>

    <training>
      <numEpochs>200</numEpochs>
      <learningRate>0.01</learningRate>
      <autoload>false</autoload>
      <trainEmbedding>JOINT</trainEmbedding>
      <embeddingScale>0.05</embeddingScale>
    </training>

  </architecture>

  <SymbolSpace>
    <language>
      <grammar>
        <!-- Per the 2026-05-07 rollback: explicit per-tier natural
             folds (sigma at P / S, pi at C). -->
        <P>sigma(P)</P>
        <C>pi(C)</C>
        <S>sigma(S)</S>
        <S>not(S)</S>
        <S>intersection(S, S)</S>
        <S>join(S, S)</S>
        <S>lower(S, S)</S>
        <S>lift(S, S)</S>
      </grammar>
    </language>
  </SymbolSpace>

  <InputSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
  </InputSpace>

  <PartSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <invertible>true</invertible>
  </PartSpace>

  <!-- Stage 1.D flat-slab invariant (2026-05-27): CS aligned to IS/PS. -->
  <ConceptualSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
    <invertible>true</invertible>
  </ConceptualSpace>

  <WholeSpace>
    <nOutput>6</nOutput>
    <nDim>14</nDim>
    <nVectors>6</nVectors>
  </WholeSpace>

  <OutputSpace>
    <nOutput>1</nOutput>
    <nDim>1</nDim>
    <nVectors>1</nVectors>
  </OutputSpace>
</model>
